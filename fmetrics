rebuild_analytics() {
  ensure_db
  local rebuilt_at
  rebuilt_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

sqlite3 "$DB_FILE" <<SQL >/dev/null 2>&1 || die "analytics rebuild failed"
BEGIN IMMEDIATE;
DELETE FROM run_steps_v1;
DELETE FROM run_facts_v1;
DELETE FROM combo_stats_v1;
DELETE FROM combo_next_stats_v1;
INSERT INTO run_steps_v1 (run_id, step_index, project_name, tool, exit_code, duration_ms)
SELECT
  run_id,
  ROW_NUMBER() OVER (PARTITION BY run_id ORDER BY timestamp, id) AS step_index,
  COALESCE(project_name, '') AS project_name,
  tool,
  exit_code,
  duration_ms
FROM telemetry
WHERE COALESCE(run_id, '') != ''
;
INSERT INTO run_facts_v1 (run_id, first_timestamp, last_timestamp, project_name, tool_count, nonzero_exit_count, tools_csv, tool_sequence, total_duration_ms)
SELECT
  t.run_id,
  MIN(t.timestamp) AS first_timestamp,
  MAX(t.timestamp) AS last_timestamp,
  COALESCE(MAX(t.project_name), '') AS project_name,
  COUNT(*) AS tool_count,
  SUM(CASE WHEN t.exit_code != 0 THEN 1 ELSE 0 END) AS nonzero_exit_count,
  COALESCE((
    SELECT group_concat(tool, ',')
    FROM (
      SELECT DISTINCT rs.tool AS tool
      FROM run_steps_v1 rs
      WHERE rs.run_id = t.run_id
      ORDER BY rs.tool
    )
  ), '') AS tools_csv,
  COALESCE((
    SELECT group_concat(tool, '>')
    FROM (
      SELECT rs2.tool AS tool
      FROM run_steps_v1 rs2
      WHERE rs2.run_id = t.run_id
      ORDER BY rs2.step_index
    )
  ), '') AS tool_sequence,
  COALESCE(SUM(t.duration_ms), 0) AS total_duration_ms
FROM telemetry t
WHERE COALESCE(t.run_id, '') != ''
GROUP BY t.run_id;
INSERT INTO combo_stats_v1 (project_name, combo_key, step_count, occurrence_count, clean_run_count, faulted_run_count, avg_duration_ms, total_duration_ms)
SELECT
  project_name,
  tool_sequence AS combo_key,
  tool_count AS step_count,
  COUNT(*) AS occurrence_count,
  SUM(CASE WHEN nonzero_exit_count = 0 THEN 1 ELSE 0 END) AS clean_run_count,
  SUM(CASE WHEN nonzero_exit_count != 0 THEN 1 ELSE 0 END) AS faulted_run_count,
  CAST(AVG(total_duration_ms) AS INTEGER) AS avg_duration_ms,
  COALESCE(SUM(total_duration_ms), 0) AS total_duration_ms
FROM run_facts_v1
WHERE tool_sequence != ''
GROUP BY project_name, tool_sequence, tool_count;
WITH prefix_edges AS (
  SELECT
    rs.run_id,
    rs.project_name,
    rs.step_index AS prefix_step_count,
    (
      SELECT group_concat(tool, '>')
      FROM (
        SELECT prefix.tool AS tool
        FROM run_steps_v1 prefix
        WHERE prefix.run_id = rs.run_id
          AND prefix.step_index <= rs.step_index
        ORDER BY prefix.step_index
      )
    ) AS prefix_key,
    next_rs.tool AS next_tool
  FROM run_steps_v1 rs
  JOIN run_steps_v1 next_rs
    ON next_rs.run_id = rs.run_id
   AND next_rs.step_index = rs.step_index + 1
)
INSERT INTO combo_next_stats_v1 (project_name, prefix_key, prefix_step_count, next_tool, support_count, clean_run_count, faulted_run_count, avg_duration_ms, total_duration_ms)
SELECT
  pe.project_name,
  COALESCE(pe.prefix_key, ''),
  pe.prefix_step_count,
  pe.next_tool,
  COUNT(*) AS support_count,
  SUM(CASE WHEN rf.nonzero_exit_count = 0 THEN 1 ELSE 0 END) AS clean_run_count,
  SUM(CASE WHEN rf.nonzero_exit_count != 0 THEN 1 ELSE 0 END) AS faulted_run_count,
  CAST(AVG(rf.total_duration_ms) AS INTEGER) AS avg_duration_ms,
  COALESCE(SUM(rf.total_duration_ms), 0) AS total_duration_ms
FROM prefix_edges pe
JOIN run_facts_v1 rf ON rf.run_id = pe.run_id
WHERE COALESCE(pe.prefix_key, '') != ''
GROUP BY pe.project_name, pe.prefix_key, pe.prefix_step_count, pe.next_tool;
INSERT INTO analytics_meta (key, value) VALUES ('analytics_version', '2')
  ON CONFLICT(key) DO UPDATE SET value=excluded.value;
INSERT INTO analytics_meta (key, value) VALUES ('last_rebuilt_at', '$rebuilt_at')
  ON CONFLICT(key) DO UPDATE SET value=excluded.value;
COMMIT;
SQL
}

# -------------------------
# Usage
# -------------------------
usage() {
  cat <<'EOF'
fmetrics — performance telemetry and analytics for fsuite

USAGE
  fmetrics <subcommand> [options]

  SUBCOMMANDS
    stats              Show dashboard of tool usage, runtimes, reliability
    history            Show recent runs (filterable)
    combos             Show telemetry-backed combo patterns
    recommend          Suggest the strongest next tool after a prefix
    predict <path>     Estimate how long fsuite tools will take on <path>
    import             Ingest telemetry.jsonl into SQLite database
    clean              Prune old telemetry data
  profile            Show machine profile (Tier 3 telemetry)

OPTIONS (global)
  -o, --output       Output format: pretty (default) or json
  -h, --help         Show this help
  --version          Print version
  --self-check       Verify dependencies
  --install-hints    Print install commands for missing dependencies

  OPTIONS (history)
    --tool <name>      Filter by tool (ftree, fsearch, fcontent)
    --project <name>   Filter by project name
    --limit <N>        Max rows (default 20)

  OPTIONS (combos)
    --project <name>           Filter by project name
    --starts-with <tool,...>   Require combo prefix
    --contains <tool>          Require a tool anywhere in the combo
    --min-occurrences <N>      Minimum occurrence count (default 1)

  OPTIONS (recommend)
    --after <tool,...>         Prefix to continue from
    --project <name>           Filter by project name
    --limit <N>                Max recommendations (default 20)

OPTIONS (predict)
  --tool <name>      Predict for specific tool only (ftree, fsearch, fcontent)
  --mode <name>      Restrict ftree predictions to tree, recon, or snapshot

OPTIONS (clean)
  --days <N>         Keep last N days (default 90)
  --dry-run          Preview what would be deleted

ENVIRONMENT
  FSUITE_TELEMETRY=0  Disable telemetry collection in fsuite tools

EXAMPLES
    fmetrics import              Import telemetry data into SQLite
    fmetrics stats               Show usage dashboard
    fmetrics stats -o json       Machine-readable stats
    fmetrics history --tool ftree --limit 10
    fmetrics combos --project fsuite -o json
    fmetrics recommend --after ftree,fsearch --project fsuite
    fmetrics predict /project    Estimate runtimes for /project
    fmetrics predict --tool ftree --mode snapshot /project
    fmetrics clean --days 30     Remove data older than 30 days
EOF
}

# -------------------------
# Subcommand: import
# -------------------------
cmd_import() {
  ensure_db

  if [[ ! -f "$JSONL_FILE" ]]; then
    rebuild_analytics
    echo "No telemetry data found at $JSONL_FILE"
    echo "Run fsuite tools (ftree, fsearch, fcontent) to generate telemetry."
    return 0
  fi

  local total=0 inserted=0 skipped=0 errors=0

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    (( total++ )) || true

    # Parse JSON fields using portable json_get (no grep -oP / PCRE dependency)
    local ts tool ver mode ph pn dur ec dep items bytes flags backend run_id
    local cpu_temp disk_temp ram_total ram_avail load_avg
    ts=$(json_get "$line" "timestamp") || true
    [[ -n "$ts" ]] || { (( errors++ )); continue; }
    tool=$(json_get "$line" "tool") || true
    [[ -n "$tool" ]] || { (( errors++ )); continue; }
    ver=$(json_get "$line" "version") || ver=""
    mode=$(json_get "$line" "mode") || mode=""
    ph=$(json_get "$line" "path_hash") || ph=""
    pn=$(json_get "$line" "project_name") || pn=""
    dur=$(json_get "$line" "duration_ms") || dur=0
    [[ "$dur" =~ ^-?[0-9]+$ ]] || dur=0
    ec=$(json_get "$line" "exit_code") || ec=0
    [[ "$ec" =~ ^[0-9]+$ ]] || ec=0
    dep=$(json_get "$line" "depth") || dep=-1
    [[ "$dep" =~ ^-?[0-9]+$ ]] || dep=-1
    items=$(json_get "$line" "items_scanned") || items=-1
    [[ "$items" =~ ^-?[0-9]+$ ]] || items=-1
    bytes=$(json_get "$line" "bytes_scanned") || bytes=-1
    [[ "$bytes" =~ ^-?[0-9]+$ ]] || bytes=-1
    flags=$(json_get "$line" "flags") || flags=""
    backend=$(json_get "$line" "backend") || backend=""
    # Hardware telemetry fields (Tier 2)
    cpu_temp=$(json_get "$line" "cpu_temp_mc") || cpu_temp=-1
    [[ "$cpu_temp" =~ ^-?[0-9]+$ ]] || cpu_temp=-1
    disk_temp=$(json_get "$line" "disk_temp_mc") || disk_temp=-1
    [[ "$disk_temp" =~ ^-?[0-9]+$ ]] || disk_temp=-1
    ram_total=$(json_get "$line" "ram_total_kb") || ram_total=-1
    [[ "$ram_total" =~ ^-?[0-9]+$ ]] || ram_total=-1
    ram_avail=$(json_get "$line" "ram_available_kb") || ram_avail=-1
    [[ "$ram_avail" =~ ^-?[0-9]+$ ]] || ram_avail=-1
    load_avg=$(json_get "$line" "load_avg_1m") || load_avg="-1"
    [[ "$load_avg" =~ ^[0-9.]+$ ]] || load_avg="-1"
    fs_type=$(json_get "$line" "filesystem_type") || fs_type="unknown"
    [[ -z "$fs_type" ]] && fs_type="unknown"
    stor_type=$(json_get "$line" "storage_type") || stor_type="unknown"
    [[ -z "$stor_type" ]] && stor_type="unknown"
    run_id=$(json_get "$line" "run_id") || run_id=""
    if [[ -z "$run_id" ]]; then
      run_id="${ts}_${dur}_${total}"
    fi

    # Sanitize string fields using helper (strips unsafe chars + escapes quotes)
    ts=$(sql_escape "$ts")
    tool=$(sql_escape "$tool")
    ver=$(sql_escape "$ver")
    mode=$(sql_escape "$mode")
    ph=$(sql_escape "$ph")
    pn=$(sql_escape "$pn")
    flags=$(sql_escape "$flags")
    backend=$(sql_escape "$backend")
    load_avg=$(sql_escape "$load_avg")
    fs_type=$(sql_escape "$fs_type")
    stor_type=$(sql_escape "$stor_type")
    run_id=$(sql_escape "$run_id")

    local result
    result=$(sqlite3 "$DB_FILE" "INSERT OR IGNORE INTO telemetry (timestamp,tool,version,mode,path_hash,project_name,duration_ms,exit_code,depth,items_scanned,bytes_scanned,flags,backend,cpu_temp_mc,disk_temp_mc,ram_total_kb,ram_available_kb,load_avg_1m,filesystem_type,storage_type,run_id) VALUES ('$ts','$tool','$ver','$mode','$ph','$pn',$dur,$ec,$dep,$items,$bytes,'$flags','$backend',$cpu_temp,$disk_temp,$ram_total,$ram_avail,'$load_avg','$fs_type','$stor_type','$run_id'); SELECT changes();" 2>/dev/null) || { (( errors++ )); continue; }

    if [[ "$result" == "1" ]]; then
      (( inserted++ )) || true
    else
      (( skipped++ )) || true
      fi
    done < "$JSONL_FILE"

    rebuild_analytics

    if [[ "$OUTPUT" == "json" ]]; then
    echo "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"import\",\"total_lines\":$total,\"inserted\":$inserted,\"skipped\":$skipped,\"errors\":$errors,\"db_path\":\"$DB_FILE\"}"
  else
    echo "Importing telemetry data..."
    echo "  Processed $total lines"
    echo "  Inserted $inserted new records"
    echo "  Skipped $skipped duplicates"
    (( errors > 0 )) && echo "  Errors: $errors (malformed lines)"
    local db_size
    db_size=$(du -h "$DB_FILE" 2>/dev/null | cut -f1) || db_size="unknown"
    echo "Database: $DB_FILE ($db_size)"
  fi
}

# -------------------------
# Subcommand: stats
# -------------------------
cmd_stats() {
  ensure_db

  local count
  count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry;" 2>/dev/null) || count=0

  if (( count == 0 )); then
    echo "No telemetry data in database."
    echo "Run: fmetrics import"
    return 0
  fi

  local oldest newest db_size
  oldest=$(sqlite3 "$DB_FILE" "SELECT MIN(timestamp) FROM telemetry;")
  newest=$(sqlite3 "$DB_FILE" "SELECT MAX(timestamp) FROM telemetry;")

  # Compatible SQL: avg, min, max, success rate per tool
  local stats_sql
  stats_sql="SELECT tool, COUNT(*), CAST(AVG(duration_ms) AS INTEGER), MIN(duration_ms), MAX(duration_ms), ROUND(100.0 * SUM(CASE WHEN exit_code=0 THEN 1 ELSE 0 END) / COUNT(*), 1) FROM telemetry GROUP BY tool ORDER BY tool;"
  local projects_sql="SELECT project_name, COUNT(*) as c FROM telemetry GROUP BY project_name ORDER BY c DESC LIMIT 5;"

  if [[ "$OUTPUT" == "json" ]]; then
    db_size=$(stat -c%s "$DB_FILE" 2>/dev/null) || db_size=0
    echo -n "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"stats\","
    echo -n "\"total_runs\":$count,\"db_path\":\"$DB_FILE\",\"db_size_bytes\":$db_size,"
    echo -n "\"oldest_run\":\"$oldest\",\"newest_run\":\"$newest\","

    echo -n "\"tools\":["
    local first=1
    while IFS='|' read -r t runs avg_ms min_ms max_ms sr; do
      (( first )) || echo -n ","
      first=0
      echo -n "{\"name\":\"$t\",\"runs\":$runs,\"avg_ms\":$avg_ms,\"min_ms\":$min_ms,\"max_ms\":$max_ms,\"success_rate\":$sr}"
    done < <(sqlite3 -separator '|' "$DB_FILE" "$stats_sql" 2>/dev/null)
    echo -n "],"

    echo -n "\"top_projects\":["
    first=1
    while IFS='|' read -r pname pruns; do
      (( first )) || echo -n ","
      first=0
      echo -n "{\"name\":\"$pname\",\"runs\":$pruns}"
    done < <(sqlite3 -separator '|' "$DB_FILE" "$projects_sql" 2>/dev/null)
    echo "]}"
    else
      echo "$(metric_title 'fmetrics stats')"
      echo "$(metric_rule '============================================')"
      echo ""
      printf "  %-12s %6s %10s %10s %10s %9s\n" "Tool" "Runs" "Avg" "Min" "Max" "Success"
      echo "$(metric_rule '  ----------------------------------------------------------')"

    while IFS='|' read -r t runs avg_ms min_ms max_ms sr; do
      printf "  %-12s %6s %10s %10s %10s %8s%%\n" \
        "$t" "$runs" "$(human_ms "$avg_ms")" "$(human_ms "$min_ms")" "$(human_ms "$max_ms")" "$sr"
    done < <(sqlite3 -separator '|' "$DB_FILE" "$stats_sql" 2>/dev/null)

    echo ""
      echo "$(metric_label '  Top Projects:')"
    while IFS='|' read -r pname pruns; do
      printf "    %-30s %d runs\n" "$pname" "$pruns"
    done < <(sqlite3 -separator '|' "$DB_FILE" "$projects_sql" 2>/dev/null)

    db_size=$(du -h "$DB_FILE" 2>/dev/null | cut -f1) || db_size="?"
    echo ""
      echo "  $(metric_label 'Telemetry:') $count total runs -- $oldest to $newest"
      echo "  $(metric_label 'Database:') $DB_FILE -- $db_size"
  fi
}

# -------------------------
# Subcommand: history
# -------------------------
cmd_history() {
  ensure_db

  # Sanitize filter inputs to prevent SQL injection
  local safe_tool safe_project
  safe_tool=$(echo "${FILTER_TOOL:-}" | tr -cd '[:alnum:]._-')
  safe_project=$(echo "${FILTER_PROJECT:-}" | tr -cd '[:alnum:]. _-')
  safe_project="${safe_project//\'/\'\'}"

  local where_clauses=()
  [[ -n "$safe_tool" ]] && where_clauses+=("tool='$safe_tool'")
  [[ -n "$safe_project" ]] && where_clauses+=("project_name='$safe_project'")

  local where=""
  if (( ${#where_clauses[@]} > 0 )); then
    local joined_where="" clause
    for clause in "${where_clauses[@]}"; do
      if [[ -n "$joined_where" ]]; then
        joined_where+=" AND "
      fi
      joined_where+="$clause"
    done
    where="WHERE $joined_where"
  fi

  if [[ "$OUTPUT" == "json" ]]; then
    echo -n "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"history\",\"runs\":["
    local first=1
    while IFS='|' read -r ts t mode pn dur ec items bytes backend; do
      (( first )) || echo -n ","
      first=0
      echo -n "{\"timestamp\":\"$ts\",\"tool\":\"$t\",\"mode\":\"$mode\",\"project\":\"$pn\",\"duration_ms\":$dur,\"exit_code\":$ec,\"items_scanned\":$items,\"bytes_scanned\":$bytes,\"backend\":\"$backend\"}"
    done < <(sqlite3 -separator '|' "$DB_FILE" "SELECT timestamp,tool,mode,project_name,duration_ms,exit_code,items_scanned,bytes_scanned,backend FROM telemetry $where ORDER BY timestamp DESC LIMIT $LIMIT;" 2>/dev/null)
    echo "]}"
  else
    local title="Recent Runs"
    [[ -n "${FILTER_TOOL:-}" ]] && title="Recent $FILTER_TOOL Runs"
    [[ -n "${FILTER_PROJECT:-}" ]] && title="$title (project: $FILTER_PROJECT)"
      echo "$(metric_title "fmetrics history — $title (last $LIMIT)")"
      echo "$(metric_rule '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━')"
      printf "  %-20s %-12s %-12s %-12s %8s %6s %8s %6s\n" "Timestamp" "Tool" "Mode" "Project" "Time" "Items" "Bytes" "Exit"
      echo "$(metric_rule '  ─────────────────────────────────────────────────────────────────────────────────────────────')"

    while IFS='|' read -r ts t mode pn dur ec items bytes backend; do
      printf "  %-20s %-12s %-12s %-12s %8s %6s %8s %6s\n" \
        "$ts" "$t" "$mode" "${pn:0:12}" "$(human_ms "$dur")" "$items" "$(human_bytes "$bytes")" "$ec"
    done < <(sqlite3 -separator '|' "$DB_FILE" "SELECT timestamp,tool,mode,project_name,duration_ms,exit_code,items_scanned,bytes_scanned,backend FROM telemetry $where ORDER BY timestamp DESC LIMIT $LIMIT;" 2>/dev/null)
  fi
}

# -------------------------
# Subcommand: combos
# -------------------------
cmd_combos() {
  ensure_analytics_populated

  local safe_project safe_contains safe_starts prefix_key
  safe_project=$(sanitize_project_name "${FILTER_PROJECT:-}")
  safe_contains=$(sanitize_tool_token "${COMBO_CONTAINS:-}")
  safe_starts=$(sanitize_tool_csv "${COMBO_STARTS_WITH:-}")
  prefix_key="${safe_starts//,/>}"

  local where_clauses=()
  [[ -n "$safe_project" ]] && where_clauses+=("base.project_name='$safe_project'")
  [[ -n "$prefix_key" ]] && where_clauses+=("(base.combo_key='$prefix_key' OR base.combo_key LIKE '$prefix_key>%')")
  [[ -n "$safe_contains" ]] && where_clauses+=("('>' || base.combo_key || '>') LIKE '%>$safe_contains>%'")
  where_clauses+=("base.occurrence_count >= ${MIN_OCCURRENCES}")

  local where=""
  if (( ${#where_clauses[@]} > 0 )); then
    local joined="" clause
    for clause in "${where_clauses[@]}"; do
      [[ -n "$joined" ]] && joined+=" AND "
      joined+="$clause"
    done
    where="WHERE $joined"
  fi

  local combo_rows total_rows case_db
  case_db="$FSUITE_DIR/fcase.db"
  total_rows=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM combo_stats_v1 base $where;" 2>/dev/null) || total_rows=0
  [[ "$total_rows" =~ ^[0-9]+$ ]] || total_rows=0

if fcase_replay_ready "$case_db"; then
local case_db_sql
local legacy_project_map_sql
case_db_sql="${case_db//\'/\'\'}"
legacy_project_map_sql="$(case_project_map_cte_sql "$case_db")"
combo_rows="$(
sqlite3 -separator '|' "$DB_FILE" 2>/dev/null <<SQL
ATTACH DATABASE '$case_db_sql' AS case_db;
WITH verification_cases AS (
SELECT case_id, 1 AS has_verification
FROM case_db.events
WHERE event_type = 'verification'
GROUP BY case_id
),
legacy_project_map AS (
$legacy_project_map_sql
),
replay_case_meta AS (
SELECT
r.id AS replay_id,
r.case_id,
COALESCE(MAX(t.project_name), MAX(legacy_project_map.project_name), '') AS project_name,
c.slug,
CASE WHEN COALESCE(c.resolved_at, '') != '' OR c.status = 'resolved' THEN 1 ELSE 0 END AS resolved_case,
CASE WHEN COALESCE(c.archived_at, '') != '' OR c.status = 'archived' THEN 1 ELSE 0 END AS archived_case,
    CASE WHEN COALESCE(c.next_move, '') != '' THEN 1 ELSE 0 END AS progress_case,
    COALESCE(vc.has_verification, 0) AS verification_case
FROM case_db.replays r
JOIN case_db.cases c ON c.id = r.case_id
LEFT JOIN case_db.replay_steps rs ON rs.replay_id = r.id
LEFT JOIN telemetry t ON t.run_id = rs.telemetry_run_id
LEFT JOIN legacy_project_map ON legacy_project_map.replay_id = r.id
LEFT JOIN verification_cases vc ON vc.case_id = r.case_id
GROUP BY r.id, r.case_id, c.slug, c.status, c.resolved_at, c.archived_at, c.next_move, vc.has_verification
),
replay_combo_keys AS (
  SELECT
    rs.replay_id,
    (
      SELECT group_concat(tool, '>')
      FROM (
        SELECT rs2.tool AS tool
        FROM case_db.replay_steps rs2
        WHERE rs2.replay_id = rs.replay_id
        ORDER BY rs2.order_num
      )
    ) AS combo_key,
    COUNT(*) AS step_count
  FROM case_db.replay_steps rs
  GROUP BY rs.replay_id
),
case_combo_stats AS (
  SELECT
    meta.project_name,
    combos.combo_key,
    combos.step_count,
    COUNT(DISTINCT CASE WHEN meta.resolved_case = 1 THEN meta.case_id END) AS resolved_cases,
    COUNT(DISTINCT CASE WHEN meta.archived_case = 1 THEN meta.case_id END) AS archived_cases,
    COUNT(DISTINCT CASE WHEN meta.progress_case = 1 THEN meta.case_id END) AS progress_cases,
    COUNT(DISTINCT CASE WHEN meta.verification_case = 1 THEN meta.case_id END) AS verification_cases,
    COALESCE(group_concat(DISTINCT meta.slug), '') AS case_slugs
  FROM replay_combo_keys combos
  JOIN replay_case_meta meta ON meta.replay_id = combos.replay_id
  WHERE combos.combo_key != ''
  GROUP BY meta.project_name, combos.combo_key, combos.step_count
)
SELECT
  base.combo_key,
  base.step_count,
  base.occurrence_count,
  base.clean_run_count,
  base.faulted_run_count,
  base.avg_duration_ms,
  COALESCE(case_stats.resolved_cases, 0),
  COALESCE(case_stats.archived_cases, 0),
  COALESCE(case_stats.progress_cases, 0),
  COALESCE(case_stats.verification_cases, 0),
  COALESCE(case_stats.case_slugs, '')
FROM combo_stats_v1 base
LEFT JOIN case_combo_stats case_stats
  ON case_stats.project_name = base.project_name
 AND case_stats.combo_key = base.combo_key
$where
ORDER BY (
  CASE
    WHEN (base.clean_run_count + base.faulted_run_count) <= 0 THEN 0
    ELSE CAST(
      ((1.0 * base.clean_run_count / (base.clean_run_count + base.faulted_run_count)) * 60)
      + (CASE WHEN base.occurrence_count > 5 THEN 25 ELSE base.occurrence_count * 5 END)
      + (CASE WHEN base.avg_duration_ms <= 1000 THEN 10 WHEN base.avg_duration_ms <= 5000 THEN 5 ELSE 0 END)
      - ((1.0 * base.faulted_run_count / (base.clean_run_count + base.faulted_run_count)) * 25)
      AS INTEGER
    )
  END
  + (COALESCE(case_stats.resolved_cases, 0) * 20)
  + (COALESCE(case_stats.verification_cases, 0) * 8)
  + (COALESCE(case_stats.progress_cases, 0) * 6)
  + (COALESCE(case_stats.archived_cases, 0) * 4)
) DESC,
COALESCE(case_stats.resolved_cases, 0) DESC,
COALESCE(case_stats.progress_cases, 0) DESC,
base.occurrence_count DESC,
base.clean_run_count DESC,
base.faulted_run_count ASC,
base.avg_duration_ms ASC,
base.combo_key ASC
LIMIT $LIMIT;
DETACH DATABASE case_db;
SQL
)" || combo_rows=""
else
combo_rows=$(sqlite3 -separator '|' "$DB_FILE" "SELECT base.combo_key, base.step_count, base.occurrence_count, base.clean_run_count, base.faulted_run_count, base.avg_duration_ms, 0, 0, 0, 0, '' FROM combo_stats_v1 base $where ORDER BY base.occurrence_count DESC, base.clean_run_count DESC, base.faulted_run_count ASC, base.avg_duration_ms ASC, base.combo_key ASC LIMIT $LIMIT;" 2>/dev/null) || combo_rows=""
fi

  if [[ -z "$combo_rows" ]]; then
    local details_json
    details_json=$(printf '"project":"%s","starts_with":%s,"contains":"%s","min_occurrences":%s,"limit":%s' \
      "$(printf '%s' "$safe_project" | json_escape)" \
        "$(delimited_to_json_array "$safe_starts" ',')" \
        "$(printf '%s' "$safe_contains" | json_escape)" \
        "$MIN_OCCURRENCES" \
        "$LIMIT")
    if [[ "$OUTPUT" == "json" ]]; then
      emit_json_error "combos" "insufficient_data" "No combos matched the current filters." "$details_json"
    else
      echo "No combos matched the current filters."
    fi
    return 0
  fi

  if [[ "$OUTPUT" == "json" ]]; then
    printf '{"tool":"fmetrics","version":"%s","subcommand":"combos","filters":{"project":"%s","starts_with":%s,"contains":"%s","limit":%s,"min_occurrences":%s},"combos":[' \
      "$VERSION" \
      "$(printf '%s' "$safe_project" | json_escape)" \
      "$(delimited_to_json_array "$safe_starts" ',')" \
      "$(printf '%s' "$safe_contains" | json_escape)" \
      "$LIMIT" \
      "$MIN_OCCURRENCES"
    local first=1 combo_key step_count occurrences clean_runs faulted_runs avg_duration_ms
    local resolved_cases archived_cases progress_cases verification_cases case_slugs_csv
    while IFS='|' read -r combo_key step_count occurrences clean_runs faulted_runs avg_duration_ms resolved_cases archived_cases progress_cases verification_cases case_slugs_csv; do
      [[ -n "$combo_key" ]] || continue
      local steps_json fault_rate clean_rate telemetry_score case_score combined_score because_json case_slugs_json
      steps_json=$(delimited_to_json_array "$combo_key" '>')
      fault_rate=$(decimal_ratio "$faulted_runs" "$occurrences")
      clean_rate=$(decimal_ratio "$clean_runs" "$occurrences")
      telemetry_score=$(combo_score "$occurrences" "$clean_runs" "$faulted_runs" "$avg_duration_ms")
      case_score=$(case_impact_score "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases")
      combined_score=$(( telemetry_score + case_score ))
      case_slugs_json=$(delimited_to_json_array "$case_slugs_csv" ',')
      because_json=$(combo_because_json "$occurrences" "$clean_runs" "$faulted_runs" "$avg_duration_ms" "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases" "$case_slugs_csv")
      (( first )) || printf ','
      first=0
      printf '{"combo_key":"%s","steps":%s,"step_count":%s,"occurrences":%s,"clean_run_rate":%s,"fault_rate":%s,"avg_duration_ms":%s,"telemetry_score":%s,"case_impact_score":%s,"score":%s,"evidence":{"clean_runs":%s,"faulted_runs":%s,"total_runs":%s,"resolved_cases":%s,"archived_cases":%s,"progress_cases":%s,"verification_cases":%s,"case_slugs":%s},"because":%s}' \
        "$(printf '%s' "$combo_key" | json_escape)" \
        "$steps_json" \
        "$step_count" \
        "$occurrences" \
        "$clean_rate" \
        "$fault_rate" \
        "$avg_duration_ms" \
        "$telemetry_score" \
        "$case_score" \
        "$combined_score" \
        "$clean_runs" \
        "$faulted_runs" \
        "$occurrences" \
        "$resolved_cases" \
        "$archived_cases" \
        "$progress_cases" \
        "$verification_cases" \
        "$case_slugs_json" \
        "$because_json"
    done <<<"$combo_rows"
    printf '],"total_combos":%s}\n' "$total_rows"
  else
    echo "$(metric_title 'fmetrics combos')"
    echo "$(metric_rule '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━')"
    printf "  %-30s %6s %6s %8s %10s %8s\n" "Combo" "Runs" "Clean" "Fault" "Avg Time" "Impact"
    echo "$(metric_rule '  ─────────────────────────────────────────────────────────────────────────────────────────────')"
    local combo_key step_count occurrences clean_runs faulted_runs avg_duration_ms
    local resolved_cases archived_cases progress_cases verification_cases case_slugs_csv
    while IFS='|' read -r combo_key step_count occurrences clean_runs faulted_runs avg_duration_ms resolved_cases archived_cases progress_cases verification_cases case_slugs_csv; do
      local case_score
      case_score=$(case_impact_score "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases")
      printf "  %-30s %6s %6s %8s %10s %8s\n" \
        "${combo_key:0:30}" "$occurrences" "$clean_runs" "$faulted_runs" "$(human_ms "$avg_duration_ms")" "$case_score"
      if (( resolved_cases + progress_cases + verification_cases + archived_cases > 0 )); then
        printf "    case: resolved %s, progress %s, verified %s, archived %s\n" \
          "$resolved_cases" "$progress_cases" "$verification_cases" "$archived_cases"
      fi
    done <<<"$combo_rows"
  fi
}

# -------------------------
# Subcommand: recommend
# -------------------------
cmd_recommend() {
  ensure_analytics_populated

  local safe_project safe_after prefix_key
  safe_project=$(sanitize_project_name "${FILTER_PROJECT:-}")
  safe_after=$(sanitize_tool_csv "${RECOMMEND_AFTER:-}")
  [[ -n "$safe_after" ]] || die "--after requires at least one tool"
  prefix_key="${safe_after//,/>}"

local where_clauses=("base.prefix_key='$prefix_key'")
[[ -n "$safe_project" ]] && where_clauses+=("base.project_name='$safe_project'")

  local where=""
  if (( ${#where_clauses[@]} > 0 )); then
    local joined="" clause
    for clause in "${where_clauses[@]}"; do
      [[ -n "$joined" ]] && joined+=" AND "
      joined+="$clause"
    done
    where="WHERE $joined"
  fi

  local recommendation_rows total_samples case_db
  case_db="$FSUITE_DIR/fcase.db"
  total_samples=$(sqlite3 "$DB_FILE" "SELECT COALESCE(SUM(base.support_count), 0) FROM combo_next_stats_v1 base $where;" 2>/dev/null) || total_samples=0
  [[ "$total_samples" =~ ^[0-9]+$ ]] || total_samples=0

if fcase_replay_ready "$case_db"; then
local case_db_sql
local legacy_project_map_sql
case_db_sql="${case_db//\'/\'\'}"
legacy_project_map_sql="$(case_project_map_cte_sql "$case_db")"
recommendation_rows="$(
sqlite3 -separator '|' "$DB_FILE" 2>/dev/null <<SQL
ATTACH DATABASE '$case_db_sql' AS case_db;
WITH verification_cases AS (
SELECT case_id, 1 AS has_verification
FROM case_db.events
WHERE event_type = 'verification'
GROUP BY case_id
),
legacy_project_map AS (
$legacy_project_map_sql
),
replay_case_meta AS (
SELECT
r.id AS replay_id,
r.case_id,
COALESCE(MAX(t.project_name), MAX(legacy_project_map.project_name), '') AS project_name,
c.slug,
CASE WHEN COALESCE(c.resolved_at, '') != '' OR c.status = 'resolved' THEN 1 ELSE 0 END AS resolved_case,
CASE WHEN COALESCE(c.archived_at, '') != '' OR c.status = 'archived' THEN 1 ELSE 0 END AS archived_case,
    CASE WHEN COALESCE(c.next_move, '') != '' THEN 1 ELSE 0 END AS progress_case,
    COALESCE(vc.has_verification, 0) AS verification_case
FROM case_db.replays r
JOIN case_db.cases c ON c.id = r.case_id
LEFT JOIN case_db.replay_steps rs ON rs.replay_id = r.id
LEFT JOIN telemetry t ON t.run_id = rs.telemetry_run_id
LEFT JOIN legacy_project_map ON legacy_project_map.replay_id = r.id
LEFT JOIN verification_cases vc ON vc.case_id = r.case_id
GROUP BY r.id, r.case_id, c.slug, c.status, c.resolved_at, c.archived_at, c.next_move, vc.has_verification
),
replay_prefix_edges AS (
  SELECT
    rs.replay_id,
    meta.project_name,
    (
      SELECT group_concat(tool, '>')
      FROM (
        SELECT prefix.tool AS tool
        FROM case_db.replay_steps prefix
        WHERE prefix.replay_id = rs.replay_id
          AND prefix.order_num <= rs.order_num
        ORDER BY prefix.order_num
      )
    ) AS prefix_key,
    next_rs.tool AS next_tool,
    meta.case_id,
    meta.slug,
    meta.resolved_case,
    meta.archived_case,
    meta.progress_case,
    meta.verification_case
  FROM case_db.replay_steps rs
  JOIN case_db.replay_steps next_rs
    ON next_rs.replay_id = rs.replay_id
   AND next_rs.order_num = rs.order_num + 1
  JOIN replay_case_meta meta ON meta.replay_id = rs.replay_id
),
case_next_stats AS (
  SELECT
    project_name,
    prefix_key,
    next_tool,
    COUNT(DISTINCT CASE WHEN resolved_case = 1 THEN case_id END) AS resolved_cases,
    COUNT(DISTINCT CASE WHEN archived_case = 1 THEN case_id END) AS archived_cases,
    COUNT(DISTINCT CASE WHEN progress_case = 1 THEN case_id END) AS progress_cases,
    COUNT(DISTINCT CASE WHEN verification_case = 1 THEN case_id END) AS verification_cases,
    COALESCE(group_concat(DISTINCT slug), '') AS case_slugs
  FROM replay_prefix_edges
  WHERE COALESCE(prefix_key, '') != ''
  GROUP BY project_name, prefix_key, next_tool
)
SELECT
  base.next_tool,
  base.support_count,
  base.clean_run_count,
  base.faulted_run_count,
  base.avg_duration_ms,
  COALESCE(case_stats.resolved_cases, 0),
  COALESCE(case_stats.archived_cases, 0),
  COALESCE(case_stats.progress_cases, 0),
  COALESCE(case_stats.verification_cases, 0),
  COALESCE(case_stats.case_slugs, '')
FROM combo_next_stats_v1 base
LEFT JOIN case_next_stats case_stats
  ON case_stats.project_name = base.project_name
 AND case_stats.prefix_key = base.prefix_key
 AND case_stats.next_tool = base.next_tool
$where
ORDER BY (
  CASE
    WHEN (base.clean_run_count + base.faulted_run_count) <= 0 THEN 0
    ELSE CAST(
      ((1.0 * base.clean_run_count / (base.clean_run_count + base.faulted_run_count)) * 60)
      + (CASE WHEN base.support_count > 5 THEN 25 ELSE base.support_count * 5 END)
      + (CASE WHEN base.avg_duration_ms <= 1000 THEN 10 WHEN base.avg_duration_ms <= 5000 THEN 5 ELSE 0 END)
      - ((1.0 * base.faulted_run_count / (base.clean_run_count + base.faulted_run_count)) * 25)
      AS INTEGER
    )
  END
  + (COALESCE(case_stats.resolved_cases, 0) * 20)
  + (COALESCE(case_stats.verification_cases, 0) * 8)
  + (COALESCE(case_stats.progress_cases, 0) * 6)
  + (COALESCE(case_stats.archived_cases, 0) * 4)
) DESC,
COALESCE(case_stats.resolved_cases, 0) DESC,
COALESCE(case_stats.progress_cases, 0) DESC,
base.support_count DESC,
base.clean_run_count DESC,
base.faulted_run_count ASC,
base.avg_duration_ms ASC,
base.next_tool ASC
LIMIT $LIMIT;
DETACH DATABASE case_db;
SQL
)" || recommendation_rows=""
else
recommendation_rows=$(sqlite3 -separator '|' "$DB_FILE" "SELECT base.next_tool, base.support_count, base.clean_run_count, base.faulted_run_count, base.avg_duration_ms, 0, 0, 0, 0, '' FROM combo_next_stats_v1 base $where ORDER BY base.support_count DESC, base.clean_run_count DESC, base.faulted_run_count ASC, base.avg_duration_ms ASC, base.next_tool ASC LIMIT $LIMIT;" 2>/dev/null) || recommendation_rows=""
fi

  if [[ -z "$recommendation_rows" ]]; then
    local details_json
    details_json=$(printf '"project":"%s","after":%s,"limit":%s' \
      "$(printf '%s' "$safe_project" | json_escape)" \
        "$(delimited_to_json_array "$safe_after" ',')" \
        "$LIMIT")
    if [[ "$OUTPUT" == "json" ]]; then
      emit_json_error "recommend" "insufficient_data" "No recommendation history matched this prefix." "$details_json"
    else
      echo "No recommendation history matched this prefix."
    fi
    return 0
  fi

  if [[ "$OUTPUT" == "json" ]]; then
    printf '{"tool":"fmetrics","version":"%s","subcommand":"recommend","prefix":%s,"filters":{"project":"%s","limit":%s},"recommendations":[' \
      "$VERSION" \
      "$(delimited_to_json_array "$safe_after" ',')" \
      "$(printf '%s' "$safe_project" | json_escape)" \
      "$LIMIT"
    local first=1 next_tool support_count clean_runs faulted_runs avg_duration_ms
    local resolved_cases archived_cases progress_cases verification_cases case_slugs_csv
    while IFS='|' read -r next_tool support_count clean_runs faulted_runs avg_duration_ms resolved_cases archived_cases progress_cases verification_cases case_slugs_csv; do
      [[ -n "$next_tool" ]] || continue
      local fault_rate clean_rate confidence because_json resulting_combo rejected_samples
      local telemetry_score case_score combined_score case_slugs_json
      fault_rate=$(decimal_ratio "$faulted_runs" "$support_count")
      clean_rate=$(decimal_ratio "$clean_runs" "$support_count")
      confidence=$(combo_confidence "$support_count" "$faulted_runs")
      telemetry_score=$(combo_score "$support_count" "$clean_runs" "$faulted_runs" "$avg_duration_ms")
      case_score=$(case_impact_score "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases")
      combined_score=$(( telemetry_score + case_score ))
      case_slugs_json=$(delimited_to_json_array "$case_slugs_csv" ',')
      because_json=$(recommend_because_json "$support_count" "$faulted_runs" "$next_tool" "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases" "$case_slugs_csv")
      resulting_combo="$prefix_key>$next_tool"
      rejected_samples=$(( total_samples - support_count ))
      (( first )) || printf ','
      first=0
      printf '{"next_step":"%s","resulting_combo":"%s","support":%s,"clean_run_rate":%s,"fault_rate":%s,"avg_duration_ms":%s,"confidence":"%s","telemetry_score":%s,"case_impact_score":%s,"score":%s,"evidence":{"clean_runs":%s,"faulted_runs":%s,"total_runs":%s,"rejected_samples":%s,"resolved_cases":%s,"archived_cases":%s,"progress_cases":%s,"verification_cases":%s,"case_slugs":%s},"because":%s}' \
        "$(printf '%s' "$next_tool" | json_escape)" \
        "$(printf '%s' "$resulting_combo" | json_escape)" \
        "$support_count" \
        "$clean_rate" \
        "$fault_rate" \
        "$avg_duration_ms" \
        "$confidence" \
        "$telemetry_score" \
        "$case_score" \
        "$combined_score" \
        "$clean_runs" \
        "$faulted_runs" \
        "$support_count" \
        "$rejected_samples" \
        "$resolved_cases" \
        "$archived_cases" \
        "$progress_cases" \
        "$verification_cases" \
        "$case_slugs_json" \
        "$because_json"
    done <<<"$recommendation_rows"
    printf '],"total_historical_samples":%s}\n' "$total_samples"
  else
    echo "$(metric_title 'fmetrics recommend')"
    echo "$(metric_rule '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━')"
    printf "  %s %s\n" "$(metric_label 'Prefix:')" "$prefix_key"
    printf "  %-18s %8s %8s %10s %12s %8s\n" "Next Tool" "Support" "Faults" "Avg Time" "Confidence" "Impact"
    echo "$(metric_rule '  ─────────────────────────────────────────────────────────────────────────────────────────────')"
    local next_tool support_count clean_runs faulted_runs avg_duration_ms
    local resolved_cases archived_cases progress_cases verification_cases case_slugs_csv
    while IFS='|' read -r next_tool support_count clean_runs faulted_runs avg_duration_ms resolved_cases archived_cases progress_cases verification_cases case_slugs_csv; do
      local case_score
      case_score=$(case_impact_score "$resolved_cases" "$archived_cases" "$progress_cases" "$verification_cases")
      printf "  %-18s %8s %8s %10s %12s %8s\n" \
        "$next_tool" "$support_count" "$faulted_runs" "$(human_ms "$avg_duration_ms")" "$(combo_confidence "$support_count" "$faulted_runs")" "$case_score"
      if (( resolved_cases + progress_cases + verification_cases + archived_cases > 0 )); then
        printf "    case: resolved %s, progress %s, verified %s, archived %s\n" \
          "$resolved_cases" "$progress_cases" "$verification_cases" "$archived_cases"
      fi
    done <<<"$recommendation_rows"
  fi
}

# -------------------------
# Subcommand: predict
# -------------------------
_predict_size_mb() {
  # Compute MB from bytes, avoiding inline awk quoting issues
  local b="${1:-0}"
  if (( b > 0 )); then
    echo "$b" | awk '{printf "%.1f", $1/1048576}'
  else
    echo "0.0"
  fi
}

_predict_get_avg() {
  # Get average duration for a tool from DB
  local tool_name="$1"
  local mode_name="${2:-}"
  # Sanitize tool_name: escape single quotes for SQL safety
  local safe_tool="${tool_name//\'/\'\'}"
  local sql="SELECT CAST(AVG(duration_ms) AS INTEGER) FROM telemetry WHERE tool='${safe_tool}' AND exit_code=0"
  if [[ -n "$mode_name" ]]; then
    local safe_mode="${mode_name//\'/\'\'}"
    sql="${sql} AND mode='${safe_mode}'"
  fi
  sql="${sql};"
  local result
  result=$(sqlite3 "$DB_FILE" "$sql" 2>/dev/null) || result=0
  [[ -z "$result" ]] && result=0
  echo "$result"
}

_predict_get_count() {
  local tool_name="$1"
  local mode_name="${2:-}"
  local safe_tool="${tool_name//\'/\'\'}"
  local sql="SELECT COUNT(*) FROM telemetry WHERE tool='${safe_tool}' AND exit_code=0"
  if [[ -n "$mode_name" ]]; then
    local safe_mode="${mode_name//\'/\'\'}"
    sql="${sql} AND mode='${safe_mode}'"
  fi
  sql="${sql};"
  local result
  result=$(sqlite3 "$DB_FILE" "$sql" 2>/dev/null) || result=0
  [[ -z "$result" ]] && result=0
  echo "$result"
}

_python3_runtime_available() {
  has python3 || return 1
  python3 -c 'pass' >/dev/null 2>&1
}

_predict_json_average_fallback() {
  local target="$1"
  local total_items="$2"
  local total_bytes="$3"
  local total_samples="$4"
  local target_json
  target_json="$(printf '%s' "$target" | json_escape)"
  local tools=()
  if [[ -n "${PREDICT_TOOL:-}" ]]; then
    tools+=("${PREDICT_TOOL}")
  else
    tools+=(ftree fsearch fcontent)
  fi

  printf '{"tool":"fmetrics","version":"%s","subcommand":"predict","path":"%s","features":{"items":%s,"bytes":%s},"predictions":[' \
    "$VERSION" "$target_json" "$total_items" "$total_bytes"

  local first=1 tool avg_ms samples mode tree_avg tree_samples recon_avg recon_samples snapshot_avg snapshot_samples total_mode_samples
  for tool in "${tools[@]}"; do
    if (( first )); then
      first=0
    else
      printf ','
    fi

    if [[ "$tool" == "ftree" ]]; then
      if [[ -n "${PREDICT_MODE:-}" ]]; then
        avg_ms=$(_predict_get_avg "$tool" "${PREDICT_MODE}")
        samples=$(_predict_get_count "$tool" "${PREDICT_MODE}")
        printf '{"tool":"ftree","mode":"%s","predicted_ms":%s,"method":"average","confidence":"low","samples":%s}' \
          "${PREDICT_MODE}" "$avg_ms" "$samples"
      else
        tree_avg=$(_predict_get_avg ftree tree)
        tree_samples=$(_predict_get_count ftree tree)
        recon_avg=$(_predict_get_avg ftree recon)
        recon_samples=$(_predict_get_count ftree recon)
        snapshot_avg=$(_predict_get_avg ftree snapshot)
        snapshot_samples=$(_predict_get_count ftree snapshot)
        total_mode_samples=$((tree_samples + recon_samples + snapshot_samples))
        printf '{"tool":"ftree","mode":"mixed","predicted_ms":-1,"method":"average","confidence":"low","samples":%s,"advisory":true,"error":"mixed ftree modes; use --mode for actionable predictions","by_mode":{"tree":{"predicted_ms":%s,"method":"average","confidence":"low","samples":%s},"recon":{"predicted_ms":%s,"method":"average","confidence":"low","samples":%s},"snapshot":{"predicted_ms":%s,"method":"average","confidence":"low","samples":%s}}}' \
          "$total_mode_samples" "$tree_avg" "$tree_samples" "$recon_avg" "$recon_samples" "$snapshot_avg" "$snapshot_samples"
      fi
    else
      avg_ms=$(_predict_get_avg "$tool")
      samples=$(_predict_get_count "$tool")
      printf '{"tool":"%s","predicted_ms":%s,"method":"average","confidence":"low","samples":%s}' \
        "$tool" "$avg_ms" "$samples"
    fi
  done

  printf '],"total_historical_samples":%s,"method":"average_fallback"}\n' "$total_samples"
}

cmd_predict() {
  local target="${PREDICT_PATH:-.}"
  [[ -d "$target" ]] || die "Not a directory: $target"

  if [[ -n "${PREDICT_TOOL:-}" ]]; then
    case "$PREDICT_TOOL" in
      ftree|fsearch|fcontent) ;;
      *) die "Invalid --tool for predict: $PREDICT_TOOL (use ftree, fsearch, or fcontent)" ;;
    esac
  fi
  if [[ -n "${PREDICT_MODE:-}" ]]; then
    case "$PREDICT_MODE" in
      tree|recon|snapshot) ;;
      *) die "Invalid --mode for predict: $PREDICT_MODE (use tree, recon, or snapshot)" ;;
    esac
    [[ "${PREDICT_TOOL:-}" == "ftree" ]] || die "--mode requires --tool ftree"
  fi

  ensure_db

  local count python3_ok=0
  count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry WHERE exit_code=0;" 2>/dev/null) || count=0
  if _python3_runtime_available; then
    python3_ok=1
  fi

  # Quick recon scan to get project features
  local recon_json
  recon_json=$(FSUITE_TELEMETRY=0 "$SCRIPT_DIR/ftree" --recon -o json "$target" 2>/dev/null) || {
    die "Failed to run ftree --recon on $target"
  }

  local total_items total_bytes size_mb
  total_items=$(json_get "$recon_json" "total_entries") || total_items=0
  [[ "$total_items" =~ ^[0-9]+$ ]] || total_items=0
  total_bytes=$(json_get "$recon_json" "total_size_bytes") || total_bytes=0
  [[ "$total_bytes" =~ ^[0-9]+$ ]] || total_bytes=0
  size_mb=$(_predict_size_mb "$total_bytes")

  if (( count < 5 )); then
    if [[ "$OUTPUT" == "json" ]]; then
      echo -n "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"predict\","
      echo -n "\"path\":\"$target\",\"features\":{\"items\":$total_items,\"bytes\":$total_bytes},"
      echo "\"error\":\"insufficient_data\",\"total_samples\":$count,\"minimum_required\":5}"
      else
        echo "$(metric_title "fmetrics predict -- $target")"
        echo ""
        echo "  $(metric_label 'Project:') $total_items entries, ${size_mb}MB"
        echo ""
        echo "  $(metric_warn 'Insufficient telemetry data:') $count runs, need at least 5."
        echo "  Run fsuite tools more to build prediction history."
        echo "  Then: fmetrics import && fmetrics predict $target"
    fi
    return 0
  fi

  # Check for Python predict helper
  local predict_py
  predict_py=$(_find_predict_script) || predict_py=""
  if [[ -n "$predict_py" ]] && (( python3_ok )); then
    local _tool_arg=""
    [[ -n "${PREDICT_TOOL:-}" ]] && _tool_arg="--tool $PREDICT_TOOL"
    local _mode_arg=""
    [[ -n "${PREDICT_MODE:-}" ]] && _mode_arg="--mode $PREDICT_MODE"
    local pred_json
    pred_json=$(python3 "$predict_py" --db "$DB_FILE" --items "$total_items" --bytes "$total_bytes" --depth 3 --output json $_tool_arg $_mode_arg 2>/dev/null) || pred_json=""

    if [[ -n "$pred_json" ]] && ! echo "$pred_json" | grep -q '"error"' 2>/dev/null; then
      if [[ "$OUTPUT" == "json" ]]; then
        echo "$pred_json"
        else
            echo "$(metric_title "fmetrics predict -- $target")"
            echo "$(metric_rule '============================================')"
            echo ""
            echo "$(metric_label '  Project Characteristics:')"
          echo "    $(metric_info 'Items:') $total_items"
          echo "    $(metric_info 'Size:')  ${size_mb}MB"
          echo ""
          echo "$(metric_label '  Estimated Runtimes:')"
        local formatted_predictions=""
          formatted_predictions=$(printf '%s' "$pred_json" | python3 -c '
import json, sys
data = json.load(sys.stdin)
for pred in data.get("predictions", []):
    label = pred.get("tool", "?")
    mode = pred.get("mode")
    if mode:
        label = f"{label}:{mode}"
    by_mode = pred.get("by_mode", {})
    print("|".join([
        "summary",
        label,
        str(pred.get("predicted_ms", -1)),
        str(pred.get("std_dev_ms", 0)),
        pred.get("confidence", "none"),
        pred.get("error", ""),
    ]))
    for mode_name in ("tree", "recon", "snapshot"):
        mode_pred = by_mode.get(mode_name)
        if not mode_pred:
            continue
        print("|".join([
            "mode",
            f"{pred.get(\"tool\", \"?\")}:{mode_name}",
            str(mode_pred.get("predicted_ms", -1)),
            str(mode_pred.get("std_dev_ms", 0)),
            mode_pred.get("confidence", "none"),
            mode_pred.get("error", ""),
        ]))
') || formatted_predictions=""
          local row_type label pred_ms std_ms conf err h_pred h_std
          while IFS='|' read -r row_type label pred_ms std_ms conf err; do
            [[ -n "$label" ]] || continue
            [[ "$pred_ms" =~ ^-?[0-9]+$ ]] || pred_ms=-1
            if (( pred_ms >= 0 )); then
              [[ "$std_ms" =~ ^[0-9]+$ ]] || std_ms=0
              h_pred=$(human_ms "$pred_ms")
              h_std=$(human_ms "$std_ms")
              if [[ "$row_type" == "mode" ]]; then
                printf '      %-18s ~%-8s +/-%s  [%s]\n' "$label" "$h_pred" "$h_std" "$conf"
              else
                printf '    %-20s ~%-8s +/-%s  [%s]\n' "$label" "$h_pred" "$h_std" "$conf"
              fi
            else
              if [[ "$row_type" == "mode" ]]; then
                printf '      %-18s -- %s\n' "$label" "${err:-no prediction}"
              else
                printf '    %-20s -- %s\n' "$label" "${err:-no prediction}"
              fi
            fi
          done <<< "$formatted_predictions"
        local total_samples
        total_samples=$(json_get "$pred_json" "total_historical_samples") || total_samples="?"
        [[ "$total_samples" =~ ^[0-9]+$ ]] || total_samples="?"
        echo ""
        echo "  Based on $total_samples historical runs"
      fi
      return 0
    fi
  fi

  # Fallback: simple average-based prediction
  if [[ "$OUTPUT" == "json" ]]; then
    local predictions_json
    if (( python3_ok )); then
      predictions_json=$(python3 - "$DB_FILE" "${PREDICT_TOOL:-}" "${PREDICT_MODE:-}" "$count" "$target" "$total_items" "$total_bytes" <<'PY'
import json
import sqlite3
import sys

db_path = sys.argv[1]
requested_tool = sys.argv[2] or None
requested_mode = sys.argv[3] or None
total_samples = int(sys.argv[4])

conn = sqlite3.connect(db_path)
try:
    tools = [requested_tool] if requested_tool else ["ftree", "fsearch", "fcontent"]
    predictions = []
    for tool in tools:
        if tool == "ftree":
            modes = [requested_mode] if requested_mode else ["tree", "recon", "snapshot"]
            by_mode = {}
            total_mode_samples = 0
            for mode in modes:
                row = conn.execute(
                    "SELECT CAST(AVG(duration_ms) AS INTEGER), COUNT(*) FROM telemetry "
                    "WHERE tool='ftree' AND mode=? AND exit_code=0",
                    (mode,),
                ).fetchone()
                avg_ms = 0 if row is None or row[0] is None else int(row[0])
                samples = 0 if row is None or row[1] is None else int(row[1])
                total_mode_samples += samples
                mode_pred = {
                    "predicted_ms": avg_ms,
                    "method": "average",
                    "confidence": "low",
                    "samples": samples,
                }
                if requested_mode:
                    mode_pred["tool"] = "ftree"
                    mode_pred["mode"] = mode
                    predictions.append(mode_pred)
                else:
                    by_mode[mode] = mode_pred
            if not requested_mode:
                predictions.append({
                    "tool": "ftree",
                    "mode": "mixed",
                    "predicted_ms": -1,
                    "method": "average",
                    "confidence": "low",
                    "samples": total_mode_samples,
                    "advisory": True,
                    "error": "mixed ftree modes; use --mode for actionable predictions",
                    "by_mode": by_mode,
                })
        else:
            row = conn.execute(
                "SELECT CAST(AVG(duration_ms) AS INTEGER), COUNT(*) FROM telemetry "
                "WHERE tool=? AND exit_code=0",
                (tool,),
            ).fetchone()
            avg_ms = 0 if row is None or row[0] is None else int(row[0])
            samples = 0 if row is None or row[1] is None else int(row[1])
            predictions.append({
                "tool": tool,
                "predicted_ms": avg_ms,
                "method": "average",
                "confidence": "low",
                "samples": samples,
            })
    print(json.dumps({
        "tool": "fmetrics",
        "version": "2.1.2",
        "subcommand": "predict",
        "path": sys.argv[5],
        "features": {
            "items": int(sys.argv[6]),
            "bytes": int(sys.argv[7]),
        },
        "predictions": predictions,
        "total_historical_samples": total_samples,
        "method": "average_fallback",
    }))
finally:
    conn.close()
PY
)
    else
      predictions_json=""
    fi
    [[ -n "$predictions_json" ]] || predictions_json=$(_predict_json_average_fallback "$target" "$total_items" "$total_bytes" "$count")
    echo "$predictions_json"
  else
      echo "$(metric_title "fmetrics predict -- $target")"
      echo "$(metric_rule '============================================')"
      echo ""
      echo "  $(metric_label 'Project:') $total_items entries, ${size_mb}MB"
      echo ""
      echo "$(metric_label '  Estimated Runtimes — based on historical averages:')"
    local t avg_ms mode
    local _predict_tools=(ftree fsearch fcontent)
    [[ -n "${PREDICT_TOOL:-}" ]] && _predict_tools=("$PREDICT_TOOL")
    for t in "${_predict_tools[@]}"; do
      if [[ "$t" == "ftree" ]] && [[ -z "${PREDICT_MODE:-}" ]]; then
        printf "    %-20s -- %s\n" "ftree:mixed" "use --mode for actionable predictions"
        for mode in tree recon snapshot; do
          avg_ms=$(_predict_get_avg "$t" "$mode")
          printf "      %-18s ~%s\n" "${t}:${mode}" "$(human_ms "$avg_ms")"
        done
      elif [[ "$t" == "ftree" ]]; then
        avg_ms=$(_predict_get_avg "$t" "${PREDICT_MODE}")
        printf "    %-20s ~%s\n" "${t}:${PREDICT_MODE}" "$(human_ms "$avg_ms")"
      else
        avg_ms=$(_predict_get_avg "$t")
        printf "    %-20s ~%s\n" "$t" "$(human_ms "$avg_ms")"
      fi
    done
      if (( ! python3_ok )); then
        echo ""
        echo "  Note: Install python3 for k-NN predictions (more accurate)."
    elif ! _find_predict_script >/dev/null 2>&1; then
      echo ""
      echo "  Note: fmetrics-predict.py not found. Reinstall fsuite or check PATH."
    fi
    echo ""
    echo "  Based on $count historical runs"
  fi
}

# -------------------------
# Subcommand: clean
# -------------------------
cmd_clean() {
  ensure_db

  local days="${CLEAN_DAYS:-$DEFAULT_CLEAN_DAYS}"
  local cutoff
  cutoff=$(date -u -d "-${days} days" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null) || \
    cutoff=$(date -u -v-"${days}d" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null) || \
    die "Cannot compute date offset"

  local to_delete
  to_delete=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry WHERE timestamp < '$cutoff';" 2>/dev/null) || to_delete=0
  local to_keep
  to_keep=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry WHERE timestamp >= '$cutoff';" 2>/dev/null) || to_keep=0

  if (( DRY_RUN )); then
    if [[ "$OUTPUT" == "json" ]]; then
      echo "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"clean\",\"dry_run\":true,\"days\":$days,\"cutoff\":\"$cutoff\",\"would_delete\":$to_delete,\"would_keep\":$to_keep}"
    else
        echo "$(metric_title 'fmetrics clean (dry run)')"
        echo "  Would delete $to_delete records older than $days days"
        echo "  Would keep $to_keep records"
    fi
    return 0
  fi

  if (( to_delete == 0 )); then
    rebuild_analytics
    echo "Nothing to clean. All $to_keep records are within the last $days days."
    return 0
  fi

  sqlite3 "$DB_FILE" "DELETE FROM telemetry WHERE timestamp < '$cutoff';"
  sqlite3 "$DB_FILE" "VACUUM;"
  rebuild_analytics

  if [[ "$OUTPUT" == "json" ]]; then
    local db_size
    db_size=$(stat -c%s "$DB_FILE" 2>/dev/null) || db_size=0
    echo "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"clean\",\"deleted\":$to_delete,\"kept\":$to_keep,\"days\":$days,\"db_size_bytes\":$db_size}"
  else
    local db_size
    db_size=$(du -h "$DB_FILE" 2>/dev/null | cut -f1) || db_size="?"
      echo "$(metric_title "Cleaning telemetry older than $days days...")"
      echo "  Deleted $to_delete records"
      echo "  Kept $to_keep records"
      echo "  $(metric_label 'Database:') $DB_FILE ($db_size)"
  fi
}

# -------------------------
# Subcommand: profile
# -------------------------
cmd_profile() {
  local profile_file="$FSUITE_DIR/machine_profile.json"

  if [[ ! -f "$profile_file" ]]; then
    if [[ "$OUTPUT" == "json" ]]; then
      echo "{\"tool\":\"fmetrics\",\"version\":\"$VERSION\",\"subcommand\":\"profile\",\"error\":\"no profile\",\"hint\":\"Run any fsuite tool with FSUITE_TELEMETRY=3 to generate\"}"
    else
      echo "$(metric_warn 'No machine profile found.')"
      echo "Generate one by running any fsuite tool with FSUITE_TELEMETRY=3"
      echo "Example: FSUITE_TELEMETRY=3 ftree ."
    fi
    return 0
  fi

  if [[ "$OUTPUT" == "json" ]]; then
    cat "$profile_file"
  else
      echo "$(metric_title "Machine Profile ($profile_file)")"
      echo "$(metric_rule '================================')"
      cat "$profile_file" | sed 's/[{}",]//g' | sed 's/^ */  /' | grep -v '^$'
  fi
}

# -------------------------
# Self-check
# -------------------------
self_check() {
  echo "fmetrics dependency check:"
  if has sqlite3; then
    echo "  sqlite3: $(sqlite3 --version 2>&1 | head -1)"
  else
    echo "  sqlite3: NOT FOUND"
  fi
  if has python3; then
    echo "  python3: $(python3 --version 2>&1)"
  else
    echo "  python3: NOT FOUND (predictions unavailable, basic stats still work)"
  fi
  local predict_path
  predict_path=$(_find_predict_script 2>/dev/null) || predict_path=""
  if [[ -n "$predict_path" ]]; then
    echo "  fmetrics-predict.py: found at $predict_path"
  else
    echo "  fmetrics-predict.py: NOT FOUND (check installation path)"
  fi
  if has python3 && [[ -n "$predict_path" ]]; then
    echo "  k-NN predictions: available"
  else
    echo "  k-NN predictions: unavailable"
  fi
  echo "  telemetry.jsonl: $(wc -l < "$JSONL_FILE" 2>/dev/null || echo "0") lines"
  if [[ -f "$DB_FILE" ]]; then
    local count
    count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry;" 2>/dev/null) || count="error"
    echo "  telemetry.db: $count records"
  else
    echo "  telemetry.db: not created yet (run: fmetrics import)"
  fi
}

install_hints() {
  cat <<'EOF'
fmetrics dependencies:

  Required:
    sqlite3    sudo apt install sqlite3      # Debian/Ubuntu
               brew install sqlite           # macOS

  Optional (for predictions):
    python3    sudo apt install python3      # Debian/Ubuntu
               brew install python3          # macOS
EOF
}

# -------------------------
# Argument parsing
# -------------------------
SUBCOMMAND=""
OUTPUT="$DEFAULT_OUTPUT"
LIMIT="$DEFAULT_LIMIT"
FILTER_TOOL=""
FILTER_PROJECT=""
PREDICT_MODE=""
PREDICT_PATH=""
CLEAN_DAYS="$DEFAULT_CLEAN_DAYS"
COMBO_STARTS_WITH=""
COMBO_CONTAINS=""
MIN_OCCURRENCES="$DEFAULT_MIN_OCCURRENCES"
RECOMMEND_AFTER=""
DRY_RUN=0

POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)    usage; exit 0 ;;
    --version)    echo "fmetrics $VERSION"; exit 0 ;;
    --self-check) self_check; exit 0 ;;
    --install-hints) install_hints; exit 0 ;;
    -o|--output)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      OUTPUT="$2"; shift 2 ;;
    --tool)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      FILTER_TOOL="$2"; shift 2 ;;
    --project)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      FILTER_PROJECT="$2"; shift 2 ;;
    --mode)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      PREDICT_MODE="$2"; shift 2 ;;
    --limit)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      LIMIT="$2"
      [[ "$LIMIT" =~ ^[0-9]+$ ]] || die "--limit must be a positive integer"
      shift 2 ;;
    --starts-with)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      COMBO_STARTS_WITH="$2"; shift 2 ;;
    --contains)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      COMBO_CONTAINS="$2"; shift 2 ;;
    --min-occurrences)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      MIN_OCCURRENCES="$2"
      [[ "$MIN_OCCURRENCES" =~ ^[0-9]+$ ]] || die "--min-occurrences must be a positive integer"
      shift 2 ;;
    --after)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      RECOMMEND_AFTER="$2"; shift 2 ;;
    --days)
      [[ -n "${2:-}" ]] || die "Missing value for $1"
      CLEAN_DAYS="$2"
      [[ "$CLEAN_DAYS" =~ ^[0-9]+$ ]] || die "--days must be a positive integer"
      shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    -*) die "Unknown option: $1" ;;
    *)  POSITIONAL+=("$1"); shift ;;
  esac
done

# Validate output
case "$OUTPUT" in
  pretty|json) ;;
  *) die "Invalid output: $OUTPUT (use pretty or json)" ;;
esac

# Extract subcommand
SUBCOMMAND="${POSITIONAL[0]:-}"
[[ -n "$SUBCOMMAND" ]] || { usage; exit 0; }
if [[ -n "$PREDICT_MODE" && "$SUBCOMMAND" != "predict" ]]; then
  die "--mode is only valid with the predict subcommand"
fi
if [[ -n "$COMBO_STARTS_WITH" || -n "$COMBO_CONTAINS" || "$MIN_OCCURRENCES" != "$DEFAULT_MIN_OCCURRENCES" ]] && [[ "$SUBCOMMAND" != "combos" ]]; then
  die "--starts-with, --contains, and --min-occurrences are only valid with the combos subcommand"
fi
if [[ -n "$RECOMMEND_AFTER" && "$SUBCOMMAND" != "recommend" ]]; then
  die "--after is only valid with the recommend subcommand"
fi

case "$SUBCOMMAND" in
  stats)   cmd_stats ;;
  history) cmd_history ;;
  combos)  cmd_combos ;;
  recommend) cmd_recommend ;;
  predict)
    PREDICT_PATH="${POSITIONAL[1]:-}"
    [[ -n "$PREDICT_PATH" ]] || die "predict requires a path argument"
    PREDICT_TOOL="$FILTER_TOOL"
    cmd_predict ;;
  import)  cmd_import ;;
  clean)   cmd_clean ;;
  profile) cmd_profile ;;
  *)       die "Unknown subcommand: $SUBCOMMAND. Run: fmetrics --help" ;;
esac
