#!/usr/bin/env bash
# fmetrics — performance telemetry and analytics for fsuite tools.
# Part of fsuite. Provides stats, history, predictions, and data management.

set -euo pipefail

VERSION="2.2.0"

# -------------------------
# Paths
# -------------------------
FSUITE_DIR="$HOME/.fsuite"
JSONL_FILE="$FSUITE_DIR/telemetry.jsonl"
DB_FILE="$FSUITE_DIR/telemetry.db"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
_FSUITE_LIB_CANDIDATES=(
  "$SCRIPT_DIR/_fsuite_common.sh"
  "${FSUITE_SHARE_DIR:-}/_fsuite_common.sh"
  "$SCRIPT_DIR/../share/fsuite/_fsuite_common.sh"
  "/usr/local/share/fsuite/_fsuite_common.sh"
  "/usr/share/fsuite/_fsuite_common.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

# -------------------------
# Defaults
# -------------------------
DEFAULT_OUTPUT="pretty"
DEFAULT_LIMIT=20
DEFAULT_CLEAN_DAYS=90
DEFAULT_MIN_OCCURRENCES=1
COLOR_ENABLED=0

if [[ -n "${FORCE_COLOR:-}" || -n "${FSUITE_FORCE_COLOR:-}" ]]; then
  COLOR_ENABLED=1
elif [[ -z "${NO_COLOR:-}" ]]; then
  if [[ -t 1 && "${TERM:-}" != "dumb" ]]; then
    COLOR_ENABLED=1
  fi
fi

# -------------------------
# Helpers
# -------------------------
die() {
  local code=1
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then code="$1"; shift; fi
  echo "fmetrics: $*" >&2
  exit "$code"
}

has() { command -v "$1" >/dev/null 2>&1; }

json_escape() {
  sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/\t/\\t/g' -e 's/\r/\\r/g' -e ':a;N;$!ba;s/\n/\\n/g'
}

human_ms() {
  local ms="$1"
  if (( ms >= 60000 )); then
    awk "BEGIN {printf \"%.1fm\", $ms/60000}"
  elif (( ms >= 1000 )); then
    awk "BEGIN {printf \"%.1fs\", $ms/1000}"
  else
    echo "${ms}ms"
  fi
}

human_bytes() {
  local bytes="$1"
  if (( bytes < 0 )); then
    echo "?"
  elif (( bytes < 1024 )); then
    echo "${bytes}B"
  elif (( bytes < 1048576 )); then
    awk "BEGIN {printf \"%.1fK\", $bytes/1024}"
  elif (( bytes < 1073741824 )); then
    awk "BEGIN {printf \"%.1fM\", $bytes/1048576}"
  else
    awk "BEGIN {printf \"%.1fG\", $bytes/1073741824}"
  fi
}

paint() {
  local code="$1" text="$2"
  if (( COLOR_ENABLED )); then
    printf '\033[%sm%s\033[0m' "$code" "$text"
  else
    printf '%s' "$text"
  fi
}

metric_title() { paint '1;38;5;196' "$1"; }
metric_label() { paint '1;38;5;129' "$1"; }
metric_info() { paint '1;38;5;27' "$1"; }
metric_good() { paint '1;38;5;46' "$1"; }
metric_warn() { paint '1;38;5;208' "$1"; }
metric_rule() { paint '38;5;240' "$1"; }

# SQL escape helper - prevents injection, handles special chars consistently
sql_escape() {
  local val="$1"
  # Strip unsafe characters, keep alphanumeric and safe punctuation
  val=$(printf '%s' "$val" | tr -cd '[:alnum:]. _:-')
  # Escape single quotes for SQL
  val="${val//\'/\'\'}"
  printf '%s' "$val"
}

_find_predict_script() {
  local candidates=(
    "${FSUITE_SHARE_DIR:-}/fmetrics-predict.py"
    "$SCRIPT_DIR/fmetrics-predict.py"
    "$SCRIPT_DIR/fmetrics-predict"
    "$SCRIPT_DIR/../share/fsuite/fmetrics-predict.py"
    "/usr/local/share/fsuite/fmetrics-predict.py"
    "/usr/share/fsuite/fmetrics-predict.py"
    "/usr/lib/fsuite/fmetrics-predict.py"
  )
  for c in "${candidates[@]}"; do
    [[ -n "$c" && -f "$c" ]] && { printf "%s" "$c"; return 0; }
  done
  return 1
}

# Portable JSON field extraction (no grep -oP / PCRE dependency)
# Handles both "key":"stringval" and "key":numval
json_get() {
  local line="$1" key="$2"
  echo "$line" | sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\{0,1\}\([^",}]*\)"\{0,1\}.*/\1/p'
}

sanitize_project_name() {
  local project="$1"
  project=$(printf '%s' "$project" | tr -cd '[:alnum:]. _-')
  project="${project//\'/\'\'}"
  printf '%s' "$project"
}

sanitize_tool_token() {
  printf '%s' "$1" | tr -cd '[:alnum:]._:-'
}

sanitize_tool_csv() {
  local raw="$1"
  local parts=()
  local cleaned=()
  local token
  local old_ifs="$IFS"
  IFS=',' read -r -a parts <<<"$raw"
  IFS="$old_ifs"
  for token in "${parts[@]}"; do
    token=$(sanitize_tool_token "$token")
    [[ -n "$token" ]] && cleaned+=("$token")
  done
  local joined=""
  for token in "${cleaned[@]}"; do
    if [[ -n "$joined" ]]; then
      joined+=","
    fi
    joined+="$token"
  done
  printf '%s' "$joined"
}

delimited_to_json_array() {
  local raw="$1" delimiter="$2"
  local parts=()
  local old_ifs="$IFS"
  local out="["
  local first=1
  local part escaped
  IFS="$delimiter" read -r -a parts <<<"$raw"
  IFS="$old_ifs"
  for part in "${parts[@]}"; do
    [[ -n "$part" ]] || continue
    escaped=$(printf '%s' "$part" | json_escape)
    if (( ! first )); then
      out+=","
    fi
    out+="\"$escaped\""
    first=0
  done
  out+="]"
  printf '%s' "$out"
}

decimal_ratio() {
  local numerator="${1:-0}" denominator="${2:-0}"
  if (( denominator <= 0 )); then
    printf '0'
    return 0
  fi
  awk -v n="$numerator" -v d="$denominator" 'BEGIN { printf "%.6f", n / d }'
}

combo_score() {
  local occurrences="${1:-0}" clean_runs="${2:-0}" faulted_runs="${3:-0}" avg_duration_ms="${4:-0}"
  awk -v occ="$occurrences" -v clean="$clean_runs" -v fault="$faulted_runs" -v avg="$avg_duration_ms" '
    BEGIN {
      total = clean + fault;
      if (total <= 0) {
        print 0;
        exit;
      }
      clean_rate = clean / total;
      fault_rate = fault / total;
      speed_bonus = (avg <= 1000 ? 10 : (avg <= 5000 ? 5 : 0));
      score = int((clean_rate * 60) + (occ > 5 ? 25 : occ * 5) + speed_bonus - (fault_rate * 25));
      if (score < 0) score = 0;
      if (score > 100) score = 100;
      print score;
    }'
}

combo_confidence() {
  local support="${1:-0}" faulted_runs="${2:-0}"
  if (( support >= 4 && faulted_runs == 0 )); then
    printf 'high'
  elif (( support >= 2 )); then
    printf 'medium'
  else
    printf 'low'
  fi
}

case_impact_score() {
  local resolved_cases="${1:-0}" archived_cases="${2:-0}" progress_cases="${3:-0}" verification_cases="${4:-0}"
  printf '%s' $(( resolved_cases * 20 + verification_cases * 8 + progress_cases * 6 + archived_cases * 4 ))
}

combo_because_json() {
  local occurrences="${1:-0}" clean_runs="${2:-0}" faulted_runs="${3:-0}" avg_duration_ms="${4:-0}"
  local resolved_cases="${5:-0}" archived_cases="${6:-0}" progress_cases="${7:-0}" verification_cases="${8:-0}" case_slugs_csv="${9:-}"
  local reasons=()
  if (( occurrences >= 2 )); then
    reasons+=("repeated across multiple runs")
  else
    reasons+=("seen in historical telemetry")
  fi
  if (( faulted_runs == 0 )); then
    reasons+=("zero-fault history")
  elif (( faulted_runs < clean_runs )); then
    reasons+=("fault rate stays below the clean-run count")
  else
    reasons+=("faults are present in this combo history")
  fi
  if (( avg_duration_ms > 0 && avg_duration_ms <= 1000 )); then
    reasons+=("fast average end-to-end duration")
  fi
  if (( resolved_cases > 0 )); then
    reasons+=("backed by ${resolved_cases} resolved case(s)")
  fi
  if (( progress_cases > 0 )); then
    reasons+=("shows forward progress in ${progress_cases} case(s)")
  fi
  if (( verification_cases > 0 )); then
    reasons+=("verification evidence is present")
  fi
  if (( archived_cases > 0 )); then
    reasons+=("archived outcomes reinforce the sequence")
  fi
  if [[ -n "$case_slugs_csv" ]]; then
    reasons+=("cases: ${case_slugs_csv}")
  fi

  local out="["
  local first=1
  local reason escaped
  for reason in "${reasons[@]}"; do
    escaped=$(printf '%s' "$reason" | json_escape)
    if (( ! first )); then
      out+=","
    fi
    out+="\"$escaped\""
    first=0
  done
  out+="]"
  printf '%s' "$out"
}

recommend_because_json() {
  local support="${1:-0}" faulted_runs="${2:-0}" next_tool="$3"
  local resolved_cases="${4:-0}" archived_cases="${5:-0}" progress_cases="${6:-0}" verification_cases="${7:-0}" case_slugs_csv="${8:-}"
  local reasons=()
  reasons+=("most common successful next step after this prefix")
  if (( faulted_runs == 0 )); then
    reasons+=("zero-fault history for this continuation")
  fi
  if (( support >= 2 )); then
    reasons+=("stronger support than one-off continuations")
  fi
  reasons+=("historical continuation favors ${next_tool}")
  if (( resolved_cases > 0 )); then
    reasons+=("resolved cases point to this next step")
  fi
  if (( progress_cases > 0 )); then
    reasons+=("active cases are moving through this continuation")
  fi
  if (( verification_cases > 0 )); then
    reasons+=("verification evidence supports this continuation")
  fi
  if (( archived_cases > 0 )); then
    reasons+=("archived cases reinforce this continuation")
  fi
  if [[ -n "$case_slugs_csv" ]]; then
    reasons+=("cases: ${case_slugs_csv}")
  fi

  local out="["
  local first=1
  local reason escaped
  for reason in "${reasons[@]}"; do
    escaped=$(printf '%s' "$reason" | json_escape)
    if (( ! first )); then
      out+=","
    fi
    out+="\"$escaped\""
    first=0
  done
  out+="]"
  printf '%s' "$out"
}

emit_json_error() {
  local subcommand="$1" code="$2" message="$3" details_pairs="${4:-}"
  local escaped_message
  local details_json="{}"
  escaped_message=$(printf '%s' "$message" | json_escape)
  if [[ -n "$details_pairs" ]]; then
    details_json="{$details_pairs}"
  fi
  cat <<EOF
{"tool":"fmetrics","version":"$VERSION","subcommand":"$subcommand","error":{"code":"$code","message":"$escaped_message","details":$details_json}}
EOF
}

fcase_replay_ready() {
local case_db="$1"
[[ -f "$case_db" ]] || return 1
local has_cases has_replays has_steps
has_cases=$(sqlite3 "$case_db" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='cases';" 2>/dev/null) || has_cases=0
has_replays=$(sqlite3 "$case_db" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='replays';" 2>/dev/null) || has_replays=0
has_steps=$(sqlite3 "$case_db" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='replay_steps';" 2>/dev/null) || has_steps=0
[[ "$has_cases" == "1" && "$has_replays" == "1" && "$has_steps" == "1" ]]
}

infer_case_project_name() {
local start_path="${1:-}"
local project_name=""
[[ -n "$start_path" ]] || return 0
if type _fsuite_infer_project_name >/dev/null 2>&1; then
  project_name="$(_fsuite_infer_project_name "$start_path")"
else
  project_name=$(basename "$start_path" | tr -cd '[:alnum:]. _-')
fi
printf '%s' "$project_name"
}

case_project_map_cte_sql() {
local case_db="${1:-$FSUITE_DIR/fcase.db}"
local sql="SELECT CAST(NULL AS INTEGER) AS replay_id, CAST('' AS TEXT) AS project_name WHERE 0"
[[ -f "$case_db" ]] || {
  printf '%s' "$sql"
  return 0
}
local replay_id cwd project_name replay_sql project_sql
while IFS='|' read -r replay_id cwd; do
  [[ -n "$replay_id" ]] || continue
  [[ -n "$cwd" ]] || continue
  project_name="$(infer_case_project_name "$cwd")"
  [[ -n "$project_name" ]] || continue
  replay_sql="$(sql_escape "$replay_id")"
  project_sql="$(sql_escape "$project_name")"
  sql+=$'\nUNION ALL\nSELECT '
  sql+="$replay_sql"
  sql+=", '"
  sql+="$project_sql"
  sql+="'"
done < <(
  sqlite3 -separator '|' "$case_db" "
    SELECT r.id, COALESCE((
      SELECT rs.cwd
      FROM replay_steps rs
      WHERE rs.replay_id = r.id
        AND COALESCE(rs.cwd, '') != ''
      ORDER BY rs.order_num
      LIMIT 1
    ), '')
    FROM replays r;
  " 2>/dev/null || true
)
printf '%s' "$sql"
}

ensure_analytics_populated() {
ensure_db
  local telemetry_count analytics_version run_facts_count combo_count next_count
  telemetry_count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM telemetry;" 2>/dev/null) || telemetry_count=0
  [[ "$telemetry_count" =~ ^[0-9]+$ ]] || telemetry_count=0
  (( telemetry_count > 0 )) || return 0
  analytics_version=$(sqlite3 "$DB_FILE" "SELECT value FROM analytics_meta WHERE key='analytics_version';" 2>/dev/null) || analytics_version=""
  run_facts_count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM run_facts_v1;" 2>/dev/null) || run_facts_count=0
  combo_count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM combo_stats_v1;" 2>/dev/null) || combo_count=0
  next_count=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM combo_next_stats_v1;" 2>/dev/null) || next_count=0
  [[ "$run_facts_count" =~ ^[0-9]+$ ]] || run_facts_count=0
  [[ "$combo_count" =~ ^[0-9]+$ ]] || combo_count=0
  [[ "$next_count" =~ ^[0-9]+$ ]] || next_count=0
  if [[ "$analytics_version" != "2" ]] || (( run_facts_count == 0 )) || (( combo_count == 0 )) || (( next_count == 0 )); then
    rebuild_analytics
  fi
}

ensure_column() {
  local table="$1" column="$2" ddl="$3"
  local exists
  exists=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM pragma_table_info('$table') WHERE name='$column';" 2>/dev/null) || exists=0
  [[ "$exists" =~ ^[0-9]+$ ]] || exists=0
  if (( exists == 0 )); then
    local alter_err=""
    alter_err=$(sqlite3 "$DB_FILE" "$ddl" 2>&1) || {
      echo "fmetrics: warning: failed to backfill column '$column' in $DB_FILE: $alter_err" >&2
      return 1
    }
  fi
  return 0
}

