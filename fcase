  [[ -n "$slug" ]] || die "target import requires <slug>"

  local output="$DEFAULT_OUTPUT" input_path=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output) output="${2:-}"; shift 2 ;;
      --input) input_path="${2:-}"; shift 2 ;;
      *) die "Unknown option for target import: $1" ;;
    esac
  done
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"
  has python3 || die 3 "python3 is required for target import"

  ensure_db
  local case_id session_id now payload_path err_file result_json rc=0 imported err_msg cleanup_payload=0
  case_id="$(case_exists_or_die "$slug")"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"
  payload_path="$(materialize_import_payload_file "$input_path")"
  [[ -z "$input_path" || "$input_path" == "-" ]] && cleanup_payload=1
  err_file="$(mktemp)"
  result_json="$(python3 - "$DB_FILE" "$case_id" "${session_id:-}" "$now" "$payload_path" 2>"$err_file" <<'PY'
import json
import re
import sqlite3
import sys

db_path = sys.argv[1]
case_id = int(sys.argv[2])
session_id = None if sys.argv[3] in ("", "NULL") else int(sys.argv[3])
now = sys.argv[4]
payload_path = sys.argv[5]

try:
    with open(payload_path, "r", encoding="utf-8") as fh:
        payload = json.load(fh)
except json.JSONDecodeError as exc:
    print(f"target import requires valid JSON: {exc}", file=sys.stderr)
    sys.exit(2)
except OSError as exc:
    print(f"target import could not read payload: {exc}", file=sys.stderr)
    sys.exit(2)

if payload.get("tool") != "fmap":
    print("target import requires fmap JSON input", file=sys.stderr)
    sys.exit(2)

files = payload.get("files")
if not isinstance(files, list):
    print("target import requires fmap JSON with a files array", file=sys.stderr)
    sys.exit(2)

conn = sqlite3.connect(db_path)
conn.execute("PRAGMA foreign_keys=ON")
imported = 0

def normalized_symbol_name(symbol):
    for key in ("name", "identifier"):
        value = symbol.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()

    text = (symbol.get("text") or "").strip()
    if not text:
        return ""

    patterns = (
        r"(?:^|\s)(?:def|function|func|fun|fn)\s+([_A-Za-z]\w*)",
        r"(?:^|\s)(?:class|struct|enum|interface|protocol|trait|module|object|extension|actor|type)\s+([_A-Za-z]\w*)",
        r"([_A-Za-z]\w*)\s*\(",
        r"([_A-Za-z]\w*)",
    )
    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            return match.group(1)
    return text

try:
    for file_entry in files:
        if not isinstance(file_entry, dict):
            continue
        path = file_entry.get("path") or payload.get("path") or ""
        for symbol in file_entry.get("symbols") or []:
            if not isinstance(symbol, dict):
                continue
            symbol_name = normalized_symbol_name(symbol)
            if not symbol_name:
                continue
            symbol_type = symbol.get("type") or ""
            line = symbol.get("line")
            reason = f"Imported from fmap line {line}" if isinstance(line, int) and line > 0 else "Imported from fmap"
            conn.execute(
                """
                INSERT INTO targets (case_id, path, symbol, symbol_type, rank, reason, state, created_at, updated_at)
                VALUES (?, ?, ?, ?, NULL, ?, 'candidate', ?, ?)
                """,
                (case_id, path, symbol_name, symbol_type, reason, now, now),
            )
            imported += 1
    if imported == 0:
        print("target import found no symbols in fmap JSON", file=sys.stderr)
        sys.exit(2)

    conn.execute("UPDATE cases SET updated_at = ? WHERE id = ?", (now, case_id))
    event_payload = json.dumps({"source_tool": "fmap", "imported_targets": imported}, separators=(",", ":"))
    conn.execute(
        """
        INSERT INTO events (case_id, session_id, event_type, payload_json, created_at)
        VALUES (?, ?, 'target_import', ?, ?)
        """,
        (case_id, session_id, event_payload, now),
    )
    conn.commit()
finally:
    conn.close()

json.dump({"imported": imported, "event_type": "target_import"}, sys.stdout, separators=(",", ":"))
PY
  )" || rc=$?
  err_msg="$(cat "$err_file")"
  rm -f "$err_file"
  if (( cleanup_payload )); then
    rm -f "$payload_path"
  fi
  (( rc == 0 )) || die "${err_msg:-target import failed}"

  imported="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["imported"])' <<< "$result_json" 2>/dev/null || printf '0')"
  if [[ "$output" == "json" ]]; then
    printf '{"case":{"slug":"%s"},"imported":%s,"event":{"event_type":"target_import"}}\n' \
      "$(printf '%s' "$slug" | json_escape)" \
      "$imported"
  else
    echo "Imported ${imported} targets into ${slug}"
  fi
}

cmd_evidence() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "evidence requires <slug>"

  local tool="" path="" symbol="" lines="" match_line="" summary="" body="" body_file=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) tool="${2:-}"; shift 2 ;;
      --path) path="${2:-}"; shift 2 ;;
      --symbol) symbol="${2:-}"; shift 2 ;;
      --lines) lines="${2:-}"; shift 2 ;;
      --match-line) match_line="${2:-}"; shift 2 ;;
      --summary) summary="${2:-}"; shift 2 ;;
      --body) body="${2:-}"; shift 2 ;;
      --body-file) body_file="${2:-}"; shift 2 ;;
      *) die "Unknown option for evidence: $1" ;;
    esac
  done
  [[ -n "$tool" ]] || die "evidence requires --tool"
  if [[ -n "$body" && -n "$body_file" ]]; then
    die "evidence requires exactly one body source"
  fi
  if [[ -z "$body" && -z "$body_file" ]]; then
    die "evidence requires exactly one body source"
  fi
  if [[ -n "$body_file" ]]; then
    [[ -f "$body_file" ]] || die "evidence body file not found: $body_file"
    body="$(cat "$body_file")"
  fi

  local line_start_sql="NULL" line_end_sql="NULL"
  if [[ -n "$lines" ]]; then
    local parsed start end
    parsed="$(parse_lines_range "$lines")" || die "evidence --lines must be start:end with positive ascending integers"
    IFS='|' read -r start end <<<"$parsed"
    line_start_sql="$start"
    line_end_sql="$end"
    if [[ -n "$match_line" ]]; then
      [[ "$match_line" =~ ^[0-9]+$ ]] || die "evidence --match-line must be an integer"
      (( match_line >= start && match_line <= end )) || die "evidence --match-line must fall within --lines"
    fi
  elif [[ -n "$match_line" ]]; then
    die "evidence --match-line requires --lines"
  fi

  local match_line_sql="NULL"
  if [[ -n "$match_line" ]]; then match_line_sql="$match_line"; fi

  ensure_db
  local case_id session_id now payload
  case_id="$(case_exists_or_die "$slug")"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"
  db_exec <<SQL
INSERT INTO evidence (case_id, tool, path, symbol, line_start, line_end, match_line, summary, body, payload_json, fingerprint, created_at)
VALUES (
  $case_id,
  $(sql_quote "$tool"),
  $(sql_quote "$path"),
  $(sql_quote "$symbol"),
  $line_start_sql,
  $line_end_sql,
  $match_line_sql,
  $(sql_quote "$summary"),
  $(sql_quote "$body"),
  NULL,
  NULL,
  $(sql_quote "$now")
);
UPDATE cases SET updated_at = $(sql_quote "$now") WHERE id = $case_id;
SQL
  payload="$(printf '{"tool":"%s","path":"%s","symbol":"%s","summary":"%s"}' \
    "$(printf '%s' "$tool" | json_escape)" \
    "$(printf '%s' "$path" | json_escape)" \
    "$(printf '%s' "$symbol" | json_escape)" \
    "$(printf '%s' "$summary" | json_escape)")"
  append_event "$case_id" "$session_id" "evidence_add" "$payload" "$now"
  rebuild_fts_for_case "$case_id"
  echo "Added evidence to ${slug}"
}

