import hashlib
import json
import sqlite3
import sys

db_path = sys.argv[1]
case_id = int(sys.argv[2])
session_id = None if sys.argv[3] in ("", "NULL") else int(sys.argv[3])
now = sys.argv[4]
payload_path = sys.argv[5]

try:
    with open(payload_path, "r", encoding="utf-8") as fh:
