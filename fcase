    )
    conn.commit()
finally:
    conn.close()

json.dump({"imported": imported, "event_type": "evidence_import"}, sys.stdout, separators=(",", ":"))
PY
  )" || rc=$?
  err_msg="$(cat "$err_file")"
  rm -f "$err_file"
  if (( cleanup_payload )); then
    rm -f "$payload_path"
  fi
  (( rc == 0 )) || die "${err_msg:-evidence import failed}"

  imported="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["imported"])' <<< "$result_json" 2>/dev/null || printf '0')"
  if [[ "$output" == "json" ]]; then
