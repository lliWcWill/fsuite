#!/usr/bin/env bash
# fcase — continuity and handoff ledger for fsuite investigations.

set -euo pipefail

VERSION="3.1.0"
FCASE_DIR="${FCASE_DIR:-$HOME/.fsuite}"
DB_FILE="${DB_FILE:-$FCASE_DIR/fcase.db}"
DEFAULT_OUTPUT="pretty"

# ---------------------------------------------------------------------------
# Source shared DB module (_fsuite_db.sh)
# ---------------------------------------------------------------------------
_FSUITE_DB_TOOL_NAME="fcase"
_FSUITE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
_FSUITE_PARENT_DIR="$(cd "$_FSUITE_SCRIPT_DIR/.." 2>/dev/null && pwd || true)"
_FSUITE_LIB_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_LIB_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_db.sh")
_FSUITE_LIB_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_db.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_db.sh"
  "/usr/local/share/fsuite/_fsuite_db.sh"
  "/usr/share/fsuite/_fsuite_db.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate
if [[ -z "${_FSUITE_DB_LOADED:-}" ]]; then
  echo "fcase: fatal: cannot find _fsuite_db.sh (searched: ${_FSUITE_LIB_CANDIDATES[*]})" >&2
  exit 2
fi

usage() {
  cat <<'EOF'
fcase — continuity and handoff ledger for fsuite investigations

USAGE
  fcase --help
  fcase --version
  fcase init <slug> --goal ... [--priority ...] [-o pretty|json]
  fcase list [--status <csv|all>] [--include-shadow] [-o pretty|json]
  fcase status <slug> [-o pretty|json]
  fcase find <query> [--deep] [--status <csv|all>] [--include-shadow] [-o pretty|json]
  fcase note <slug> --body ...
  fcase next <slug> --body ... [-o pretty|json]
  fcase handoff <slug> [-o pretty|json]
  fcase export <slug> -o json
  fcase target add <slug> --path ... [--symbol ... --symbol-type ... --rank ... --reason ... --state ...]
  fcase target import <slug> [-o pretty|json] [--input <path|- >]
  fcase evidence <slug> --tool ... [--path ... --symbol ... --lines <start:end> --match-line ... --summary ...] (--body ... | --body-file <path>)
  fcase evidence import <slug> [-o pretty|json] [--input <path|- >]
  fcase hypothesis add <slug> --body ... [--confidence ...]
  fcase hypothesis set <slug> --id ... --status ... [--reason ... --confidence ...]
  fcase reject <slug> (--target-id <id> | --hypothesis-id <id>) [--reason ...]
  fcase resolve <slug> --summary ... [-o pretty|json]
  fcase archive <slug> [-o pretty|json]
  fcase delete <slug> --reason ... --confirm DELETE [-o pretty|json]

DESCRIPTION
  fcase preserves investigation state once the seam is known:
    init         Create a case and open a session
    list         Show cases (default: open only; shadow/session cases hidden unless --include-shadow)
    find         Search resolved/archived cases via FTS (--deep for full text; shadow/session cases hidden unless --include-shadow)
    status       Show current case state
    note         Append a note to a case
    next         Update the next best move
    handoff      Generate a concise handoff packet
    export       Export the full case envelope
    resolve      Mark case as resolved (requires --summary)
    archive      Archive a resolved case
    delete       Tombstone a case (requires --reason and --confirm DELETE)
    target import    Import structured targets from fmap JSON
    evidence import  Import structured evidence from fread JSON
EOF
}

latest_session_id_for_case() {
  local case_id="$1"
  db_query <<<"SELECT id FROM case_sessions WHERE case_id = $case_id ORDER BY id DESC LIMIT 1;"
}

append_event() {
  local case_id="$1"
  local session_id="$2"
  local event_type="$3"
  local payload_json="$4"
  local created_at="$5"
  db_exec <<<"INSERT INTO events (case_id, session_id, event_type, payload_json, created_at) VALUES ($case_id, ${session_id:-NULL}, $(sql_quote "$event_type"), $(sql_quote "$payload_json"), $(sql_quote "$created_at"));"
}

is_valid_target_state() {
  case "$1" in
    candidate|active|validated|ruled_out) return 0 ;;
    *) return 1 ;;
  esac
}

is_valid_hypothesis_status() {
  case "$1" in
    open|active|validated|rejected) return 0 ;;
    *) return 1 ;;
  esac
}

validate_status_filter() {
  local filter="$1"
  [[ -n "$filter" ]] || die "status filter cannot be empty"
  if [[ "$filter" == "all" ]]; then return 0; fi
  local _old_ifs="${IFS:-}" _s _found
  IFS=','
  for _s in $filter; do
    _found=false
    case "$_s" in
      open|resolved|archived|deleted) _found=true ;;
    esac
    IFS="$_old_ifs"
    [[ "$_found" == "true" ]] || die "invalid status filter: '$_s' (allowed: open,resolved,archived,deleted,all)"
    IFS=','
  done
  IFS="$_old_ifs"
}

default_case_kind() {
  printf '%s' 'explicit_diagnosis'
}

case_kind_value_expr() {
  local prefix="${1:-}"
  printf "COALESCE(%scase_kind, '%s')" "$prefix" "$(default_case_kind)"
}

visible_case_kind_clause() {
  local prefix="${1:-}"
  printf "%s != 'shadow_session'" "$(case_kind_value_expr "$prefix")"
}

parse_lines_range() {
  local raw="$1"
  [[ "$raw" =~ ^([0-9]+):([0-9]+)$ ]] || return 1
  local start="${BASH_REMATCH[1]}"
  local end="${BASH_REMATCH[2]}"
  (( start > 0 )) || return 1
  (( end > 0 )) || return 1
  (( start <= end )) || return 1
  printf '%s|%s' "$start" "$end"
}

materialize_import_payload_file() {
  local input_path="${1:-}"
  if [[ -n "$input_path" && "$input_path" != "-" ]]; then
    [[ -f "$input_path" ]] || die "import input file not found: $input_path"
    printf '%s\n' "$input_path"
    return
  fi

  local payload_file
  payload_file="$(mktemp)"

  if [[ -n "$input_path" && "$input_path" == "-" ]]; then
    cat > "$payload_file"
    printf '%s\n' "$payload_file"
    return
  fi

  if [[ -t 0 ]]; then
    rm -f "$payload_file"
    die "import requires piped JSON or --input <path|- >"
  fi

  cat > "$payload_file"
  printf '%s\n' "$payload_file"
}

