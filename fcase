  shift || true
  [[ -n "$query" ]] || die "find requires <query>"

  local deep=false status_filter="resolved,archived" output="$DEFAULT_OUTPUT" include_shadow=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --deep) deep=true; shift ;;
      --status) status_filter="${2:-}"; shift 2 ;;
      --include-shadow) include_shadow=true; shift ;;
      -o|--output) output="${2:-}"; shift 2 ;;
      *) die "Unknown option for find: $1" ;;
    esac
  done
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db

  validate_status_filter "$status_filter"

  # Build status WHERE clause (exclude deleted unless explicitly requested)
  local status_clause where_clause
  if [[ "$status_filter" == "all" ]]; then
    status_clause="1=1"
  else
    local sql_in
    sql_in=$(echo "$status_filter" | sed "s/,/','/g")
    status_clause="c.status IN ('${sql_in}')"
  fi

  if [[ "$include_shadow" == "true" ]]; then
    where_clause="${status_clause}"
  else
    where_clause="${status_clause} AND $(visible_case_kind_clause 'c.')"
  fi

  # Sanitize query for SQL safety.
  # 1. SQL-escape single quotes (doubles them).
  # 2. For FTS (deep mode): also strip double-quotes, FTS boolean keywords,
  #    and prefix operators (- and *) that FTS4 interprets specially.
  local like_safe fts_safe
  like_safe=$(printf '%s' "$query" | sed "s/'/''/g" | sed 's/\\/\\\\/g' | sed 's/%/\\%/g' | sed 's/_/\\_/g')
  fts_safe=$(printf '%s' "$query" | sed 's/"//g' | sed 's/\*//g' | sed 's/\(^\| \)-/\1/g' \
    | sed 's/ OR / or /g; s/^OR /or /; s/ OR$/or/' \
    | sed 's/ AND / and /g; s/^AND /and /; s/ AND$/ and/' \
    | sed 's/ NOT / not /g; s/^NOT /not /; s/ NOT$/ not/' \
    | sed 's/ NEAR / near /g; s/^NEAR /near /; s/ NEAR$/ near/' \
    | sed "s/'/''/g")

  if [[ "$deep" == "true" ]]; then
    # Deep search: FTS phrase match across all indexed columns (slug, goal,
    # resolution_summary, evidence, hypotheses, notes, next_move).
    local fts_match="'\"${fts_safe}\"'"

    if [[ "$output" == "json" ]]; then
      db_query <<SQL
SELECT json_object(
  'query', '${like_safe}',
  'statuses', '${status_filter}',
  'deep', json('true'),
  'results', COALESCE((
      SELECT json_group_array(json_object(
        'slug', c.slug, 'status', c.status, 'priority', c.priority,
        'case_kind', $(case_kind_value_expr 'c.'),
        'goal', c.goal, 'resolution_summary', c.resolution_summary,
        'resolved_at', c.resolved_at, 'archived_at', c.archived_at
      ))
    FROM cases_fts fts
    JOIN cases c ON c.id = fts.rowid
    WHERE cases_fts MATCH ${fts_match}
      AND ${where_clause}
    ORDER BY
CASE WHEN c.slug LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
CASE WHEN c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
      c.updated_at DESC
  ), json('[]'))
);
SQL
    else
      local results
      results=$(db_query --separator '|' <<SQL
  SELECT c.slug, c.status, c.priority, $(case_kind_value_expr 'c.'), c.goal, c.resolution_summary, c.resolved_at
  FROM cases_fts fts
  JOIN cases c ON c.id = fts.rowid
WHERE cases_fts MATCH ${fts_match}
  AND ${where_clause}
ORDER BY
CASE WHEN c.slug LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
CASE WHEN c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
c.updated_at DESC;
SQL
      )
    fi
  else
    # Shallow search: direct LIKE on cases table (no FTS).
    # Handles all punctuation safely — FTS4 tokenizer strips punctuation
    # like c++ → c, so we bypass FTS entirely for shallow searches.
    if [[ "$output" == "json" ]]; then
      db_query <<SQL
SELECT json_object(
  'query', '${like_safe}',
  'statuses', '${status_filter}',
  'deep', json('false'),
  'results', COALESCE((
      SELECT json_group_array(json_object(
        'slug', c.slug, 'status', c.status, 'priority', c.priority,
        'case_kind', $(case_kind_value_expr 'c.'),
        'goal', c.goal, 'resolution_summary', c.resolution_summary,
        'resolved_at', c.resolved_at, 'archived_at', c.archived_at
      ))
    FROM cases c
    WHERE ${where_clause}
      AND (c.slug LIKE '%${like_safe}%' ESCAPE '\' OR c.goal LIKE '%${like_safe}%' ESCAPE '\' OR c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\')
    ORDER BY
      CASE WHEN c.slug LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
      CASE WHEN c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
      c.updated_at DESC
  ), json('[]'))
);
SQL
    else
      local results
      results=$(db_query --separator '|' <<SQL
  SELECT c.slug, c.status, c.priority, $(case_kind_value_expr 'c.'), c.goal, c.resolution_summary, c.resolved_at
  FROM cases c
WHERE ${where_clause}
AND (c.slug LIKE '%${like_safe}%' ESCAPE '\' OR c.goal LIKE '%${like_safe}%' ESCAPE '\' OR c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\')
ORDER BY
CASE WHEN c.slug LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
CASE WHEN c.resolution_summary LIKE '%${like_safe}%' ESCAPE '\' THEN 0 ELSE 1 END,
c.updated_at DESC;
SQL
      )
    fi
  fi

  if [[ "$output" == "json" ]]; then
    : # already emitted above
  else
    if [[ -z "$results" ]]; then
      echo "No cases found matching '$query'"
    else
      local count
      count=$(echo "$results" | wc -l)
      echo "Found $count case(s) matching '$query'"
      echo ""
        while IFS='|' read -r rslug rstatus rpriority rkind rgoal rsummary rresolved; do
          local label="$rpriority"
          if [[ "$rkind" != "$(default_case_kind)" ]]; then
            label="${label}, ${rkind}"
          fi
          echo "  [$rstatus] $rslug ($label)"
          echo "    Goal: $rgoal"
          [[ -n "$rsummary" ]] && echo "    Summary: $rsummary"
          [[ -n "$rresolved" ]] && echo "    Resolved: $rresolved"
        echo ""
      done <<< "$results"
    fi
  fi
}

cmd_resolve() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "resolve requires <slug>"

  local summary="" output="$DEFAULT_OUTPUT"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --summary) summary="${2:-}"; shift 2 ;;
      -o|--output) output="${2:-}"; shift 2 ;;
      *) die "Unknown option for resolve: $1" ;;
    esac
  done
  [[ -n "$summary" ]] || die "resolve requires --summary"
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db
  local case_id session_id now prior_status
  case_id="$(case_exists_or_die "$slug")"
  prior_status="$(db_query <<<"SELECT status FROM cases WHERE id = $case_id;")"
  [[ "$prior_status" == "open" ]] || die "resolve requires status=open (current: $prior_status)"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"

  db_exec <<SQL
UPDATE cases
SET status = 'resolved',
    resolution_summary = $(sql_quote "$summary"),
    resolved_at = $(sql_quote "$now"),
    next_move = '',
    updated_at = $(sql_quote "$now")
WHERE id = $case_id;
SQL

  local payload
  payload="$(printf '{"prior_status":"%s","summary":"%s"}' \
    "$(printf '%s' "$prior_status" | json_escape)" \
    "$(printf '%s' "$summary" | json_escape)")"
  append_event "$case_id" "$session_id" "case_resolved" "$payload" "$now"

  rebuild_fts_for_case "$case_id"

  if [[ "$output" == "json" ]]; then
    status_json "$slug"
  else
    echo "Case '${slug}' resolved."
  fi
}

cmd_archive() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "archive requires <slug>"

  local output="$DEFAULT_OUTPUT"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output) output="${2:-}"; shift 2 ;;
      *) die "Unknown option for archive: $1" ;;
    esac
  done
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db
  local case_id session_id now prior_status
  case_id="$(case_exists_or_die "$slug")"
  prior_status="$(db_query <<<"SELECT status FROM cases WHERE id = $case_id;")"
  [[ "$prior_status" == "resolved" ]] || die "archive requires status=resolved (current: $prior_status)"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"

  db_exec <<SQL
UPDATE cases
SET status = 'archived',
    archived_at = $(sql_quote "$now"),
    updated_at = $(sql_quote "$now")
WHERE id = $case_id;
SQL

  local payload
  payload="$(printf '{"prior_status":"%s"}' \
    "$(printf '%s' "$prior_status" | json_escape)")"
  append_event "$case_id" "$session_id" "case_archived" "$payload" "$now"

  rebuild_fts_for_case "$case_id"

  if [[ "$output" == "json" ]]; then
    status_json "$slug"
  else
    echo "Case '${slug}' archived."
  fi
}

cmd_delete() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "delete requires <slug>"

  local reason="" confirm="" output="$DEFAULT_OUTPUT"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) reason="${2:-}"; shift 2 ;;
      --confirm) confirm="${2:-}"; shift 2 ;;
      -o|--output) output="${2:-}"; shift 2 ;;
      *) die "Unknown option for delete: $1" ;;
    esac
  done
  [[ -n "$reason" ]] || die "delete requires --reason"
  [[ "$confirm" == "DELETE" ]] || die "delete requires --confirm DELETE"
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db
  local case_id session_id now prior_status
  case_id="$(case_exists_or_die "$slug")"
  prior_status="$(db_query <<<"SELECT status FROM cases WHERE id = $case_id;")"
  [[ "$prior_status" != "deleted" ]] || die "case is already deleted"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"

  db_exec <<SQL
UPDATE cases
SET status = 'deleted',
    deleted_at = $(sql_quote "$now"),
    delete_reason = $(sql_quote "$reason"),
    next_move = '',
    updated_at = $(sql_quote "$now")
WHERE id = $case_id;
SQL

  local payload
  payload="$(printf '{"prior_status":"%s","reason":"%s"}' \
    "$(printf '%s' "$prior_status" | json_escape)" \
    "$(printf '%s' "$reason" | json_escape)")"
  append_event "$case_id" "$session_id" "case_deleted" "$payload" "$now"

  rebuild_fts_for_case "$case_id"

  if [[ "$output" == "json" ]]; then
    status_json "$slug"
  else
    echo "Case '${slug}' tombstoned. Reason: ${reason}"
  fi
}

main() {
  local cmd="${1:---help}"
  case "$cmd" in
    --help|-h|help)
      usage
      ;;
    --version|version)
      echo "fcase ${VERSION}"
      ;;
    init)
      shift
      cmd_init "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    status)
      shift
      cmd_status "$@"
      ;;
    note)
      shift
      cmd_note "$@"
      ;;
    next)
      shift
      cmd_next "$@"
      ;;
    handoff)
      shift
      cmd_handoff "$@"
      ;;
    export)
      shift
      cmd_export "$@"
      ;;
    target)
      shift
      case "${1:-}" in
        add)
          shift
          cmd_target_add "$@"
          ;;
        import)
          shift
          cmd_target_import "$@"
          ;;
        *)
          die 2 "unknown target subcommand: ${1:-}"
          ;;
      esac
      ;;
    evidence)
      shift
      case "${1:-}" in
        import)
          shift
          cmd_evidence_import "$@"
          ;;
        *)
          cmd_evidence "$@"
          ;;
      esac
      ;;
    hypothesis)
      shift
      case "${1:-}" in
        add)
          shift
          cmd_hypothesis_add "$@"
          ;;
        set)
          shift
          cmd_hypothesis_set "$@"
          ;;
        *)
          die 2 "unknown hypothesis subcommand: ${1:-}"
          ;;
      esac
      ;;
    reject)
      shift
      cmd_reject "$@"
      ;;
    find)
      shift
      cmd_find "$@"
      ;;
    resolve)
      shift
      cmd_resolve "$@"
      ;;
    archive)
      shift
      cmd_archive "$@"
      ;;
    delete)
      shift
      cmd_delete "$@"
      ;;
    *)
      die 2 "unknown or unimplemented subcommand: $cmd"
      ;;
  esac
}

main "$@"
