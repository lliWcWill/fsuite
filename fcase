main() {
  local cmd="${1:---help}"
  case "$cmd" in
    --help|-h|help)
      usage
      ;;
    --version|version)
      echo "fcase ${VERSION}"
      ;;
    init)
      shift
      cmd_init "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    status)
      shift
      cmd_status "$@"
      ;;
    note)
      shift
      cmd_note "$@"
      ;;
    next)
      shift
      cmd_next "$@"
      ;;
    handoff)
      shift
      cmd_handoff "$@"
      ;;
    export)
      shift
      cmd_export "$@"
      ;;
    target)
      shift
      case "${1:-}" in
        add)
          shift
          cmd_target_add "$@"
          ;;
        import)
          shift
          cmd_target_import "$@"
          ;;
        *)
          die 2 "unknown target subcommand: ${1:-}"
          ;;
      esac
      ;;
    evidence)
      shift
      case "${1:-}" in
        import)
          shift
          cmd_evidence_import "$@"
          ;;
        *)
          cmd_evidence "$@"
          ;;
      esac
      ;;
    hypothesis)
      shift
      case "${1:-}" in
        add)
          shift
          cmd_hypothesis_add "$@"
          ;;
        set)
          shift
          cmd_hypothesis_set "$@"
          ;;
        *)
          die 2 "unknown hypothesis subcommand: ${1:-}"
          ;;
      esac
      ;;
    reject)
      shift
      cmd_reject "$@"
      ;;
    *)
      die 2 "unknown or unimplemented subcommand: $cmd"
      ;;
  esac
}

main "$@"
