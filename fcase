cmd_init() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "init requires <slug>"

  local goal=""
  local priority="normal"
  local output="$DEFAULT_OUTPUT"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --goal)
        goal="${2:-}"
        shift 2
        ;;
      --priority)
        priority="${2:-}"
        shift 2
        ;;
      -o|--output)
        output="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown option for init: $1"
        ;;
    esac
  done

  [[ -n "$goal" ]] || die "init requires --goal"
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db

  local now actor case_kind escaped_slug escaped_goal escaped_priority escaped_case_kind
  now="$(now_utc)"
  actor="${USER:-unknown}"
  case_kind="$(default_case_kind)"
  escaped_slug="$(sql_quote "$slug")"
  escaped_goal="$(sql_quote "$goal")"
  escaped_priority="$(sql_quote "$priority")"
  escaped_case_kind="$(sql_quote "$case_kind")"

  if ! db_exec <<SQL
PRAGMA foreign_keys=ON;
BEGIN IMMEDIATE;
INSERT INTO cases (slug, goal, status, priority, case_kind, next_move, created_at, updated_at)
VALUES (${escaped_slug}, ${escaped_goal}, 'open', ${escaped_priority}, ${escaped_case_kind}, '', $(sql_quote "$now"), $(sql_quote "$now"));
INSERT INTO case_sessions (case_id, started_at, ended_at, actor, summary)
VALUES (last_insert_rowid(), $(sql_quote "$now"), NULL, $(sql_quote "$actor"), '');
INSERT INTO events (case_id, session_id, event_type, payload_json, created_at)
VALUES (
  (SELECT id FROM cases WHERE slug = ${escaped_slug}),
  (SELECT id FROM case_sessions WHERE case_id = (SELECT id FROM cases WHERE slug = ${escaped_slug}) ORDER BY id DESC LIMIT 1),
  'case_init',
  json_object('slug', ${escaped_slug}, 'goal', ${escaped_goal}, 'priority', ${escaped_priority}),
  $(sql_quote "$now")
);
COMMIT;
SQL
  then
    die "failed to create case (slug may already exist)"
  fi

  # Rebuild FTS index for the newly created case
  local _new_case_id
  _new_case_id="$(case_id_for_slug "$slug")"
  [[ -n "$_new_case_id" ]] && rebuild_fts_for_case "$_new_case_id"

  if [[ "$output" == "json" ]]; then
    db_query <<SQL
SELECT json_object(
  'case', (
    SELECT json_object(
      'id', id,
      'slug', slug,
        'goal', goal,
        'status', status,
        'priority', priority,
        'case_kind', $(case_kind_value_expr ''),
        'next_move', next_move,
        'created_at', created_at,
        'updated_at', updated_at
    )
    FROM cases
    WHERE slug = ${escaped_slug}
  ),
  'session', (
    SELECT json_object(
      'id', id,
      'actor', actor,
      'started_at', started_at,
      'ended_at', ended_at,
      'summary', summary
    )
    FROM case_sessions
    WHERE case_id = (SELECT id FROM cases WHERE slug = ${escaped_slug})
    ORDER BY id DESC
    LIMIT 1
  ),
  'event', (
    SELECT json_object(
      'id', id,
      'event_type', event_type,
      'payload_json', payload_json,
      'created_at', created_at
    )
    FROM events
    WHERE case_id = (SELECT id FROM cases WHERE slug = ${escaped_slug})
    ORDER BY id DESC
    LIMIT 1
  )
);
SQL
  else
    echo "Created case: ${slug}"
    echo "Goal: ${goal}"
    echo "Priority: ${priority}"
  fi
}

cmd_list() {
  local output="$DEFAULT_OUTPUT"
  local filter="open"  # default: show only open cases
  local include_shadow=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output)
        output="${2:-}"
        shift 2
        ;;
      --status)
        filter="${2:-}"
        shift 2
        ;;
      --include-shadow)
        include_shadow=true
        shift
        ;;
      *)
        die "Unknown option for list: $1"
        ;;
    esac
  done
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db

  validate_status_filter "$filter"

  # Build SQL WHERE clause from status filter
  local status_clause where_clause
  if [[ "$filter" == "all" ]]; then
    status_clause="1=1"
  else
    local sql_in
    sql_in=$(echo "$filter" | sed "s/,/','/g")
    status_clause="status IN ('${sql_in}')"
  fi

  if [[ "$include_shadow" == "true" ]]; then
    where_clause="${status_clause}"
  else
    where_clause="${status_clause} AND $(visible_case_kind_clause '')"
  fi

  if [[ "$output" == "json" ]]; then
    db_query <<SQL
SELECT json_object(
  'cases',
  COALESCE((
    SELECT json_group_array(json_object(
      'id', id,
      'slug', slug,
        'goal', goal,
        'status', status,
        'priority', priority,
        'case_kind', case_kind,
        'next_move', next_move,
        'resolution_summary', resolution_summary,
      'resolved_at', resolved_at,
      'archived_at', archived_at,
      'deleted_at', deleted_at,
      'delete_reason', delete_reason,
      'created_at', created_at,
      'updated_at', updated_at
    ))
    FROM (
        SELECT id, slug, goal, status, priority, $(case_kind_value_expr '') AS case_kind, next_move,
               resolution_summary, resolved_at, archived_at, deleted_at, delete_reason,
               created_at, updated_at
        FROM cases
      WHERE ${where_clause}
      ORDER BY updated_at DESC, id DESC
    )
  ), json('[]'))
);
SQL
  else
    local count
    count="$(db_query <<<"SELECT COUNT(*) FROM cases WHERE ${where_clause};")"
    local label
    if [[ "$filter" == "all" ]]; then
      label="All cases"
    else
      label="$(echo "$filter" | sed 's/,/ + /g') cases"
    fi
    echo "${label}: ${count}"
    db_query --separator ' | ' <<<"SELECT slug, status, priority, goal FROM cases WHERE ${where_clause} ORDER BY updated_at DESC, id DESC;"
  fi
}

cmd_status() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "status requires <slug>"

  local output="$DEFAULT_OUTPUT"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output)
        output="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown option for status: $1"
        ;;
    esac
  done
  [[ "$output" == "pretty" || "$output" == "json" ]] || die "Invalid --output: $output"

  ensure_db
  local case_id
  case_id="$(case_id_for_slug "$slug")"
  [[ -n "$case_id" ]] || die "case not found: $slug"

  if [[ "$output" == "json" ]]; then
    status_json "$slug"
  else
    local details
    details="$(db_query --separator '|' <<<"SELECT slug, goal, status, priority, next_move, updated_at FROM cases WHERE slug = $(sql_quote "$slug");")"
    IFS='|' read -r case_slug case_goal case_status case_priority case_next case_updated <<<"$details"
    echo "Case: ${case_slug}"
    echo "Goal: ${case_goal}"
    echo "Status: ${case_status}"
    echo "Priority: ${case_priority}"
    echo "Next: ${case_next}"
    echo "Updated: ${case_updated}"
  fi
}

cmd_target_add() {
  local slug="${1:-}"
  shift || true
  [[ -n "$slug" ]] || die "target add requires <slug>"

  local path="" symbol="" symbol_type="" rank="" reason="" state="candidate"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path) path="${2:-}"; shift 2 ;;
      --symbol) symbol="${2:-}"; shift 2 ;;
      --symbol-type) symbol_type="${2:-}"; shift 2 ;;
      --rank) rank="${2:-}"; shift 2 ;;
      --reason) reason="${2:-}"; shift 2 ;;
      --state) state="${2:-}"; shift 2 ;;
      *) die "Unknown option for target add: $1" ;;
    esac
  done
  [[ -n "$path" ]] || die "target add requires --path"
  [[ -z "$rank" || "$rank" =~ ^[0-9]+$ ]] || die "target add --rank must be an integer"
  is_valid_target_state "$state" || die "target add --state must be one of: candidate, active, validated, ruled_out"

  ensure_db
  local case_id session_id now payload rank_sql json_rank
  case_id="$(case_exists_or_die "$slug")"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"
  if [[ -n "$rank" ]]; then rank_sql="$rank"; else rank_sql="NULL"; fi
  if [[ "$rank_sql" == "NULL" ]]; then json_rank="null"; else json_rank="$rank_sql"; fi
  db_exec <<SQL
INSERT INTO targets (case_id, path, symbol, symbol_type, rank, reason, state, created_at, updated_at)
VALUES (
  $case_id,
  $(sql_quote "$path"),
  $(sql_quote "$symbol"),
