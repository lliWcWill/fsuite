      --hypothesis-id) hypothesis_id="${2:-}"; shift 2 ;;
      --reason) reason="${2:-}"; shift 2 ;;
      *) die "Unknown option for reject: $1" ;;
    esac
  done

  local selectors=0
  [[ -n "$target_id" ]] && selectors=$((selectors + 1))
  [[ -n "$hypothesis_id" ]] && selectors=$((selectors + 1))
  (( selectors == 1 )) || die "reject requires exactly one selector"

  ensure_db
  local case_id session_id now count_sql
  case_id="$(case_exists_or_die "$slug")"
  session_id="$(latest_session_id_for_case "$case_id")"
  now="$(now_utc)"

  if [[ -n "$target_id" ]]; then
    [[ "$target_id" =~ ^[0-9]+$ ]] || die "reject --target-id must be an integer"
    count_sql="$(db_query <<<"SELECT COUNT(*) FROM targets WHERE id = $target_id AND case_id = $case_id;")"
    [[ "$count_sql" == "1" ]] || die "target not found for case: $target_id"
    db_exec <<<"UPDATE targets SET state = 'ruled_out', reason = $(sql_quote "$reason"), updated_at = $(sql_quote "$now") WHERE id = $target_id AND case_id = $case_id;"
    append_event "$case_id" "$session_id" "target_rejected" "$(printf '{"target_id":%s,"reason":"%s"}' "$target_id" "$(printf '%s' "$reason" | json_escape)")" "$now"
  else
    [[ "$hypothesis_id" =~ ^[0-9]+$ ]] || die "reject --hypothesis-id must be an integer"
    count_sql="$(db_query <<<"SELECT COUNT(*) FROM hypotheses WHERE id = $hypothesis_id AND case_id = $case_id;")"
    [[ "$count_sql" == "1" ]] || die "hypothesis not found for case: $hypothesis_id"
    db_exec <<<"UPDATE hypotheses SET status = 'rejected', reason = $(sql_quote "$reason"), updated_at = $(sql_quote "$now") WHERE id = $hypothesis_id AND case_id = $case_id;"
