#!/usr/bin/env bash
# fcase — continuity and handoff ledger for fsuite investigations.

set -euo pipefail

VERSION="0.1.0"
FCASE_DIR="$HOME/.fsuite"
DB_FILE="$FCASE_DIR/fcase.db"
DEFAULT_OUTPUT="pretty"

die() {
  local code=1
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    code="$1"
    shift
  fi
  echo "fcase: $*" >&2
  exit "$code"
}

has() { command -v "$1" >/dev/null 2>&1; }

json_escape() {
  perl -CS -0pe '
    s/\\/\\\\/g;
    s/"/\\"/g;
    s/\x08/\\b/g;
    s/\x0c/\\f/g;
    s/\n/\\n/g;
    s/\r/\\r/g;
    s/\t/\\t/g;
    s/([\x00-\x07\x0b\x0e-\x1f])/sprintf("\\u%04x", ord($1))/ge;
  '
}

sql_quote() {
  local value="${1//\'/\'\'}"
  printf "'%s'" "$value"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

usage() {
  cat <<'EOF'
fcase — continuity and handoff ledger for fsuite investigations

USAGE
  fcase --help
  fcase --version
  fcase init <slug> --goal ... [--priority ...] [-o pretty|json]
  fcase list [-o pretty|json]
  fcase status <slug> [-o pretty|json]
  fcase note <slug> --body ...
  fcase next <slug> --body ... [-o pretty|json]
  fcase handoff <slug> [-o pretty|json]
  fcase export <slug> -o json
  fcase target add <slug> --path ... [--symbol ... --symbol-type ... --rank ... --reason ... --state ...]
  fcase target import <slug> [-o pretty|json] [--input <path|- >]
  fcase evidence <slug> --tool ... [--path ... --symbol ... --lines <start:end> --match-line ... --summary ...] (--body ... | --body-file <path>)
  fcase evidence import <slug> [-o pretty|json] [--input <path|- >]
  fcase hypothesis add <slug> --body ... [--confidence ...]
  fcase hypothesis set <slug> --id ... --status ... [--reason ... --confidence ...]
  fcase reject <slug> (--target-id <id> | --hypothesis-id <id>) [--reason ...]

DESCRIPTION
  fcase preserves investigation state once the seam is known:
    init         Create a case and open a session
    list         Show known cases
    status       Show current case state
    note         Append a note to a case
    next         Update the next best move
    handoff      Generate a concise handoff packet
    export       Export the full case envelope
    target import    Import structured targets from fmap JSON
    evidence import  Import structured evidence from fread JSON
EOF
}

db_query() {
  local separator=""
  if [[ "${1:-}" == "--separator" ]]; then
    separator="${2:-}"
    [[ -n "$separator" ]] || die "db_query requires a value for --separator"
    shift 2
  fi

  has sqlite3 || die 3 "sqlite3 is required"
  mkdir -p "$FCASE_DIR" 2>/dev/null || die "Cannot create $FCASE_DIR"

  if [[ -n "$separator" ]]; then
    { printf 'PRAGMA foreign_keys=ON;\n'; cat; } | sqlite3 -separator "$separator" "$DB_FILE"
  else
    { printf 'PRAGMA foreign_keys=ON;\n'; cat; } | sqlite3 "$DB_FILE"
  fi
}

db_exec() {
  has sqlite3 || die 3 "sqlite3 is required"
  mkdir -p "$FCASE_DIR" 2>/dev/null || die "Cannot create $FCASE_DIR"
  { printf 'PRAGMA foreign_keys=ON;\n'; cat; } | sqlite3 "$DB_FILE" >/dev/null
}

ensure_db() {
  db_exec <<'SQL'
PRAGMA journal_mode=WAL;
PRAGMA foreign_keys=ON;
PRAGMA user_version=1;

CREATE TABLE IF NOT EXISTS cases (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  slug TEXT NOT NULL UNIQUE,
  goal TEXT NOT NULL,
  status TEXT NOT NULL DEFAULT 'open',
  priority TEXT NOT NULL DEFAULT 'normal',
  next_move TEXT NOT NULL DEFAULT '',
  created_at TEXT NOT NULL,
  updated_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS case_sessions (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  case_id INTEGER NOT NULL REFERENCES cases(id) ON DELETE CASCADE,
  started_at TEXT NOT NULL,
  ended_at TEXT,
  actor TEXT NOT NULL,
  summary TEXT NOT NULL DEFAULT ''
);

CREATE TABLE IF NOT EXISTS targets (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  case_id INTEGER NOT NULL REFERENCES cases(id) ON DELETE CASCADE,
  path TEXT NOT NULL,
  symbol TEXT,
  symbol_type TEXT,
  rank INTEGER,
  reason TEXT,
  state TEXT NOT NULL DEFAULT 'candidate',
  created_at TEXT NOT NULL,
  updated_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS evidence (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  case_id INTEGER NOT NULL REFERENCES cases(id) ON DELETE CASCADE,
  tool TEXT NOT NULL,
  path TEXT,
  symbol TEXT,
  line_start INTEGER,
  line_end INTEGER,
  match_line INTEGER,
  summary TEXT,
  body TEXT NOT NULL,
  payload_json TEXT,
  fingerprint TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS hypotheses (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  case_id INTEGER NOT NULL REFERENCES cases(id) ON DELETE CASCADE,
  body TEXT NOT NULL,
  status TEXT NOT NULL DEFAULT 'open',
  confidence TEXT,
  reason TEXT,
  created_at TEXT NOT NULL,
  updated_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS events (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  case_id INTEGER NOT NULL REFERENCES cases(id) ON DELETE CASCADE,
  session_id INTEGER REFERENCES case_sessions(id) ON DELETE SET NULL,
  event_type TEXT NOT NULL,
  payload_json TEXT,
  created_at TEXT NOT NULL
);
SQL
}

case_id_for_slug() {
  local slug="$1"
  db_query <<<"SELECT id FROM cases WHERE slug = $(sql_quote "$slug");"
}

latest_session_id_for_case() {
  local case_id="$1"
  db_query <<<"SELECT id FROM case_sessions WHERE case_id = $case_id ORDER BY id DESC LIMIT 1;"
}

case_exists_or_die() {
  local slug="$1"
  local case_id
  case_id="$(case_id_for_slug "$slug")"
  [[ -n "$case_id" ]] || die "case not found: $slug"
  printf '%s' "$case_id"
}

append_event() {
  local case_id="$1"
  local session_id="$2"
  local event_type="$3"
  local payload_json="$4"
  local created_at="$5"
  db_exec <<<"INSERT INTO events (case_id, session_id, event_type, payload_json, created_at) VALUES ($case_id, ${session_id:-NULL}, $(sql_quote "$event_type"), $(sql_quote "$payload_json"), $(sql_quote "$created_at"));"
}

is_valid_target_state() {
  case "$1" in
    candidate|active|validated|ruled_out) return 0 ;;
    *) return 1 ;;
  esac
}

is_valid_hypothesis_status() {
  case "$1" in
    open|active|validated|rejected) return 0 ;;
    *) return 1 ;;
  esac
}

parse_lines_range() {
  local raw="$1"
  [[ "$raw" =~ ^([0-9]+):([0-9]+)$ ]] || return 1
  local start="${BASH_REMATCH[1]}"
  local end="${BASH_REMATCH[2]}"
  (( start > 0 )) || return 1
  (( end > 0 )) || return 1
  (( start <= end )) || return 1
  printf '%s|%s' "$start" "$end"
}

materialize_import_payload_file() {
  local input_path="${1:-}"
  if [[ -n "$input_path" && "$input_path" != "-" ]]; then
    [[ -f "$input_path" ]] || die "import input file not found: $input_path"
    printf '%s\n' "$input_path"
    return
  fi

  local payload_file
  payload_file="$(mktemp)"

  if [[ -n "$input_path" && "$input_path" == "-" ]]; then
    cat > "$payload_file"
    printf '%s\n' "$payload_file"
    return
  fi

  if [[ -t 0 ]]; then
    rm -f "$payload_file"
    die "import requires piped JSON or --input <path|- >"
  fi

  cat > "$payload_file"
  printf '%s\n' "$payload_file"
}

status_json() {
  local slug="$1"
  db_query <<SQL
WITH target_case AS (
  SELECT id, slug, goal, status, priority, next_move, created_at, updated_at
  FROM cases
  WHERE slug = $(sql_quote "$slug")
)
SELECT json_object(
  'case', (
    SELECT json_object(
      'id', id,
      'slug', slug,
      'goal', goal,
      'status', status,
      'priority', priority,
      'next_move', next_move,
      'created_at', created_at,
      'updated_at', updated_at
    ) FROM target_case
  ),
  'active_session', (
    SELECT json_object(
      'id', id,
      'actor', actor,
      'started_at', started_at,
      'ended_at', ended_at,
      'summary', summary
    )
    FROM case_sessions
    WHERE case_id = (SELECT id FROM target_case)
    ORDER BY id DESC
    LIMIT 1
  ),
  'targets', COALESCE((
    SELECT json_group_array(json_object(
      'id', id,
      'path', path,
      'symbol', symbol,
      'symbol_type', symbol_type,
      'rank', rank,
      'reason', reason,
      'state', state,
      'created_at', created_at,
      'updated_at', updated_at
    ))
    FROM targets
    WHERE case_id = (SELECT id FROM target_case)
  ), json('[]')),
  'evidence', COALESCE((
    SELECT json_group_array(json_object(
      'id', id,
      'tool', tool,
      'path', path,
      'symbol', symbol,
      'line_start', line_start,
      'line_end', line_end,
      'match_line', match_line,
      'summary', summary,
      'body', body,
      'payload_json', payload_json,
      'fingerprint', fingerprint,
      'created_at', created_at
    ))
    FROM evidence
    WHERE case_id = (SELECT id FROM target_case)
  ), json('[]')),
  'hypotheses', COALESCE((
    SELECT json_group_array(json_object(
      'id', id,
      'body', body,
      'status', status,
      'confidence', confidence,
      'reason', reason,
      'created_at', created_at,
      'updated_at', updated_at
    ))
    FROM hypotheses
    WHERE case_id = (SELECT id FROM target_case)
  ), json('[]')),
  'recent_events', COALESCE((
    SELECT json_group_array(json_object(
      'id', id,
      'session_id', session_id,
      'event_type', event_type,
      'payload_json', payload_json,
      'created_at', created_at
    ))
    FROM (
      SELECT id, session_id, event_type, payload_json, created_at
      FROM events
      WHERE case_id = (SELECT id FROM target_case)
      ORDER BY id DESC
      LIMIT 10
    )
  ), json('[]'))
);
SQL
}

