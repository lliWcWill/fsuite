#!/usr/bin/env bash
# fpatch-claude-mcp â€” patch Claude Code binary for cleaner MCP tool display
#
# Changes: "fsuite - fread (MCP)" â†’ "fread" in bold cyan
# Uses fprobe to find offsets dynamically (survives version updates)
#
# Usage:
#   fpatch-claude-mcp [--dry-run] [--color COLOR] [--binary PATH]
#   fpatch-claude-mcp --restore
#
# Colors: cyan green yellow magenta bold_cyan bold_green (default: bold_cyan)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
FPROBE="${SCRIPT_DIR}/fprobe"

# Defaults
_CLAUDE_VERSIONS_DIR="${HOME}/.local/share/claude/versions"
if [[ -d "$_CLAUDE_VERSIONS_DIR" ]]; then
  CLAUDE_BINARY="${_CLAUDE_VERSIONS_DIR}/$(ls -1t "$_CLAUDE_VERSIONS_DIR" 2>/dev/null | head -1)"
else
  CLAUDE_BINARY=""
fi
DRY_RUN=0
COLOR="bold_cyan"
RESTORE=0

die() { echo "fpatch: $*" >&2; exit 1; }

usage() {
cat <<'EOF'
fpatch-claude-mcp â€” patch Claude Code binary for cleaner MCP tool display

USAGE
  fpatch-claude-mcp                     Apply patch (bold cyan, latest binary)
  fpatch-claude-mcp --dry-run           Show what would be patched
  fpatch-claude-mcp --color green       Use green instead of bold_cyan
  fpatch-claude-mcp --binary PATH       Patch a specific binary
  fpatch-claude-mcp --restore           Restore from backup

COLORS
  cyan  green  yellow  magenta  bold_cyan  bold_green

WHAT IT DOES
  Patches userFacingName() in the Claude Code binary so MCP tools
  display as just the tool name (e.g. "fread") in color, instead of
  "fsuite - fread (MCP)" in plain white.

  Creates a .bak backup before patching. Use --restore to undo.
EOF
}

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)   DRY_RUN=1; shift ;;
    --restore)   RESTORE=1; shift ;;
    --color)     [[ -n "${2:-}" ]] || die "--color requires an argument"; COLOR="$2"; shift 2 ;;
    --binary)    [[ -n "${2:-}" ]] || die "--binary requires an argument"; CLAUDE_BINARY="$2"; shift 2 ;;
    -h|--help)   usage; exit 0 ;;
    *)           die "Unknown option: $1" ;;
  esac
done

[[ -f "$CLAUDE_BINARY" ]] || die "Claude binary not found: $CLAUDE_BINARY"

# Restore mode
if (( RESTORE == 1 )); then
  [[ -f "${CLAUDE_BINARY}.bak" ]] || die "No backup found at ${CLAUDE_BINARY}.bak"
  cp "${CLAUDE_BINARY}.bak" "$CLAUDE_BINARY"
  echo "Restored from backup: ${CLAUDE_BINARY}.bak"
  exit 0
fi

# Color map (ANSI escape bytes)
declare -A COLOR_MAP=(
  [cyan]='\x1b[36m'
  [green]='\x1b[32m'
  [yellow]='\x1b[33m'
  [magenta]='\x1b[35m'
  [bold_cyan]='\x1b[1;36m'
  [bold_green]='\x1b[1;32m'
)

ANSI_CODE="${COLOR_MAP[$COLOR]:-}"
[[ -n "$ANSI_CODE" ]] || die "Unknown color: $COLOR (use: ${!COLOR_MAP[*]})"

# Target pattern (the exact bytes to find)
TARGET='return`${H.name} - ${A} (MCP)`'

echo "Binary: $CLAUDE_BINARY"
echo "Target: $TARGET"
echo "Color:  $COLOR"
echo ""

# Find offsets using fprobe
echo "Scanning for patch points..."
OFFSETS=$("$FPROBE" scan "$CLAUDE_BINARY" --pattern "$TARGET" -o json | \
  python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
except json.JSONDecodeError as e:
    print(f'fpatch: failed to parse fprobe output: {e}', file=sys.stderr)
    sys.exit(1)
for m in data:
    print(m['offset'])
" 2>&1) || die "fprobe scan failed: $OFFSETS"

if [[ -z "$OFFSETS" ]]; then
  die "Pattern not found in binary. Maybe already patched or different version?"
fi

COUNT=$(echo "$OFFSETS" | wc -l)
echo "Found $COUNT patch points:"
echo "$OFFSETS" | while read -r off; do echo "  offset $off"; done
echo ""

if (( DRY_RUN == 1 )); then
  echo "[DRY RUN] Would patch $COUNT locations. No changes made."
  exit 0
fi

# Backup
if [[ ! -f "${CLAUDE_BINARY}.bak" ]]; then
  echo "Creating backup: ${CLAUDE_BINARY}.bak"
cp "$CLAUDE_BINARY" "${CLAUDE_BINARY}.bak" || die "failed to create backup"
else
  echo "Backup already exists: ${CLAUDE_BINARY}.bak"
fi

# Apply patch
python3 - "$CLAUDE_BINARY" "$ANSI_CODE" "$COLOR" <<'PYEOF'
import sys
import os

binary_path = sys.argv[1]
ansi_code = sys.argv[2].encode().decode('unicode_escape').encode('latin-1')
color_name = sys.argv[3]

target = b'return`${H.name} - ${A} (MCP)`'
target_len = len(target)

# Build patch: return`<ANSI>${z}<RESET>` padded to target_len
reset = b'\x1b[m'
patch = b'return`' + ansi_code + b'${A}' + reset + b'`'

if len(patch) > target_len:
    print(f"ERROR: patch ({len(patch)}B) exceeds target ({target_len}B)", file=sys.stderr)
    sys.exit(1)

# Pad with spaces to exact length
patch = patch + b' ' * (target_len - len(patch))
if len(patch) != target_len:
    print(f"ERROR: patch length mismatch: {len(patch)} != {target_len}", file=sys.stderr)
    sys.exit(1)

# Read binary
with open(binary_path, 'rb') as f:
    data = bytearray(f.read())

# Find and replace all occurrences
count = 0
pos = 0
while True:
    idx = data.find(target, pos)
    if idx == -1:
        break
    data[idx:idx+target_len] = patch
    print(f"  Patched offset {idx}")
    count += 1
    pos = idx + target_len

if count == 0:
    print("No matches found â€” maybe already patched?")
    sys.exit(1)

# Write back
with open(binary_path, 'wb') as f:
    f.write(data)

print(f"\nPatched {count} locations with {color_name} tool names.")
print("Restart Claude Code to see the change.")
PYEOF

echo ""
echo "Done. To undo: fpatch-claude-mcp --restore"
