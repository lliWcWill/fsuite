#!/usr/bin/env bash
# fbash — token-budgeted shell execution for fsuite.
# Part of fsuite. Runs bash commands with output capping, session state,
# command classification, smart routing, and fcase integration.

set -euo pipefail

VERSION="1.0.0"

# ── Source common library ────────────────────────────────────────
_FSUITE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
_FSUITE_PARENT_DIR="$(cd "$_FSUITE_SCRIPT_DIR/.." 2>/dev/null && pwd || true)"
_FSUITE_LIB_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_LIB_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_common.sh")
_FSUITE_LIB_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_common.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_common.sh"
  "/usr/local/share/fsuite/_fsuite_common.sh"
  "/usr/share/fsuite/_fsuite_common.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

# ── Source DB library (for fcase integration) ────────────────────
_FSUITE_DB_TOOL_NAME="fbash"
for _fsuite_candidate in \
  "$_FSUITE_SCRIPT_DIR/_fsuite_db.sh" \
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_db.sh" \
  "/usr/local/share/fsuite/_fsuite_db.sh" \
  "/usr/share/fsuite/_fsuite_db.sh"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

# ── Telemetry — opt-out via FSUITE_TELEMETRY=0 ──────────────────
now_ms() {
  local ms=""
  ms=$(date +%s%3N 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then printf '%s' "$ms"; return 0; fi
  ms=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time() * 1000' 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then printf '%s' "$ms"; return 0; fi
  ms=$(date +%s 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then printf '%s' "$(( ms * 1000 ))"; return 0; fi
  printf '0'
}

_FSUITE_TELEM="${FSUITE_TELEMETRY:-1}"
[[ "$_FSUITE_TELEM" =~ ^[0-9]+$ ]] || _FSUITE_TELEM=1
_TELEM_START_MS=$(now_ms)
_TELEM_EXIT_CODE=0
_TELEM_FLAGS=""
_TELEM_PATH_HINT=""

# ── Globals ──────────────────────────────────────────────────────
SESSION_DIR="${FBASH_SESSION_DIR:-$HOME/.fsuite/fbash}"
SESSION_FILE="$SESSION_DIR/session.json"
JOBS_DIR="$SESSION_DIR/jobs"
SKIP_SESSION_SAVE=0
FBASH_RAW_OUTPUT=0

COMMAND=""
MAX_LINES=200
MAX_BYTES=51200
JSON_MODE=0
EXPLICIT_CWD=""
TIMEOUT=""
FILTER=""
QUIET=0
TAG=""
BACKGROUND=0
TAIL_MODE=0
OUTPUT="pretty"

SESSION_CWD=""
SESSION_CASE_SLUG=""

declare -a ENV_OVERRIDES=()
declare -a WARNINGS=()
# Budget globals (set by budget_output)
BUDGET_TOTAL_LINES=0
BUDGET_TOTAL_BYTES=0
BUDGET_TRUNCATED="false"
BUDGET_TRUNCATION_REASON=""

# Execution globals (set by execute_command)
EXEC_STDOUT_FILE=""
EXEC_STDERR_FILE=""
EXEC_EXIT_CODE=0
EXEC_DURATION_MS=0
EXEC_NEW_CWD=""
EXEC_TIMED_OUT=0
RENDER_BG_JOB_ID=""
RENDER_BG_STATUS=""

# Routing globals (set by compute_routing_suggestion)
ROUTING_TOOL=""
ROUTING_REASON=""
ROUTING_ARGS="{}"

# ── Helpers ──────────────────────────────────────────────────────

cleanup_exec_files() {
  [[ -n "${EXEC_STDOUT_FILE:-}" ]] && rm -f "$EXEC_STDOUT_FILE" 2>/dev/null || true
  [[ -n "${EXEC_STDERR_FILE:-}" ]] && rm -f "$EXEC_STDERR_FILE" 2>/dev/null || true
  EXEC_STDOUT_FILE=""
  EXEC_STDERR_FILE=""
}

die() { echo "fbash: error: $*" >&2; exit 1; }
has() { command -v "$1" >/dev/null 2>&1; }

json_escape_str() {
  perl -CS -0pe '
    s/\\/\\\\/g;
    s/"/\\"/g;
    s/\x08/\\b/g;
    s/\x0c/\\f/g;
    s/\n/\\n/g;
    s/\r/\\r/g;
    s/\t/\\t/g;
    s/([\x00-\x07\x0b\x0e-\x1f])/sprintf("\\u%04x", ord($1))/ge;
  '
}

normalize_abs_path() {
  local p="$1"
  if abs="$(realpath -e "$p" 2>/dev/null)"; then
    printf '%s' "$abs"
    return 0
  fi
  if abs="$(cd "$(dirname "$p")" 2>/dev/null && printf '%s/%s' "$(pwd)" "$(basename "$p")")"; then
    printf '%s' "$abs"
    return 0
  fi
  printf '%s' "$p"
}

token_estimate() {
  local bytes="${1:-0}"
  echo $(( (bytes * 10 + 34) / 35 ))  # ceil(bytes / 3.5)
}

# ── Usage ────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
fbash — token-budgeted shell execution for fsuite

USAGE
  fbash --command '<cmd>' [options]
  fbash '<cmd>' [options]

OPTIONS
  --command <cmd>       Bash command to execute (or pass as positional arg)
  --max-lines <n>       Cap stdout to n lines (default: 200)
  --max-bytes <n>       Cap stdout to n bytes (default: 51200)
  --json                Parse command output as JSON
  --cwd <path>          Working directory (overrides session CWD)
  --timeout <secs>      Timeout in seconds (auto-tuned by class if omitted)
  --env <KEY=VALUE>     Environment override (repeatable)
  --filter <regex>      Regex filter for output lines
  --quiet               Suppress stdout/stderr, return exit code + metadata
  --tag <label>         Label for fcase event logging
  --background          Run in background, return job_id
  --tail                Keep tail instead of head when truncating
  -o, --output <fmt>    Output format: pretty (default) or json
  --history             Show command history from session
  --version             Show version
  -h, --help            Show this help

INTERNAL COMMANDS
  __fbash_history       Return command history
  __fbash_session       Return full session state
  __fbash_reset         Clear session state
  __fbash_poll <id>     Check background job status
  __fbash_jobs          List background jobs
  __fbash_set_case <s>  Set active fcase slug
  __fbash_clear_case    Clear active fcase

EXAMPLES
  fbash --command 'git status'
  fbash --command 'npm test' --tail --max-lines 100
  fbash --command 'find . -name "*.ts"' -o json
  fbash --command 'npm run build' --background
  fbash --command '__fbash_poll fbash_1712035200_12345'
EOF
}

# ── Session State ────────────────────────────────────────────────

ensure_session_dir() {
  mkdir -p "$SESSION_DIR" 2>/dev/null || true
  mkdir -p "$JOBS_DIR" 2>/dev/null || true
}

load_session() {
  if [[ -f "$SESSION_FILE" ]] && has jq; then
    SESSION_CWD=$(jq -r '.cwd // empty' "$SESSION_FILE" 2>/dev/null || true)
    SESSION_CASE_SLUG=$(jq -r '.active_case_slug // empty' "$SESSION_FILE" 2>/dev/null || true)
  fi
}

save_session() {
  (( SKIP_SESSION_SAVE )) && return 0

  local new_cwd="$1"
  local cmd="$2"
  local class="$3"
  local exit_code="$4"
  local duration="$5"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "unknown")

  ensure_session_dir

  if ! has jq; then
    # Minimal fallback: just save CWD
    printf '{"cwd":"%s"}\n' "$new_cwd" > "$SESSION_FILE"
    return
  fi

  local history_entry
  history_entry=$(jq -n \
    --arg cmd "$cmd" \
    --arg class "$class" \
    --argjson exit_code "${exit_code:-0}" \
    --argjson duration "${duration:-0}" \
    --arg cwd "$new_cwd" \
    --arg ts "$ts" \
    --arg tag "${TAG:-}" \
    '{command:$cmd, class:$class, exit_code:$exit_code, duration_ms:$duration, cwd:$cwd, timestamp:$ts, tag:(if $tag == "" then null else $tag end)}')

  if [[ -f "$SESSION_FILE" ]]; then
    {
      flock -x 200 2>/dev/null
      local tmp_file="${SESSION_FILE}.tmp.$$"
      jq --argjson entry "$history_entry" --arg cwd "$new_cwd" --arg ts "$ts" '
        .cwd = $cwd |
        .updated_at = $ts |
        .history = ((.history // []) + [$entry] | .[-50:])
      ' "$SESSION_FILE" > "$tmp_file" && mv "$tmp_file" "$SESSION_FILE"
    } 200>"${SESSION_FILE}.lock" 2>/dev/null || true
  else
    jq -n --argjson entry "$history_entry" --arg cwd "$new_cwd" --arg ts "$ts" '{
      cwd: $cwd,
      env_overrides: {},
      history: [$entry],
      history_max: 50,
      active_case_slug: null,
      session_id: ("fbash_" + (now | tostring)),
      created_at: $ts,
      updated_at: $ts
    }' > "$SESSION_FILE" 2>/dev/null || true
  fi
}

save_active_case() {
  local slug="$1"
  ensure_session_dir
  if ! has jq; then return; fi
  if [[ -f "$SESSION_FILE" ]]; then
    {
      flock -x 200 2>/dev/null
      local tmp_file="${SESSION_FILE}.tmp.$$"
      if [[ -z "$slug" ]]; then
        jq '.active_case_slug = null' "$SESSION_FILE" > "$tmp_file" && mv "$tmp_file" "$SESSION_FILE"
      else
        jq --arg s "$slug" '.active_case_slug = $s' "$SESSION_FILE" > "$tmp_file" && mv "$tmp_file" "$SESSION_FILE"
      fi
    } 200>"${SESSION_FILE}.lock" 2>/dev/null || true
  else
    local ts
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "unknown")
    local case_val="null"
    [[ -n "$slug" ]] && case_val="\"$slug\""
    printf '{"cwd":"%s","env_overrides":{},"history":[],"history_max":50,"active_case_slug":%s,"session_id":"fbash_%s","created_at":"%s","updated_at":"%s"}\n' \
      "$PWD" "$case_val" "$(date +%s)" "$ts" "$ts" > "$SESSION_FILE" 2>/dev/null || true
  fi
}

# ── Command Classification ───────────────────────────────────────

classify_command() {
  local cmd="$1"
  local first_token="${cmd%% *}"
  # Strip path prefix (e.g., /usr/bin/git -> git)
  first_token="${first_token##*/}"

  case "$first_token" in
    make|cmake|gcc|g++|javac|tsc) echo "build" ;;
    gradle|mvn)                   echo "build" ;;
    cargo)
      case "$cmd" in
        *" build"*) echo "build" ;; *" test"*) echo "test" ;;
        *" install"*) echo "install" ;; *) echo "general" ;;
      esac ;;
    npm|npx|yarn|pnpm|bun)
      case "$cmd" in
        *" run build"*|*" run compile"*) echo "build" ;;
        *" test"*|*" run test"*)         echo "test" ;;
        *" install"*|*" add"*|*" ci"*)   echo "install" ;;
        *)                               echo "general" ;;
      esac ;;
    go)
      case "$cmd" in
        *" build"*) echo "build" ;; *" test"*) echo "test" ;;
        *" install"*) echo "install" ;; *) echo "general" ;;
      esac ;;
    jest|pytest|vitest|mocha|bats) echo "test" ;;
    git)                  echo "git" ;;
    pip|pip3)             echo "install" ;;
    apt|apt-get|brew)     echo "install" ;;
    docker|podman)        echo "service" ;;
    systemctl|journalctl) echo "service" ;;
    kubectl|helm)         echo "service" ;;
    pm2)                  echo "service" ;;
    ls|find|cat|head|tail|wc|du|df|stat|file|which|type|echo|printf|env|printenv|pwd|date|uname)
                          echo "query" ;;
    grep|rg|ag|ack)       echo "search" ;;
    sed|awk)              echo "search" ;;
    curl|wget|ssh|scp|rsync|ping|nc|nslookup|dig)
                          echo "network" ;;
    eslint|prettier|clippy|golint|shellcheck|flake8|mypy|black|ruff)
                          echo "lint" ;;
    __fbash_*)            echo "internal" ;;
    *)                    echo "general" ;;
  esac
}

default_timeout_for_class() {
  case "$1" in
    build)    echo 120 ;;
    test)     echo 120 ;;
    install)  echo 180 ;;
    service)  echo 60 ;;
    lint)     echo 60 ;;
    query)    echo 15 ;;
    search)   echo 30 ;;
    network)  echo 30 ;;
    git)      echo 30 ;;
    internal) echo 5 ;;
    *)        echo 30 ;;
  esac
}

auto_tail_class() {
  case "$1" in
    build|test|install|lint) return 0 ;;
    *) return 1 ;;
  esac
}

# ── Smart Routing ────────────────────────────────────────────────

compute_routing_suggestion() {
  local cmd="$1"
  local first_token="${cmd%% *}"
  first_token="${first_token##*/}"

  ROUTING_TOOL=""
  ROUTING_REASON=""
  ROUTING_ARGS="{}"

  case "$first_token" in
    ls)
      local ls_path
      ls_path=$(printf '%s' "$cmd" | sed 's/^ls[[:space:]]*//' | sed 's/-[a-zA-Z]*[[:space:]]*//g' | xargs 2>/dev/null || true)
      [[ -z "$ls_path" ]] && ls_path="."
      ROUTING_TOOL="fls"
      ROUTING_REASON="fls provides structured listing with recon mode and JSON output"
      ROUTING_ARGS="{\"path\":\"$(printf '%s' "$ls_path" | json_escape_str)\"}"
      ;;
    tree)
      local tree_path
      tree_path=$(printf '%s' "$cmd" | sed 's/^tree[[:space:]]*//' | sed 's/-[a-zA-Z]*[[:space:]]*//g' | xargs 2>/dev/null || true)
      [[ -z "$tree_path" ]] && tree_path="."
      ROUTING_TOOL="ftree"
      ROUTING_REASON="ftree snapshot mode combines recon + tree in one budgeted call"
      ROUTING_ARGS="{\"path\":\"$(printf '%s' "$tree_path" | json_escape_str)\",\"snapshot\":true}"
      ;;
    cat|head|tail)
      # Only suggest if not piped
      if [[ ! "$cmd" =~ \| ]]; then
        local read_file
        read_file=$(printf '%s' "$cmd" | sed "s/^${first_token}[[:space:]]*//" | sed 's/-[a-zA-Z0-9]*[[:space:]]*//g' | xargs 2>/dev/null || true)
        if [[ -n "$read_file" ]]; then
          ROUTING_TOOL="fread"
          ROUTING_REASON="fread provides budgeted reading with symbol resolution and line numbers"
          ROUTING_ARGS="{\"path\":\"$(printf '%s' "$read_file" | json_escape_str)\"}"
        fi
      fi
      ;;
    grep|rg|ag|ack)
      ROUTING_TOOL="fcontent"
      ROUTING_REASON="fcontent caps matches, ranks results, and provides next_hint"
      ROUTING_ARGS="{}"
      ;;
    find)
      ROUTING_TOOL="fsearch"
      ROUTING_REASON="fsearch handles file discovery with ranking and directory preview"
      ROUTING_ARGS="{}"
      ;;
    sed)
      if [[ "$cmd" == *"-i"* ]]; then
        ROUTING_TOOL="fedit"
        ROUTING_REASON="fedit provides surgical editing with preconditions and dry-run"
        ROUTING_ARGS="{}"
      fi
      ;;
    echo|printf)
      if [[ "$cmd" == *">"* ]]; then
        ROUTING_TOOL="fwrite"
        ROUTING_REASON="fwrite routes through fedit — one mutation brain, auditable"
        ROUTING_ARGS="{}"
      else
        ROUTING_TOOL=""
        ROUTING_REASON="Use direct text output instead of echo/printf through bash"
        ROUTING_ARGS="{}"
      fi
      ;;
    wc)
      if [[ "$cmd" == *"-l"* ]]; then
        ROUTING_TOOL="fmap"
        ROUTING_REASON="fmap provides symbol extraction with line counts"
        ROUTING_ARGS="{}"
      fi
      ;;
  esac
}

# ── Internal Command Dispatch ────────────────────────────────────

dispatch_internal() {
  # Internal commands execute locally and write their output to EXEC_STDOUT_FILE
  # so the normal render pipeline can wrap them in the standard JSON envelope.
  # This ensures the MCP server always gets a consistent contract.
  local cmd="$1"
  local start_ms
  start_ms=$(now_ms)

  ensure_session_dir

  case "$cmd" in
    __fbash_history*)
      if [[ -f "$SESSION_FILE" ]] && has jq; then
        jq '.history // []' "$SESSION_FILE" > "$EXEC_STDOUT_FILE"
      else
        echo "[]" > "$EXEC_STDOUT_FILE"
      fi
      ;;
    __fbash_session*)
      if [[ -f "$SESSION_FILE" ]]; then
        cat "$SESSION_FILE" > "$EXEC_STDOUT_FILE"
      else
        echo "{}" > "$EXEC_STDOUT_FILE"
      fi
      ;;
    __fbash_reset*)
      SKIP_SESSION_SAVE=1
      rm -f "$SESSION_FILE" "${SESSION_FILE}.lock" 2>/dev/null || true
      echo '{"status":"reset"}' > "$EXEC_STDOUT_FILE"
      ;;
    __fbash_poll*)
      local job_id="${cmd#__fbash_poll }"
      job_id="${job_id#"${job_id%%[![:space:]]*}"}"  # trim leading whitespace
      job_id="${job_id%"${job_id##*[![:space:]]}"}"  # trim trailing whitespace
      FBASH_RAW_OUTPUT=1
      poll_background_job "$job_id" > "$EXEC_STDOUT_FILE" 2>"$EXEC_STDERR_FILE" || EXEC_EXIT_CODE=$?
      ;;
    __fbash_jobs*)
      list_background_jobs > "$EXEC_STDOUT_FILE"
      ;;
    __fbash_set_case*)
      local slug="${cmd#__fbash_set_case }"
      slug="${slug#"${slug%%[![:space:]]*}"}"
      slug="${slug%"${slug##*[![:space:]]}"}"
      save_active_case "$slug"
      echo "{\"status\":\"ok\",\"active_case_slug\":\"$slug\"}" > "$EXEC_STDOUT_FILE"
      ;;
    __fbash_clear_case*)
      save_active_case ""
      echo '{"status":"ok","active_case_slug":null}' > "$EXEC_STDOUT_FILE"
      ;;
    *)
      # Not an internal command — return 1 to signal fall-through
      return 1
      ;;
  esac

  # Set execution metadata for the render pipeline
  local end_ms
  end_ms=$(now_ms)
  EXEC_DURATION_MS=$(( end_ms - start_ms ))
  (( EXEC_DURATION_MS < 0 )) && EXEC_DURATION_MS=0
  EXEC_NEW_CWD="$RESOLVED_CWD"
  EXEC_TIMED_OUT=0
  # Touch stderr file so it exists (internal commands don't produce stderr)
  : > "$EXEC_STDERR_FILE"
  return 0
}

# ── Background Job Management ────────────────────────────────────

cleanup_old_jobs() {
  # Auto-delete job files older than 1 hour
  find "$JOBS_DIR" -maxdepth 1 -type f -mmin +60 -delete 2>/dev/null || true
}

start_background_job() {
  local cmd="$1"
  local resolved_cwd="$2"
  local job_id="fbash_$(date +%s)_$$"

  ensure_session_dir

  # Write metadata
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "unknown")
  local cmd_class
  cmd_class=$(classify_command "$cmd")

  if has jq; then
    jq -n --arg cmd "$cmd" --arg cwd "$resolved_cwd" \
          --arg class "$cmd_class" \
          --arg ts "$ts" \
      '{command:$cmd, cwd:$cwd, class:$class, started_at:$ts}' \
      > "$JOBS_DIR/${job_id}.meta"
  else
    printf '{"command":"%s","cwd":"%s","class":"%s","started_at":"%s"}\n' \
      "$cmd" "$resolved_cwd" "$cmd_class" "$ts" \
      > "$JOBS_DIR/${job_id}.meta"
  fi

  # Build environment prefix (respecting ENV_OVERRIDES)
  local env_prefix=""
  for override in "${ENV_OVERRIDES[@]}"; do
    local env_key="${override%%=*}"
    local env_val="${override#*=}"
    if [[ -z "$env_val" ]]; then
      env_prefix+="unset ${env_key}; "
    else
      env_prefix+="export $(printf '%q' "$override"); "
    fi
  done

  # Build timeout command if available (respecting TIMEOUT)
  local timeout_cmd=""
  if [[ -n "${TIMEOUT:-}" ]] && has timeout; then
    timeout_cmd="timeout ${TIMEOUT}s "
  fi

  # Spawn background process with env and timeout support
  (
    cd "$resolved_cwd" 2>/dev/null || true
    ${timeout_cmd}bash -c "${env_prefix}${cmd}" > "$JOBS_DIR/${job_id}.out" 2> "$JOBS_DIR/${job_id}.err"
    echo $? > "$JOBS_DIR/${job_id}.rc"
  ) &
  echo $! > "$JOBS_DIR/${job_id}.pid"

  # Set permissions
  chmod 600 "$JOBS_DIR/${job_id}"* 2>/dev/null || true

  printf '%s' "$job_id"
}

poll_background_job() {
  local job_id="$1"
  local rc_file="$JOBS_DIR/${job_id}.rc"
  local meta_file="$JOBS_DIR/${job_id}.meta"

  if [[ ! -f "$meta_file" ]]; then
    if [[ "$OUTPUT" == "json" ]]; then
      printf '{"tool":"fbash","version":"%s","command":"__fbash_poll %s","command_class":"internal","exit_code":1,"cwd":"%s","cwd_changed":false,"duration_ms":0,"stdout":"","stderr":"unknown job: %s","stdout_lines":0,"stderr_lines":1,"truncated":false,"truncation_reason":null,"lines_total":0,"bytes_total":0,"token_estimate":0,"next_hint":null,"routing_suggestion":null,"metadata":{"files_modified":[],"background_job_id":null},"warnings":[],"errors":["unknown job: %s"]}\n' \
        "$VERSION" "$job_id" "${RESOLVED_CWD:-$PWD}" "$job_id" "$job_id"
    else
      echo "fbash: error: unknown job: $job_id"
    fi
    return 1
  fi

if [[ -f "$rc_file" ]]; then
    # Job complete
    local exit_code
    exit_code=$(cat "$rc_file" 2>/dev/null || echo 1)
    local poll_rc=1
    if [[ "$exit_code" =~ ^[0-9]+$ ]]; then
      poll_rc=$exit_code
    fi
    local stdout_content="" stderr_content=""

    if [[ -f "$JOBS_DIR/${job_id}.out" ]]; then
      # Apply budgeting to stdout
      local use_tail=0
      local cmd_class
      cmd_class=$(jq -r '.class // "general"' "$meta_file" 2>/dev/null || echo "general")
      if auto_tail_class "$cmd_class"; then use_tail=1; fi

      local poll_out_file poll_meta_file
      poll_out_file=$(mktemp)
      poll_meta_file=$(mktemp)
      budget_output "$JOBS_DIR/${job_id}.out" "$MAX_LINES" "$MAX_BYTES" "$use_tail" "$poll_out_file" "$poll_meta_file"
      read -r BUDGET_TOTAL_LINES BUDGET_TOTAL_BYTES BUDGET_TRUNCATED BUDGET_TRUNCATION_REASON < "$poll_meta_file" 2>/dev/null || true
      [[ "$BUDGET_TOTAL_LINES" =~ ^[0-9]+$ ]] || BUDGET_TOTAL_LINES=0
      [[ "$BUDGET_TOTAL_BYTES" =~ ^[0-9]+$ ]] || BUDGET_TOTAL_BYTES=0
      [[ "$BUDGET_TRUNCATED" == "true" ]] || BUDGET_TRUNCATED="false"
      [[ -n "$BUDGET_TRUNCATION_REASON" && "$BUDGET_TRUNCATION_REASON" != "false" ]] || BUDGET_TRUNCATION_REASON=""
      stdout_content=$(cat "$poll_out_file" 2>/dev/null || true)
      rm -f "$poll_out_file" "$poll_meta_file" 2>/dev/null || true
    fi
    if [[ -f "$JOBS_DIR/${job_id}.err" ]]; then
      stderr_content=$(head -n 100 "$JOBS_DIR/${job_id}.err" 2>/dev/null || true)
    fi

    # Compute duration from metadata
    local started_at duration_ms=0
    started_at=$(jq -r '.started_at // ""' "$meta_file" 2>/dev/null || true)
    if [[ -n "$started_at" ]] && has date; then
      local start_epoch end_epoch
      start_epoch=$(date -d "$started_at" +%s 2>/dev/null || echo 0)
      end_epoch=$(stat -c %Y "$rc_file" 2>/dev/null || echo 0)
      if (( start_epoch > 0 && end_epoch > 0 )); then
        duration_ms=$(( (end_epoch - start_epoch) * 1000 ))
      fi
    fi

    local orig_cmd
    orig_cmd=$(jq -r '.command // ""' "$meta_file" 2>/dev/null || echo "")
    local cmd_class_poll
    cmd_class_poll=$(jq -r '.class // "general"' "$meta_file" 2>/dev/null || echo "general")

if [[ "$OUTPUT" == "json" ]]; then
RENDER_BG_JOB_ID="$job_id"
RENDER_BG_STATUS="completed"
render_json \
"__fbash_poll $job_id" "internal" \
"$stdout_content" "$stderr_content" \
"$exit_code" "$duration_ms" \
"${RESOLVED_CWD:-$PWD}" "${RESOLVED_CWD:-$PWD}" \
"$BUDGET_TRUNCATED" "$BUDGET_TRUNCATION_REASON" \
"$BUDGET_TOTAL_LINES" "$BUDGET_TOTAL_BYTES" \
0
RENDER_BG_JOB_ID=""
RENDER_BG_STATUS=""
else
      echo "fbash: job $job_id complete (exit=$exit_code, ${duration_ms}ms)"
      if (( ! QUIET )) && [[ -n "$stdout_content" ]]; then
        echo "---"
        echo "$stdout_content"
      fi
      if [[ -n "$stderr_content" ]]; then
        echo "--- stderr ---"
        echo "$stderr_content"
      fi
    fi
    return "$poll_rc"
  else
    # Job still running
    local pid
    pid=$(cat "$JOBS_DIR/${job_id}.pid" 2>/dev/null || echo "0")
    local elapsed_ms=0
    local started_at
    started_at=$(jq -r '.started_at // ""' "$meta_file" 2>/dev/null || true)
    if [[ -n "$started_at" ]] && has date; then
      local start_epoch now_epoch
      start_epoch=$(date -d "$started_at" +%s 2>/dev/null || echo 0)
      now_epoch=$(date +%s 2>/dev/null || echo 0)
      if (( start_epoch > 0 && now_epoch > 0 )); then
        elapsed_ms=$(( (now_epoch - start_epoch) * 1000 ))
      fi
    fi

    if kill -0 "$pid" 2>/dev/null; then
      if [[ "$OUTPUT" == "json" ]]; then
        printf '{"tool":"fbash","version":"%s","command":"__fbash_poll %s","command_class":"internal","exit_code":null,"cwd":"%s","cwd_changed":false,"duration_ms":%d,"stdout":"","stderr":"","stdout_lines":0,"stderr_lines":0,"truncated":false,"truncation_reason":null,"lines_total":0,"bytes_total":0,"token_estimate":0,"next_hint":"fbash --command '"'"'__fbash_poll %s'"'"'","routing_suggestion":null,"metadata":{"files_modified":[],"background_job_id":"%s","background_status":"running","pid":%s,"elapsed_ms":%d},"warnings":[],"errors":[]}\n' \
          "$VERSION" "$job_id" "${RESOLVED_CWD:-$PWD}" "$elapsed_ms" "$job_id" "$job_id" "$pid" "$elapsed_ms"
      else
        echo "fbash: job $job_id running (pid=$pid, elapsed=${elapsed_ms}ms)"
        echo "  Poll: fbash --command '__fbash_poll $job_id'"
      fi
    else
      if [[ "$OUTPUT" == "json" ]]; then
        printf '{"tool":"fbash","version":"%s","command":"__fbash_poll %s","command_class":"internal","exit_code":1,"cwd":"%s","cwd_changed":false,"duration_ms":%d,"stdout":"","stderr":"process disappeared","stdout_lines":0,"stderr_lines":1,"truncated":false,"truncation_reason":null,"lines_total":0,"bytes_total":0,"token_estimate":0,"next_hint":null,"routing_suggestion":null,"metadata":{"files_modified":[],"background_job_id":"%s","background_status":"failed"},"warnings":[],"errors":["background process disappeared"]}\n' \
          "$VERSION" "$job_id" "${RESOLVED_CWD:-$PWD}" "$elapsed_ms" "$job_id"
      else
        echo "fbash: job $job_id failed (process disappeared)"
      fi
      return 1
    fi
  fi
}

list_background_jobs() {
  ensure_session_dir
  local json_arr="["
  local first=1
  for meta in "$JOBS_DIR"/*.meta; do
    [[ -f "$meta" ]] || continue
    local job_id
    job_id=$(basename "$meta" .meta)
    local status="running"
    [[ -f "$JOBS_DIR/${job_id}.rc" ]] && status="complete"
    local pid
    pid=$(cat "$JOBS_DIR/${job_id}.pid" 2>/dev/null || echo "0")
    if [[ "$status" == "running" ]] && ! kill -0 "$pid" 2>/dev/null; then
      status="failed"
    fi

    local entry
    if has jq; then
      entry=$(jq --arg id "$job_id" --arg status "$status" '. + {job_id:$id, status:$status}' "$meta" 2>/dev/null || echo "{\"job_id\":\"$job_id\",\"status\":\"$status\"}")
    else
      entry="{\"job_id\":\"$job_id\",\"status\":\"$status\"}"
    fi

    if (( first )); then
      first=0
    else
      json_arr+=","
    fi
    json_arr+="$entry"
  done
  json_arr+="]"
  echo "$json_arr"
}

# ── Execution Engine ─────────────────────────────────────────────

execute_command() {
  local cmd="$1"
  local resolved_cwd="$2"
  local resolved_timeout="$3"

  local stdout_file stderr_file pwd_file
  stdout_file="${EXEC_STDOUT_FILE:-}"
  stderr_file="${EXEC_STDERR_FILE:-}"
  [[ -n "$stdout_file" ]] || stdout_file=$(mktemp)
  [[ -n "$stderr_file" ]] || stderr_file=$(mktemp)
  : > "$stdout_file"
  : > "$stderr_file"
  pwd_file=$(mktemp)

  local start_ms exit_code=0
  start_ms=$(now_ms)

  # Build environment prefix
  local env_prefix=""
  for override in "${ENV_OVERRIDES[@]}"; do
    # Skip empty env removals
    local env_key="${override%%=*}"
    local env_val="${override#*=}"
    if [[ -z "$env_val" ]]; then
      env_prefix+="unset ${env_key}; "
    else
      env_prefix+="export $(printf '%q' "$override"); "
    fi
  done

  # Execute with timeout
  local quoted_cwd quoted_pwd_file shell_script
  quoted_cwd=$(printf '%q' "$resolved_cwd")
  quoted_pwd_file=$(printf '%q' "$pwd_file")
  shell_script="
${env_prefix}
cd ${quoted_cwd} 2>/dev/null || true
trap 'pwd -P > ${quoted_pwd_file}' EXIT
${cmd}
"

  if has timeout; then
    timeout "${resolved_timeout}s" bash -c "$shell_script" > "$stdout_file" 2> "$stderr_file" || exit_code=$?
  else
    bash -c "$shell_script" > "$stdout_file" 2> "$stderr_file" || exit_code=$?
  fi

  # Handle timeout exit code (124 for GNU timeout)
  local timed_out=0
  if (( exit_code == 124 )); then
    timed_out=1
  fi

  local end_ms duration_ms
  end_ms=$(now_ms)
  duration_ms=$(( end_ms - start_ms ))
  (( duration_ms < 0 )) && duration_ms=0

  local new_cwd="$resolved_cwd"
  if [[ -s "$pwd_file" ]]; then
    local tracked_cwd
    tracked_cwd=$(<"$pwd_file")
    if [[ "$tracked_cwd" == /* ]]; then
      new_cwd="$tracked_cwd"
    fi
  fi
  rm -f "$pwd_file" 2>/dev/null || true

  # Store results in globals
  EXEC_STDOUT_FILE="$stdout_file"
  EXEC_STDERR_FILE="$stderr_file"
  EXEC_EXIT_CODE="$exit_code"
  EXEC_DURATION_MS="$duration_ms"
  EXEC_NEW_CWD="$new_cwd"
  EXEC_TIMED_OUT="$timed_out"
}

# ── Output Budgeting ─────────────────────────────────────────────

budget_output() {
  # Reads $file, applies line/byte budgets, writes budgeted content to $out_file.
  # Writes metadata to $meta_file as: total_lines total_bytes truncated truncation_reason
  local file="$1"
  local max_lines="$2"
  local max_bytes="$3"
  local use_tail="$4"
  local out_file="$5"
  local meta_file="$6"

  local total_lines total_bytes
  total_lines=$(wc -l < "$file" 2>/dev/null || echo 0)
  total_bytes=$(wc -c < "$file" 2>/dev/null || echo 0)
  # Trim whitespace from wc output
  total_lines="${total_lines#"${total_lines%%[! ]*}"}"
  total_bytes="${total_bytes#"${total_bytes%%[! ]*}"}"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  [[ "$total_bytes" =~ ^[0-9]+$ ]] || total_bytes=0

  local truncated="false"
  local truncation_reason=""

  # Line budget
  if (( total_lines > max_lines )); then
    truncated="true"
    truncation_reason="max_lines"
    if (( use_tail )); then
      { tail -n "$max_lines" "$file"; printf '\n...(showing last %d of %d lines — use --filter or increase --max-lines)...' "$max_lines" "$total_lines"; } > "$out_file"
    else
      { head -n "$max_lines" "$file"; printf '\n...(showing first %d of %d lines — use --filter or increase --max-lines)...' "$max_lines" "$total_lines"; } > "$out_file"
    fi
    printf '%s %s %s %s\n' "$total_lines" "$total_bytes" "$truncated" "$truncation_reason" > "$meta_file"
    return
  fi

  # Byte budget
  if (( total_bytes > max_bytes )); then
    truncated="true"
    truncation_reason="max_bytes"
    if (( use_tail )); then
      { tail -c "$max_bytes" "$file"; printf '\n...(showing last %d of %d bytes — use --filter or increase --max-bytes)...' "$max_bytes" "$total_bytes"; } > "$out_file"
    else
      { head -c "$max_bytes" "$file"; printf '\n...(showing first %d of %d bytes — use --filter or increase --max-bytes)...' "$max_bytes" "$total_bytes"; } > "$out_file"
    fi
    printf '%s %s %s %s\n' "$total_lines" "$total_bytes" "$truncated" "$truncation_reason" > "$meta_file"
    return
  fi

  cp "$file" "$out_file"
  printf '%s %s %s %s\n' "$total_lines" "$total_bytes" "$truncated" "$truncation_reason" > "$meta_file"
}

# ── fcase Logging (async) ───────────────────────────────────────

log_to_fcase() {
  local case_slug="$1"
  local cmd="$2"
  local class="$3"
  local exit_code="$4"
  local duration="$5"
  local cwd="$6"

  # Skip logging for internal commands
  [[ "$class" == "internal" ]] && return 0

  # Skip trivial queries unless tagged or failed
  if [[ "$class" == "query" && -z "$TAG" && "$exit_code" == "0" ]]; then
    return 0
  fi

  # Only log tagged commands, failures, or significant classes
  if [[ -z "$TAG" && "$exit_code" == "0" ]]; then
    case "$class" in
      build|test|git|install) ;; # log these
      *) return 0 ;;             # skip others
    esac
  fi

  # Resolve fcase binary
  local fcase_bin=""
  for _c in "$_FSUITE_SCRIPT_DIR/fcase" "$(command -v fcase 2>/dev/null || true)"; do
    [[ -n "$_c" && -x "$_c" ]] && { fcase_bin="$_c"; break; }
  done
  [[ -n "$fcase_bin" ]] || return 0

  # Background log — never blocks command execution
  (
    local body="[fbash] ${cmd}"
    [[ -n "$TAG" ]] && body="[fbash:$TAG] ${cmd}"
    body+=" (exit=$exit_code, ${duration}ms)"
    FSUITE_TELEMETRY=0 "$fcase_bin" note "$case_slug" --body "$body" -o json >/dev/null 2>&1
  ) &
}

# ── Sensitive Token Detection ────────────────────────────────────

detect_sensitive_tokens() {
  local content="$1"
  # Look for base64-like strings > 40 chars that might be tokens/keys
  if printf '%s' "$content" | grep -qE '[A-Za-z0-9+/=]{40,}' 2>/dev/null; then
    return 0  # found potential tokens
  fi
  return 1
}

# ── JSON Rendering ───────────────────────────────────────────────

render_json() {
  local cmd="$1"
  local class="$2"
  local stdout_content="$3"
  local stderr_content="$4"
  local exit_code="$5"
  local duration_ms="$6"
  local new_cwd="$7"
  local old_cwd="$8"
  local truncated="$9"
  local truncation_reason="${10}"
  local total_lines="${11}"
  local total_bytes="${12}"
  local timed_out="${13:-0}"

local stdout_lines stderr_lines stdout_bytes
if [[ -n "$stdout_content" ]]; then
  stdout_bytes=$(printf '%s' "$stdout_content" | wc -c 2>/dev/null || echo 0)
  if [[ "$truncated" == "true" && "$truncation_reason" == "max_lines" ]]; then
    # When truncated by lines, report the requested line count, not the count
    # including the truncation marker
    stdout_lines="$MAX_LINES"
  else
    stdout_lines=$(printf '%s' "$stdout_content" | wc -l 2>/dev/null || echo 0)
    # Non-empty content with no newlines is still 1 line
    if (( stdout_lines == 0 )) && [[ -n "$stdout_content" ]]; then
      stdout_lines=1
    fi
  fi
else
  stdout_lines=0
  stdout_bytes=0
fi
  if [[ -n "$stderr_content" ]]; then
    stderr_lines=$(printf '%s' "$stderr_content" | wc -l 2>/dev/null || echo 0)
    if (( stderr_lines == 0 )) && [[ -n "$stderr_content" ]]; then
      stderr_lines=1
    fi
  else
    stderr_lines=0
  fi

  # Trim wc output
  stdout_lines="${stdout_lines#"${stdout_lines%%[! ]*}"}"
  stderr_lines="${stderr_lines#"${stderr_lines%%[! ]*}"}"
  stdout_bytes="${stdout_bytes#"${stdout_bytes%%[! ]*}"}"
  [[ "$stdout_lines" =~ ^[0-9]+$ ]] || stdout_lines=0
  [[ "$stderr_lines" =~ ^[0-9]+$ ]] || stderr_lines=0
  [[ "$stdout_bytes" =~ ^[0-9]+$ ]] || stdout_bytes=0

  local tok_est
  tok_est=$(token_estimate "$stdout_bytes")

  local cwd_changed="false"
  [[ "$new_cwd" != "$old_cwd" ]] && cwd_changed="true"

  if (( timed_out )); then
    truncation_reason="timeout"
    truncated="true"
  fi

  # Ensure numeric defaults
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  [[ "$total_bytes" =~ ^[0-9]+$ ]] || total_bytes=0
  [[ "$duration_ms" =~ ^[0-9]+$ ]] || duration_ms=0

  # Build warnings array
  local warnings_json=""
  local warn_items=()
  if [[ "$truncated" == "true" ]]; then
    warn_items+=("\"Output truncated: $total_lines lines -> $stdout_lines lines. Use --filter or increase --max-lines.\"")
  fi
  if [[ -n "$ROUTING_TOOL" ]]; then
    warn_items+=("\"Consider using $ROUTING_TOOL instead: $(printf '%s' "$ROUTING_REASON" | sed 's/"/\\"/g')\"")
  elif [[ -n "$ROUTING_REASON" ]]; then
    warn_items+=("\"$(printf '%s' "$ROUTING_REASON" | sed 's/"/\\"/g')\"")
  fi
  if detect_sensitive_tokens "$stdout_content" 2>/dev/null; then
    warn_items+=("\"Output may contain sensitive tokens\"")
fi
# Include any global WARNINGS accumulated during execution
for gw in "${WARNINGS[@]+"${WARNINGS[@]}"}"; do
  warn_items+=("\"$(printf '%s' "$gw" | sed 's/"/\\"/g')\"")
done
  local warn_joined=""
  local i=0
  for w in "${warn_items[@]}"; do
    if (( i > 0 )); then warn_joined+=","; fi
    warn_joined+="$w"
    (( i++ )) || true
  done

  # Build next_hint
  local next_hint=""
  if [[ "$truncated" == "true" ]]; then
    if [[ -n "$ROUTING_TOOL" ]]; then
      next_hint="$ROUTING_TOOL"
    elif [[ "$TAIL_MODE" == "0" ]] && auto_tail_class "$class" 2>/dev/null; then
      local escaped_cmd
      escaped_cmd=$(printf '%s' "$cmd" | sed "s/'/'\\\\''/g")
      next_hint="fbash --command '${escaped_cmd}' --tail"
    else
      local escaped_cmd
      escaped_cmd=$(printf '%s' "$cmd" | sed "s/'/'\\\\''/g")
      next_hint="fbash --command '${escaped_cmd}' --filter '<pattern>'"
    fi
  fi

  # Build routing_suggestion
  local routing_json="null"
  if [[ -n "$ROUTING_TOOL" ]]; then
    routing_json="{\"tool\":\"$(printf '%s' "$ROUTING_TOOL" | json_escape_str)\",\"reason\":\"$(printf '%s' "$ROUTING_REASON" | json_escape_str)\",\"args\":$ROUTING_ARGS}"
  elif [[ -n "$ROUTING_REASON" ]]; then
    routing_json="{\"tool\":null,\"reason\":\"$(printf '%s' "$ROUTING_REASON" | json_escape_str)\",\"args\":{}}"
  fi

  # Build errors array
  local errors_json="[]"
  if (( timed_out )); then
    errors_json="[\"Command timed out after ${TIMEOUT:-30}s\"]"
  fi

  # Assemble JSON
  local exit_code_json
  if [[ "$exit_code" == "null" ]]; then
    exit_code_json="null"
  else
    exit_code_json="$exit_code"
  fi

local next_hint_json="null"
if [[ -n "$next_hint" ]]; then
next_hint_json="\"$(printf '%s' "$next_hint" | json_escape_str)\""
fi

local bg_job_id_json="null"
local bg_meta_extra=""
if [[ -n "${RENDER_BG_JOB_ID:-}" ]]; then
bg_job_id_json="\"$(printf '%s' "$RENDER_BG_JOB_ID" | json_escape_str)\""
fi
if [[ -n "${RENDER_BG_STATUS:-}" ]]; then
bg_meta_extra+=",\"background_status\":\"$(printf '%s' "$RENDER_BG_STATUS" | json_escape_str)\""
fi

# Quiet mode: empty stdout/stderr
local out_stdout="$stdout_content"
  local out_stderr="$stderr_content"
  if (( QUIET )); then
    out_stdout=""
    out_stderr=""
    stdout_lines=0
    stderr_lines=0
    stdout_bytes=0
    tok_est=0
  fi

printf '{"tool":"fbash","version":"%s","command":"%s","command_class":"%s","exit_code":%s,"cwd":"%s","cwd_changed":%s,"duration_ms":%d,"stdout":"%s","stderr":"%s","stdout_lines":%d,"stderr_lines":%d,"truncated":%s,"truncation_reason":%s,"lines_total":%d,"bytes_total":%d,"token_estimate":%d,"next_hint":%s,"routing_suggestion":%s,"metadata":{"files_modified":[],"background_job_id":%s%s},"warnings":[%s],"errors":%s}\n' \
"$VERSION" \
"$(printf '%s' "$cmd" | json_escape_str)" \
"$class" \
    "$exit_code_json" \
    "$(printf '%s' "$new_cwd" | json_escape_str)" \
    "$cwd_changed" \
    "$duration_ms" \
    "$(printf '%s' "$out_stdout" | json_escape_str)" \
    "$(printf '%s' "$out_stderr" | json_escape_str)" \
    "$stdout_lines" \
    "$stderr_lines" \
    "$truncated" \
    "$(if [[ -n "$truncation_reason" ]]; then printf '"%s"' "$truncation_reason"; else printf 'null'; fi)" \
    "$total_lines" \
"$total_bytes" \
"$tok_est" \
"$next_hint_json" \
"$routing_json" \
"$bg_job_id_json" \
"$bg_meta_extra" \
"$warn_joined" \
"$errors_json"
}

# ── Pretty Rendering ─────────────────────────────────────────────

render_pretty() {
  local cmd="$1"
  local class="$2"
  local stdout_content="$3"
  local stderr_content="$4"
  local exit_code="$5"
  local duration_ms="$6"
  local new_cwd="$7"
  local truncated="$8"
  local total_lines="${9}"

  # ANSI codes
  local BOLD='\033[1m'
  local DIM='\033[2m'
  local RESET='\033[0m'
  local GREEN='\033[38;2;80;200;80m'
  local RED='\033[38;2;220;90;90m'
  local YELLOW='\033[38;2;230;219;116m'
  local PURPLE='\033[38;2;190;132;255m'
  local CYAN='\033[38;2;102;217;239m'
  local GRAY='\033[38;2;200;200;200m'

  # Class-specific color
  local class_color="$GRAY"
  case "$class" in
    build)   class_color='\033[38;2;166;226;46m' ;;
    test)    class_color="$CYAN" ;;
    git)     class_color="$PURPLE" ;;
    install) class_color='\033[38;2;253;151;31m' ;;
    service) class_color="$RED" ;;
    search)  class_color="$CYAN" ;;
    lint)    class_color="$YELLOW" ;;
  esac

  local exit_color="$GREEN"
  if [[ "$exit_code" != "0" && "$exit_code" != "null" ]]; then
    exit_color="$RED"
  fi

  # Header line
  printf "${class_color}${BOLD}%s${RESET} " "$class"
  printf "${exit_color}exit=%s${RESET} " "$exit_code"
  printf "${DIM}%dms${RESET} " "$duration_ms"
  printf "${DIM}cwd=${RESET}%s\n" "$new_cwd"

  # Truncation notice
  if [[ "$truncated" == "true" ]]; then
    printf "  ${YELLOW}truncated: showing %d of %d lines${RESET}\n" "$MAX_LINES" "$total_lines"
  fi

  # Routing hint
  if [[ -n "$ROUTING_TOOL" ]]; then
    printf "  ${PURPLE}hint:${RESET} use ${CYAN}%s${RESET} ${DIM}— %s${RESET}\n" "$ROUTING_TOOL" "$ROUTING_REASON"
  elif [[ -n "$ROUTING_REASON" ]]; then
    printf "  ${PURPLE}hint:${RESET} ${DIM}%s${RESET}\n" "$ROUTING_REASON"
  fi

  # Sensitive token warning
  if detect_sensitive_tokens "$stdout_content" 2>/dev/null; then
    printf "  ${YELLOW}warning: output may contain sensitive tokens${RESET}\n"
  fi

  echo ""

  # Output body
  if (( ! QUIET )); then
    if [[ -n "$stdout_content" ]]; then
      printf '%s\n' "$stdout_content"
    fi
    if [[ -n "$stderr_content" ]]; then
      printf "\n${RED}--- stderr ---${RESET}\n"
      printf '%s\n' "$stderr_content"
    fi
  fi

  # Next hint
  if [[ "$truncated" == "true" ]]; then
    local next_hint=""
    if [[ -n "$ROUTING_TOOL" ]]; then
      next_hint="$ROUTING_TOOL"
    elif [[ "$TAIL_MODE" == "0" ]] && auto_tail_class "$class" 2>/dev/null; then
      next_hint="fbash --command '$(printf '%s' "$cmd" | sed "s/'/'\\\\''/g")' --tail"
    else
      next_hint="fbash --command '$(printf '%s' "$cmd" | sed "s/'/'\\\\''/g")' --filter '<pattern>'"
    fi
    if [[ -n "$next_hint" ]]; then
      printf "\n${PURPLE}${BOLD}next ->${RESET} %s\n" "$next_hint"
    fi
  fi
}

# ── Telemetry ────────────────────────────────────────────────────

_fsuite_record_telemetry() {
  [[ "${_TELEM_EXIT_CODE:-}" =~ ^[0-9]+$ ]] || _TELEM_EXIT_CODE=$?
  (( _FSUITE_TELEM >= 1 )) || return 0
  [[ "$_TELEM_START_MS" != "0" ]] || return 0
  [[ "$_TELEM_START_MS" =~ ^[0-9]+$ ]] || return 0

  local end_ms dur_ms telem_dir ts mode_hint
  end_ms=$(now_ms)
  [[ "$end_ms" =~ ^[0-9]+$ ]] || return 0
  dur_ms=$(( end_ms - _TELEM_START_MS ))
  (( dur_ms < 0 )) && dur_ms=0

  telem_dir="$HOME/.fsuite"
  mkdir -p "$telem_dir" 2>/dev/null || return 0
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "unknown")

  local ph="unknown" pn="" abs_hint=""
  mode_hint="${CMD_CLASS:-general}"
  [[ -n "$_TELEM_PATH_HINT" ]] || _TELEM_PATH_HINT="${EXEC_NEW_CWD:-$PWD}"
  if [[ -n "$_TELEM_PATH_HINT" ]]; then
    abs_hint="$(normalize_abs_path "$_TELEM_PATH_HINT" 2>/dev/null || printf '%s' "$_TELEM_PATH_HINT")"
    ph=$(printf '%s' "$abs_hint" | sha256sum 2>/dev/null | cut -c1-16) || ph="unknown"
    [[ -z "$ph" ]] && ph="unknown"
    if type _fsuite_infer_project_name &>/dev/null; then
      pn=$(_fsuite_infer_project_name "$abs_hint" 2>/dev/null || true)
    else
      pn=$(basename "$abs_hint" 2>/dev/null | tr -cd '[:alnum:]. _-' || true)
    fi
  fi

  local _hw_fields=""
  if type _fsuite_collect_hw_telemetry &>/dev/null; then
    _fsuite_collect_hw_telemetry "$_FSUITE_TELEM" "${_TELEM_PATH_HINT:-}" 2>/dev/null || true
  fi
  if type _fsuite_hw_json_fields &>/dev/null && (( _FSUITE_TELEM >= 2 )); then
    _hw_fields=$(_fsuite_hw_json_fields "$_FSUITE_TELEM" 2>/dev/null || true)
    [[ -n "$_hw_fields" ]] && _hw_fields=",${_hw_fields}"
  fi

  local _safe_flags
  _safe_flags=$(printf '%s' "${_TELEM_FLAGS# }" | tr -cd '[:alnum:] _./:=-' | head -c 200)
  local _telem_run_id="${FSUITE_TELEMETRY_RUN_ID:-${_TELEM_START_MS}_$$}"
  local _telem_line
  _telem_line="{\"timestamp\":\"$ts\",\"run_id\":\"${_telem_run_id}\",\"tool\":\"fbash\",\"version\":\"$VERSION\",\"mode\":\"$mode_hint\",\"path_hash\":\"$ph\",\"project_name\":\"$pn\",\"duration_ms\":$dur_ms,\"exit_code\":$_TELEM_EXIT_CODE,\"depth\":-1,\"items_scanned\":0,\"bytes_scanned\":${BUDGET_TOTAL_BYTES:-0},\"flags\":\"$_safe_flags\",\"backend\":\"bash\"${_hw_fields}}"

  {
    flock -x 200 2>/dev/null
    echo "$_telem_line" >> "$telem_dir/telemetry.jsonl"
  } 200>"$telem_dir/.telemetry.lock" 2>/dev/null || true
}
trap 'cleanup_exec_files; _fsuite_record_telemetry' EXIT

# ── Parse Arguments ──────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
  case "$1" in
    --command)
      [[ -n "${2:-}" ]] || die "Missing value for --command"
      COMMAND="$2"; shift 2
      ;;
    --max-lines)
      [[ -n "${2:-}" ]] || die "Missing value for --max-lines"
      MAX_LINES="$2"; shift 2
      _TELEM_FLAGS+=" --max-lines $MAX_LINES"
      ;;
    --max-bytes)
      [[ -n "${2:-}" ]] || die "Missing value for --max-bytes"
      MAX_BYTES="$2"; shift 2
      _TELEM_FLAGS+=" --max-bytes $MAX_BYTES"
      ;;
    --json)
      JSON_MODE=1; shift
      _TELEM_FLAGS+=" --json"
      ;;
    --cwd)
      [[ -n "${2:-}" ]] || die "Missing value for --cwd"
      EXPLICIT_CWD="$2"; shift 2
      _TELEM_FLAGS+=" --cwd"
      ;;
    --timeout)
      [[ -n "${2:-}" ]] || die "Missing value for --timeout"
      TIMEOUT="$2"; shift 2
      _TELEM_FLAGS+=" --timeout $TIMEOUT"
      ;;
    --env)
      [[ -n "${2:-}" ]] || die "Missing value for --env"
      ENV_OVERRIDES+=("$2"); shift 2
      _TELEM_FLAGS+=" --env"
      ;;
    --filter)
      [[ -n "${2:-}" ]] || die "Missing value for --filter"
      FILTER="$2"; shift 2
      _TELEM_FLAGS+=" --filter"
      ;;
    --quiet)
      QUIET=1; shift
      _TELEM_FLAGS+=" --quiet"
      ;;
    --tag)
      [[ -n "${2:-}" ]] || die "Missing value for --tag"
      TAG="$2"; shift 2
      _TELEM_FLAGS+=" --tag"
      ;;
    --background)
      BACKGROUND=1; shift
      _TELEM_FLAGS+=" --background"
      ;;
    --tail)
      TAIL_MODE=1; shift
      _TELEM_FLAGS+=" --tail"
      ;;
    -o|--output)
      [[ -n "${2:-}" ]] || die "Missing value for --output"
      OUTPUT="$2"; shift 2
      ;;
    --version)
      echo "fbash $VERSION"; exit 0
      ;;
    --history)
      COMMAND="__fbash_history"; shift
      ;;
    -h|--help)
      usage; exit 0
      ;;
    --)
      shift; break
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      # Positional: treat as command if not set
      if [[ -z "$COMMAND" ]]; then
        COMMAND="$1"
      else
        die "Unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

# Consume remaining positional args after --
while [[ $# -gt 0 ]]; do
  if [[ -z "$COMMAND" ]]; then
    COMMAND="$1"
  else
    die "Unexpected argument: $1"
  fi
  shift
done

_TELEM_FLAGS+=" -o $OUTPUT"

# Validate output format
case "$OUTPUT" in
  pretty|json) ;;
  *) die "Invalid --output: $OUTPUT (expected pretty or json)" ;;
esac

[[ -n "$COMMAND" ]] || die "No command specified. Use --command '<cmd>' or pass as positional arg."

# --json flag: reserved for future structured output parsing
if (( JSON_MODE )); then
  WARNINGS+=("--json flag is reserved for future use; output format unchanged. Use -o json for JSON envelope.")
fi

# ── Main ─────────────────────────────────────────────────────────

ensure_session_dir
load_session

# Clean up old background jobs
cleanup_old_jobs

# Resolve CWD: explicit > session > process
RESOLVED_CWD="${EXPLICIT_CWD:-${SESSION_CWD:-$PWD}}"
# Validate resolved CWD exists, fallback to PWD
if [[ ! -d "$RESOLVED_CWD" ]]; then
  RESOLVED_CWD="$PWD"
fi

# Classify command
CMD_CLASS=$(classify_command "$COMMAND")
_TELEM_FLAGS+=" class=$CMD_CLASS"

# Pre-create temp files for stdout/stderr capture.
# Both internal and external commands write to these; the budget + render
# pipeline reads them afterward for a consistent MCP output contract.
EXEC_STDOUT_FILE=$(mktemp)
EXEC_STDERR_FILE=$(mktemp)

# Check for internal commands — dispatch writes to EXEC_STDOUT_FILE,
# then falls through to the normal budget + render pipeline.
IS_INTERNAL=0
if [[ "$COMMAND" == __fbash_* ]]; then
  if dispatch_internal "$COMMAND"; then
    IS_INTERNAL=1
  fi
fi

# --- External command path (skipped for internal commands) ---

if (( ! IS_INTERNAL )); then
  # Auto-tune timeout from command class if not set
  if [[ -z "$TIMEOUT" ]]; then
    TIMEOUT=$(default_timeout_for_class "$CMD_CLASS")
  fi

  # Cap timeout at 300s
  (( TIMEOUT > 300 )) && TIMEOUT=300

  # Auto-tail for build/test/install/lint if not explicitly set
  if (( ! TAIL_MODE )) && auto_tail_class "$CMD_CLASS"; then
    TAIL_MODE=1
  fi

  # Compute routing suggestion
  compute_routing_suggestion "$COMMAND"

  # Handle background execution
  if (( BACKGROUND )); then
    JOB_ID=$(start_background_job "$COMMAND" "$RESOLVED_CWD")
    if [[ "$OUTPUT" == "json" ]]; then
printf '{"tool":"fbash","version":"%s","command":"%s","command_class":"%s","exit_code":null,"cwd":"%s","cwd_changed":false,"duration_ms":0,"stdout":"","stderr":"","stdout_lines":0,"stderr_lines":0,"truncated":false,"truncation_reason":null,"lines_total":0,"bytes_total":0,"token_estimate":0,"next_hint":"fbash --command '"'"'__fbash_poll %s'"'"'","routing_suggestion":null,"metadata":{"files_modified":[],"background_job_id":"%s","background_status":"running"},"warnings":[],"errors":[]}\n' \
        "$VERSION" \
        "$(printf '%s' "$COMMAND" | json_escape_str)" \
        "$CMD_CLASS" \
        "$(printf '%s' "$RESOLVED_CWD" | json_escape_str)" \
        "$JOB_ID" \
        "$JOB_ID"
    else
      echo "fbash: background job started: $JOB_ID"
      echo "  Poll: fbash --command '__fbash_poll $JOB_ID'"
    fi
    exit 0
  fi

  # Execute external command — this creates its own temp files internally,
  # then sets EXEC_STDOUT_FILE, EXEC_STDERR_FILE, etc.
  execute_command "$COMMAND" "$RESOLVED_CWD" "$TIMEOUT"
fi

# Apply filter regex if provided
if [[ -n "$FILTER" ]]; then
  FILTERED_FILE=$(mktemp)
  grep -E "$FILTER" "$EXEC_STDOUT_FILE" > "$FILTERED_FILE" 2>/dev/null || true
  mv "$FILTERED_FILE" "$EXEC_STDOUT_FILE"
fi

# Budget stdout via file-based approach (avoids subshell global loss)
BUDGET_OUT_FILE=$(mktemp)
BUDGET_META_FILE=$(mktemp)
budget_output "$EXEC_STDOUT_FILE" "$MAX_LINES" "$MAX_BYTES" "$TAIL_MODE" "$BUDGET_OUT_FILE" "$BUDGET_META_FILE"

# Read budget metadata back
read -r BUDGET_TOTAL_LINES BUDGET_TOTAL_BYTES BUDGET_TRUNCATED BUDGET_TRUNCATION_REASON < "$BUDGET_META_FILE" 2>/dev/null || true
[[ "$BUDGET_TOTAL_LINES" =~ ^[0-9]+$ ]] || BUDGET_TOTAL_LINES=0
[[ "$BUDGET_TOTAL_BYTES" =~ ^[0-9]+$ ]] || BUDGET_TOTAL_BYTES=0
[[ "$BUDGET_TRUNCATED" == "true" ]] || BUDGET_TRUNCATED="false"
[[ -n "$BUDGET_TRUNCATION_REASON" && "$BUDGET_TRUNCATION_REASON" != "false" ]] || BUDGET_TRUNCATION_REASON=""

STDOUT_BUDGETED=$(cat "$BUDGET_OUT_FILE" 2>/dev/null || true)
rm -f "$BUDGET_OUT_FILE" "$BUDGET_META_FILE" 2>/dev/null || true

# Budget stderr (always head, max 100 lines)
STDERR_BUDGETED=$(head -n 100 "$EXEC_STDERR_FILE" 2>/dev/null || true)

# Save session state
save_session "$EXEC_NEW_CWD" "$COMMAND" "$CMD_CLASS" "$EXEC_EXIT_CODE" "$EXEC_DURATION_MS"

# Log to fcase if active case
if [[ -n "${SESSION_CASE_SLUG:-}" ]]; then
  log_to_fcase "$SESSION_CASE_SLUG" "$COMMAND" "$CMD_CLASS" "$EXEC_EXIT_CODE" "$EXEC_DURATION_MS" "$EXEC_NEW_CWD"
fi

# Set telemetry hints
_TELEM_PATH_HINT="$EXEC_NEW_CWD"

# Render output
if (( FBASH_RAW_OUTPUT )); then
  # Output is already in proper format, write as-is
  cat "$EXEC_STDOUT_FILE"
elif [[ "$OUTPUT" == "json" ]]; then
  render_json \
    "$COMMAND" "$CMD_CLASS" \
    "$STDOUT_BUDGETED" "$STDERR_BUDGETED" \
    "$EXEC_EXIT_CODE" "$EXEC_DURATION_MS" \
    "$EXEC_NEW_CWD" "$RESOLVED_CWD" \
    "$BUDGET_TRUNCATED" "$BUDGET_TRUNCATION_REASON" \
    "$BUDGET_TOTAL_LINES" "$BUDGET_TOTAL_BYTES" \
    "$EXEC_TIMED_OUT"
else
  render_pretty \
    "$COMMAND" "$CMD_CLASS" \
    "$STDOUT_BUDGETED" "$STDERR_BUDGETED" \
    "$EXEC_EXIT_CODE" "$EXEC_DURATION_MS" \
    "$EXEC_NEW_CWD" \
    "$BUDGET_TRUNCATED" "$BUDGET_TOTAL_LINES"
fi

# Cleanup temp files
cleanup_exec_files

# Propagate non-zero exit from the executed command for telemetry
_TELEM_EXIT_CODE="$EXEC_EXIT_CODE"

exit "$EXEC_EXIT_CODE"
