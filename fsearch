#!/usr/bin/env bash
# fsearch — filename/path search helper (glob-aware) with agent-friendly output.
# Public-repo-ready: no user-specific paths or secrets.

set -euo pipefail

VERSION="2.2.0"

# -------------------------
# Source common library for tiered telemetry
# -------------------------
_FSUITE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
_FSUITE_PARENT_DIR="$(cd "$_FSUITE_SCRIPT_DIR/.." 2>/dev/null && pwd || true)"
_FSUITE_LIB_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_LIB_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_common.sh")
_FSUITE_LIB_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_common.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_common.sh"
  "/usr/local/share/fsuite/_fsuite_common.sh"
  "/usr/share/fsuite/_fsuite_common.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

# -------------------------
# Telemetry — opt-out via FSUITE_TELEMETRY=0
# Tiers: 0=disabled, 1=timing+bytes, 2=+hardware, 3=+profile
# -------------------------
_FSUITE_TELEM="${FSUITE_TELEMETRY:-1}"
[[ "$_FSUITE_TELEM" =~ ^[0-9]+$ ]] || _FSUITE_TELEM=1
_TELEM_START_MS=$(date +%s%3N 2>/dev/null || echo 0)
_TELEM_EXIT_CODE=0
_TELEM_BYTES=-1
_TELEM_FLAGS=""
_TELEM_PROJECT_NAME=""

_fsuite_record_telemetry() {
  _TELEM_EXIT_CODE=$?
  (( _FSUITE_TELEM >= 1 )) || return 0
  [[ "$_TELEM_START_MS" != "0" ]] || return 0
  [[ "$_TELEM_START_MS" =~ ^[0-9]+$ ]] || return 0
  local end_ms
  end_ms=$(date +%s%3N 2>/dev/null || echo 0)
  [[ "$end_ms" != "0" ]] || return 0
  [[ "$end_ms" =~ ^[0-9]+$ ]] || return 0
  local dur_ms=$(( end_ms - _TELEM_START_MS ))
  (( dur_ms < 0 )) && dur_ms=0
  local telem_dir="$HOME/.fsuite"
  mkdir -p "$telem_dir" 2>/dev/null || return 0
  local ts
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "unknown")
  local ph=""
  if [[ -n "${SEARCH_PATH:-}" ]]; then
    local abs_sp
    abs_sp=$(cd "$SEARCH_PATH" 2>/dev/null && pwd) || abs_sp="$SEARCH_PATH"
    ph=$(printf "%s" "$abs_sp" | sha256sum 2>/dev/null | cut -c1-16) || true
    [[ -z "$ph" ]] && ph="unknown"
  fi
  # Sanitize project name: alphanumeric + safe chars only
  local pn=""
  if [[ -n "${SEARCH_PATH:-}" ]]; then
    local abs_pn
    abs_pn=$(cd "$SEARCH_PATH" 2>/dev/null && pwd) || abs_pn="$SEARCH_PATH"
    if type _fsuite_infer_project_name &>/dev/null; then
      pn=$(_fsuite_infer_project_name "$abs_pn")
    else
      pn=$(basename "$abs_pn" | tr -cd '[:alnum:]. _-')
    fi
  fi
  if [[ -n "${_TELEM_PROJECT_NAME:-}" ]]; then
    pn=$(printf '%s' "$_TELEM_PROJECT_NAME" | tr -cd '[:alnum:]. _-')
  fi
  # Compute bytes_scanned if not already set
  if [[ "$_TELEM_BYTES" -eq -1 ]] && [[ -d "${SEARCH_PATH:-}" ]]; then
    local _bs=""
    if command -v timeout >/dev/null 2>&1; then
      _bs=$(timeout 3 du -sb "$SEARCH_PATH" 2>/dev/null | cut -f1) || _bs=""
    else
      # macOS fallback: no timeout, use du -sk * 1024
      _bs=$(du -sk "$SEARCH_PATH" 2>/dev/null | cut -f1) || _bs=""
      [[ "${_bs:-}" =~ ^[0-9]+$ ]] && _bs=$(( _bs * 1024 ))
    fi
    [[ "${_bs:-}" =~ ^[0-9]+$ ]] && _TELEM_BYTES="$_bs"
  fi
  # Collect hardware telemetry if tier >= 2
  if type _fsuite_collect_hw_telemetry &>/dev/null; then
    _fsuite_collect_hw_telemetry "$_FSUITE_TELEM" "${SEARCH_PATH:-}"
  fi
  local _hw_fields=""
  if type _fsuite_hw_json_fields &>/dev/null && (( _FSUITE_TELEM >= 2 )); then
    _hw_fields=$(_fsuite_hw_json_fields "$_FSUITE_TELEM")
    [[ -n "$_hw_fields" ]] && _hw_fields=",${_hw_fields}"
  fi
  local _safe_flags
  _safe_flags=$(printf '%s' "${_TELEM_FLAGS# }" | tr -cd '[:alnum:] _./-' | head -c 200)
  local _telem_run_id="${FSUITE_TELEMETRY_RUN_ID:-${_TELEM_START_MS}_$$}"
  local _telem_line="{\"timestamp\":\"$ts\",\"run_id\":\"${_telem_run_id}\",\"tool\":\"fsearch\",\"version\":\"$VERSION\",\"mode\":\"search\",\"path_hash\":\"$ph\",\"project_name\":\"$pn\",\"duration_ms\":$dur_ms,\"exit_code\":$_TELEM_EXIT_CODE,\"depth\":-1,\"items_scanned\":${TOTAL_FOUND:-0},\"bytes_scanned\":${_TELEM_BYTES},\"flags\":\"$_safe_flags\",\"backend\":\"${BACKEND_BIN:-unknown}\"${_hw_fields}}"
  # Atomic append with flock to prevent interleaved writes
  {
    flock -x 200 2>/dev/null
    echo "$_telem_line" >> "$telem_dir/telemetry.jsonl"
  } 200>"$telem_dir/.telemetry.lock" 2>/dev/null || true
}
trap '_fsuite_record_telemetry' EXIT

# -------------------------
# Defaults (override via flags)
# -------------------------
DEFAULT_PATH="."
DEFAULT_MAX=50
DEFAULT_BACKEND="auto"   # auto|find|fd
DEFAULT_OUTPUT="pretty"  # pretty|json|paths
DEFAULT_EXCLUDE_PATTERNS=(
"*/node_modules"
"*/node_modules/*"
"*/dist"
"*/dist/*"
"*/build"
"*/build/*"
"*/.next"
"*/.next/*"
"*/coverage"
"*/coverage/*"
"*/.git"
"*/.git/*"
"*/vendor"
"*/vendor/*"
"*/target"
"*/target/*"
)

# -------------------------
# Helpers
# -------------------------
die() { echo "Error: $*" >&2; exit 1; }

has() { command -v "$1" >/dev/null 2>&1; }

normalize_input_path() {
  if type _fsuite_normalize_input_path &>/dev/null; then
    _fsuite_normalize_input_path "$1"
  else
    local p="$1"
    [[ -n "$p" ]] || return 0
    if [[ "$p" == "~/"* ]]; then
      p="${HOME}/${p#\~/}"
    elif [[ "$p" == "~" ]]; then
      p="$HOME"
    fi
    if [[ "$p" != /* ]]; then
      p="$PWD/$p"
    fi
    if [[ -e "$p" ]]; then
      realpath -e "$p" 2>/dev/null || printf "%s" "$p"
    else
      printf "%s" "$p"
    fi
  fi
}

path_is_low_signal_root() {
  if type _fsuite_path_is_low_signal_root &>/dev/null; then
    _fsuite_path_is_low_signal_root "$1"
  else
    local p="$1"
    [[ "$p" =~ (^|/)(node_modules|dist|build|\.next|coverage|\.git|vendor|target)(/|$) ]]
  fi
}

has_wildcard() {
  local token="$1"
  [[ "$token" == *'*'* || "$token" == *'?'* || "$token" == *'['* || "$token" == *']'* ]]
}

path_matches_filter() {
  local path="$1"
  local pattern="$2"

  if has_wildcard "$pattern"; then
    [[ "$path" == $pattern ]]
  else
    [[ "$path" == *"$pattern"* ]]
  fi
}

filter_results_stream() {
  local item pattern include_match exclude_match
  while IFS= read -r item; do
    [[ -z "$item" ]] && continue

    if (( ${#INCLUDE_PATTERNS[@]} > 0 )); then
      include_match=0
      for pattern in "${INCLUDE_PATTERNS[@]}"; do
        if path_matches_filter "$item" "$pattern"; then
          include_match=1
          break
        fi
      done
      (( include_match == 1 )) || continue
    fi

    if (( ${#EXCLUDE_PATTERNS[@]} > 0 )); then
      exclude_match=0
      for pattern in "${EXCLUDE_PATTERNS[@]}"; do
        if path_matches_filter "$item" "$pattern"; then
          exclude_match=1
          break
        fi
      done
      (( exclude_match == 1 )) && continue
    fi

    printf "%s\n" "$item"
  done
}

usage() {
  cat <<'EOF'
fsearch — fast filename/path search (glob patterns, extensions, agent-friendly)

USAGE
  fsearch [OPTIONS] <pattern_or_ext> [path]

QUICK EXAMPLES
  # Starts-with (glob)
  fsearch 'upscale*' /home/USER

  # Contains substring anywhere (use * on both sides)
  fsearch '*progress*' /var/log

  # Extension search (user can pass "log" or ".log")
  fsearch log /home/USER
  fsearch .log /home/USER

  # End-of-name (suffix)
  fsearch '*error' /var/log

  # Headless / agent-friendly output (paths only)
  fsearch --output paths '*.log' /var/log

  # JSON output (good for AI agents)
  fsearch --output json '*progress*' /home/USER

  # Prefer fd backend if available (faster than find)
  fsearch --backend fd '*.log' /

OPTIONS
  -p, --path PATH
      Search root. If omitted, uses current directory.

  -m, --max N
      Max number of results to print in pretty output. Default: 50
      (JSON output always includes the total count; still prints only up to --max results.)

  -I, --include PATTERN
      Keep only paths matching at least one include pattern.
      Can be repeated for broader selection.
      Pattern supports wildcard matching if it contains *, ?, or [ ].

  -x, --exclude PATTERN
      Exclude paths matching any pattern.
      Can be repeated for broader filtering.
      Pattern supports wildcard matching if it contains *, ?, or [ ].

  --no-default-ignore
      Disable built-in low-signal directory filtering.
      By default, fsearch suppresses dependency/build trees such as:
        node_modules, dist, build, .next, coverage, .git, vendor, target

  -b, --backend auto|find|fd
      Choose search backend.
        auto: use fd if installed, else find
        fd:   use fd (fast). Requires fd to be installed
        find: use POSIX find

  --type file|dir|both
      Choose the search surface. Default: file
        file: legacy file-name search
        dir:  directory-oriented nav surface (v1 contract)
        both: file + directory surface

  --match name|path|both
      Choose what the query matches against. Default: name
        name: match file or directory names
        path: match full paths
        both: allow either name or path matching

  --mode auto|literal|glob|ext
      Control query normalization. Default: auto
        auto:    legacy heuristic in file/name mode only
        literal: use the query as-is
        glob:    treat the query as a glob pattern
        ext:     force extension normalization (log -> *.log)

  --preview N
      Reserved shallow preview depth. Default: 0

  -o, --output pretty|paths|json
      pretty: human-friendly header + list (default)
      paths:  print only matching paths, one per line (best for piping/headless use)
      json:   print a compact JSON object (best for AI agents/tools)

  -q, --quiet
      Suppress header line in pretty mode. Useful for scripting.

  --project-name <name>
      Override project name in telemetry.

  -i, --interactive
      Force interactive prompts even if args were provided.

  --install-hints
      Print suggestions to install optional tools (fd, rg) and exit.
      (Does not install automatically; avoids storing credentials.)

  --self-check
      Checks availability of optional tools and prints guidance.
      If you intend to let the script invoke sudo-driven installs, authenticate first:
        sudo -v
      Then re-run with your preferred package installs manually.

  -h, --help
      Show help and exit.

NOTES ON PATTERNS (GLOBS)
  This tool searches FILE NAMES/PATHS (not file contents).
  Wildcards:
    *  matches any characters (including none)
    ?  matches exactly one character
  Common patterns:
    upscale*        "starts with upscale"
    *progress*      "contains progress anywhere"
    *.log           "ends with .log"
    *error          "ends with error"

  IMPORTANT: Quote patterns containing '*' or '?' so your shell doesn't expand them early:
    fsearch '*progress*' /some/path

EXTENSIONS
  Wildcards are preserved (e.g. *progress* or upscale*).
  If you pass:
    .log      -> treated as *.log
    file.txt  -> treated literally as file.txt
  If you pass a short lowercase token (<=4 chars, ^[a-z0-9]+$, not purely numeric):
    py    -> *.py
    main  -> *.main
  Numeric-only tokens are NOT treated as extensions:
    123   -> treated literally as 123

HEADLESS / AI AGENT USAGE
  This script is designed to be easy for an agent to call in "headless" mode:
    fsearch --output json '*token*' /path
  The agent can parse:
    - "total_found"
    - "shown"
    - "results" (array of file paths)
    - "backend" used
    - "pattern" and "name_glob" resolved
    - "path" searched

  For simple piping (no JSON parsing), use:
    fsearch --output paths '*.log' /var/log | head

SECURITY / SUDO
  This script DOES NOT store passwords. Do not embed admin passwords in scripts.
  If you need privileged scanning or installs:
    1) Authenticate once for your session:
         sudo -v
    2) Run commands with sudo as needed (recommended):
         sudo fsearch '*.log' /var/log
  Or configure tightly scoped sudoers rules (advanced; do carefully).

OPTIONAL TOOLS
  - fd: faster filename search backend than find
  - rg (ripgrep): searches INSIDE file contents (different problem)
  To get install hints:
    fsearch --install-hints

EOF
}

print_install_hints() {
  cat <<'EOF'
Optional tools you may want:

1) fd (recommended)
   Debian/Ubuntu:
     sudo apt update && sudo apt install -y fd-find
   Note: On Debian, the binary may be named "fdfind".
         You can create an alias or symlink if desired:
           sudo ln -s "$(command -v fdfind)" /usr/local/bin/fd

2) ripgrep (rg) — for searching inside file contents
   Debian/Ubuntu:
     sudo apt update && sudo apt install -y ripgrep

If you want this script to benefit from newly installed tools,
re-run it after installation.

Tip: authenticate once first (helps if you're doing multiple installs):
  sudo -v
EOF
}

# Normalize user pattern:
# - If user provides wildcards '*' or '?', respect as-is.
# - Else if pattern begins with '.', treat as extension: "*.ext"
# - Else if pattern contains '.', treat as literal name (or suffix) the user gave.
# - Else treat as extension: "*.pattern"
normalize_pattern() {
  local p="$1"
  local search_type="${2:-file}"
  local match_mode="${3:-name}"
  local query_mode="${4:-auto}"
  local out="$p"

  if [[ "$query_mode" == "literal" ]]; then
    printf "%s" "$p"
    return
  fi

  if [[ "$query_mode" == "glob" ]]; then
    printf "%s" "$p"
    return
  fi

  if [[ "$query_mode" == "ext" ]]; then
    if [[ "$p" == .* ]]; then
      printf "*%s" "$p"
    else
      printf "*.%s" "$p"
    fi
    return
  fi

  if [[ "$p" == *'*'* || "$p" == *'?'* ]]; then
    # Has wildcards: use as-is
    printf "%s" "$p"
    return
  fi

  if [[ "$search_type" == "file" && "$match_mode" == "name" && "$query_mode" == "auto" ]]; then
    if [[ "$p" == .* ]]; then
      # Starts with dot: treat as extension (.log → *.log)
      out="*${p}"
    elif [[ "$p" == *.* ]]; then
      # Contains dot: treat as literal (file.txt → file.txt)
      out="$p"
    else
      # No wildcards, no dots: heuristic to distinguish extensions from filenames.
      # Short all-lowercase strings (<=4 chars) → extension (py → *.py)
      # Everything else → literal filename (Makefile, LICENSE, index)
      if [[ ${#p} -le 4 ]] && [[ "$p" =~ ^[a-z0-9]+$ ]] && ! [[ "$p" =~ ^[0-9]+$ ]]; then
        out="*.${p}"
      else
        out="$p"
      fi
    fi
  fi

  printf "%s" "$out"
}

# Choose backend
choose_backend() {
  local requested="$1"
  if [[ "$requested" == "find" ]]; then
    echo "find"
  elif [[ "$requested" == "fd" ]]; then
    # Debian often has fdfind instead of fd; treat both.
    if has fd; then echo "fd"
    elif has fdfind; then echo "fdfind"
    else die "Backend 'fd' requested but 'fd'/'fdfind' not installed. Run: fsearch --install-hints"
    fi
  else
    # auto
    if has fd; then echo "fd"
    elif has fdfind; then echo "fdfind"
    else echo "find"
    fi
  fi
}

# Find results with find
run_find() {
  local path="$1"
  local query="$2"
  local search_type="${3:-file}"
  local match_mode="${4:-name}"
  local type_args=()

  case "$search_type" in
    file) type_args=(-type f) ;;
    dir) type_args=(-type d) ;;
    both) type_args=( \( -type f -o -type d \) ) ;;
  esac

  # 2>/dev/null to avoid permission noise in normal use; agent can rerun with sudo if needed.
  if [[ "$match_mode" == "name" ]]; then
    find "$path" "${type_args[@]}" -name "$query" 2>/dev/null | normalize_result_paths_stream
  else
    find "$path" "${type_args[@]}" 2>/dev/null \
      | normalize_result_paths_stream \
      | match_paths_stream "$query" "$match_mode"
  fi
}

# Find results with fd/fdfind
run_fd() {
  local bin="$1"   # fd or fdfind
  local path="$2"
  local query="$3"
  local search_type="${4:-file}"
  local match_mode="${5:-name}"
  local type_args=()

  case "$search_type" in
    file) type_args=(-t f) ;;
    dir) type_args=(-t d) ;;
    both) type_args=(-t f -t d) ;;
  esac

  # fd uses pattern matching; for glob, use --glob
  if [[ "$match_mode" == "name" ]]; then
    "$bin" "${type_args[@]}" --glob "$query" "$path" 2>/dev/null | normalize_result_paths_stream
  else
    "$bin" "${type_args[@]}" . "$path" 2>/dev/null \
      | normalize_result_paths_stream \
      | match_paths_stream "$query" "$match_mode"
  fi
}

normalize_result_paths_stream() {
  local item
  while IFS= read -r item; do
    [[ -z "$item" ]] && continue
    if [[ "$item" != "/" ]]; then
      item="${item%/}"
    fi
    printf "%s\n" "$item"
  done
}

match_paths_stream() {
  local query="$1"
  local match_mode="$2"
  local item base

  while IFS= read -r item; do
    [[ -z "$item" ]] && continue
    base="${item##*/}"

    case "$match_mode" in
      path)
        path_matches_filter "$item" "$query" && printf "%s\n" "$item"
        ;;
      both)
        if path_matches_filter "$base" "$query" || path_matches_filter "$item" "$query"; then
          printf "%s\n" "$item"
        fi
        ;;
      *)
        path_matches_filter "$base" "$query" && printf "%s\n" "$item"
        ;;
    esac
  done
}

collect_preview() {
  local dir_path="$1"
  local limit="$2"

  [[ "$limit" =~ ^[0-9]+$ ]] || return 0
  (( limit > 0 )) || return 0
  [[ -d "$dir_path" ]] || return 0

  find "$dir_path" -mindepth 1 -maxdepth 1 2>/dev/null \
    | filter_results_stream \
    | LC_ALL=C sort \
    | head -n "$((limit + 1))"
}

path_kind() {
  local path="$1"
  if [[ -d "$path" ]]; then
    printf "dir"
  else
    printf "file"
  fi
}

render_next_hint_json() {
  local path="$1"
  local kind="$2"
  local escaped_path

  escaped_path="$(printf "%s" "$path" | json_escape)"
  if [[ "$kind" == "dir" ]]; then
    printf '{"tool":"ftree","args":{"path":"%s","depth":2}}' "$escaped_path"
  else
    printf '{"tool":"fread","args":{"path":"%s"}}' "$escaped_path"
  fi
}

# JSON escape minimal
json_escape() {
  # Escapes JSON string delimiters plus all ASCII control characters.
  perl -0pe 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g; s/([\x00-\x1f])/sprintf("\\u%04x", ord($1))/ge'
}

# -------------------------
# Parse args
# -------------------------
PATTERN=""
SEARCH_PATH=""
MAX="$DEFAULT_MAX"
BACKEND="$DEFAULT_BACKEND"
OUTPUT="$DEFAULT_OUTPUT"
SEARCH_TYPE="file"
MATCH_MODE="name"
QUERY_MODE="auto"
PREVIEW="0"
FORCE_INTERACTIVE=0
INSTALL_HINTS=0
SELF_CHECK=0
QUIET=0
NO_DEFAULT_IGNORE=0
INCLUDE_PATTERNS=()
EXCLUDE_PATTERNS=()
TYPE_SEEN=0
MATCH_SEEN=0
MODE_SEEN=0
PREVIEW_SEEN=0

# Pre-process arguments: expand combined short flags like -m5 to -m 5
_args=()
for _arg in "$@"; do
  if [[ "$_arg" =~ ^-([m])([0-9]+)$ ]]; then
    _args+=("-${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}")
  else
    _args+=("$_arg")
  fi
done
set -- "${_args[@]}"

# Manual parsing to support both flags and positionals
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--path) SEARCH_PATH="${2:-}"; shift 2 ;;
    -m|--max) MAX="${2:-}"; _TELEM_FLAGS+=" -m $2"; shift 2 ;;
    -I|--include)
      [[ -n "${2:-}" ]] || die "Missing value for --include"
      INCLUDE_PATTERNS+=("$2")
      _TELEM_FLAGS+=" -I $2"
      shift 2
      ;;
    -x|--exclude)
      [[ -n "${2:-}" ]] || die "Missing value for --exclude"
      EXCLUDE_PATTERNS+=("$2")
      _TELEM_FLAGS+=" -x $2"
      shift 2
      ;;
    --no-default-ignore)
      NO_DEFAULT_IGNORE=1
      _TELEM_FLAGS+=" --no-default-ignore"
      shift
      ;;
    -b|--backend) BACKEND="${2:-}"; _TELEM_FLAGS+=" -b $2"; shift 2 ;;
    --type)
      [[ -n "${2:-}" ]] || die "Missing value for --type"
      case "$2" in
        file|dir|both) SEARCH_TYPE="$2" ;;
        *) die "Invalid --type: $2" ;;
      esac
      TYPE_SEEN=1
      _TELEM_FLAGS+=" --type $2"
      shift 2
      ;;
    --match)
      [[ -n "${2:-}" ]] || die "Missing value for --match"
      case "$2" in
        name|path|both) MATCH_MODE="$2" ;;
        *) die "Invalid --match: $2" ;;
      esac
      MATCH_SEEN=1
      _TELEM_FLAGS+=" --match $2"
      shift 2
      ;;
    --mode)
      [[ -n "${2:-}" ]] || die "Missing value for --mode"
      case "$2" in
        auto|literal|glob|ext) QUERY_MODE="$2" ;;
        *) die "Invalid --mode: $2" ;;
      esac
      MODE_SEEN=1
      _TELEM_FLAGS+=" --mode $2"
      shift 2
      ;;
    --preview)
      [[ -n "${2:-}" ]] || die "Missing value for --preview"
      [[ "$2" =~ ^[0-9]+$ ]] || die "Invalid --preview: $2"
      PREVIEW="$2"
      PREVIEW_SEEN=1
      _TELEM_FLAGS+=" --preview $2"
      shift 2
      ;;
    -o|--output) OUTPUT="${2:-}"; shift 2 ;;
    -q|--quiet) QUIET=1; _TELEM_FLAGS+=" -q"; shift ;;
    -i|--interactive) FORCE_INTERACTIVE=1; shift ;;
    --project-name)
      [[ -n "${2:-}" ]] || die "Missing value for --project-name"
      _TELEM_PROJECT_NAME="$2"; shift 2 ;;
    --install-hints) INSTALL_HINTS=1; shift ;;
    --self-check) SELF_CHECK=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --version) echo "fsearch $VERSION"; exit 0 ;;
    --) shift; break ;;
    -*) die "Unknown option: $1 (try --help)" ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

# Append any remaining args after --
while [[ $# -gt 0 ]]; do POSITIONAL+=("$1"); shift; done

PATTERN="${POSITIONAL[0]:-}"
SEARCH_PATH="${POSITIONAL[1]:-$SEARCH_PATH}"
SEARCH_PATH="${SEARCH_PATH:-$DEFAULT_PATH}"

# Install hints mode
if (( INSTALL_HINTS == 1 )); then
  print_install_hints
  exit 0
fi

# Self-check mode
if (( SELF_CHECK == 1 )); then
  echo "Self-check:"
  if has fd || has fdfind; then
    echo "  ✓ fd backend available ($(command -v fd 2>/dev/null || command -v fdfind))"
  else
    echo "  ✗ fd not found (recommended). Run: fsearch --install-hints"
  fi
  if has rg; then
    echo "  ✓ rg (ripgrep) available ($(command -v rg))"
  else
    echo "  ✗ rg not found (optional). Run: fsearch --install-hints"
  fi
  echo ""
  echo "If you plan to install packages and want fewer sudo prompts:"
  echo "  sudo -v"
  exit 0
fi

# Seed telemetry flags with defaults
_TELEM_FLAGS+=" -o ${OUTPUT:-pretty}"
(( TYPE_SEEN == 0 )) && _TELEM_FLAGS+=" --type $SEARCH_TYPE"
(( MATCH_SEEN == 0 )) && _TELEM_FLAGS+=" --match $MATCH_MODE"
(( MODE_SEEN == 0 )) && _TELEM_FLAGS+=" --mode $QUERY_MODE"
(( PREVIEW_SEEN == 0 )) && _TELEM_FLAGS+=" --preview $PREVIEW"

# Validate output/backend
case "$OUTPUT" in pretty|paths|json) ;; *) die "Invalid --output: $OUTPUT" ;; esac
case "$BACKEND" in auto|find|fd) ;; *) die "Invalid --backend: $BACKEND" ;; esac
[[ "$MAX" =~ ^[0-9]+$ ]] || die "--max must be an integer"

# Interactive prompt if requested or missing pattern
if (( FORCE_INTERACTIVE == 1 )) || [[ -z "$PATTERN" ]]; then
  echo "Interactive mode."
  read -r -p "Enter pattern or extension (e.g. upscale* or log): " PATTERN
  read -r -p "Enter search path (default: $SEARCH_PATH): " INPUT_PATH
  if [[ -n "${INPUT_PATH:-}" ]]; then SEARCH_PATH="$INPUT_PATH"; fi
fi

SEARCH_PATH="$(normalize_input_path "$SEARCH_PATH")"

if (( NO_DEFAULT_IGNORE == 0 )) && ! path_is_low_signal_root "$SEARCH_PATH"; then
  EXCLUDE_PATTERNS=("${DEFAULT_EXCLUDE_PATTERNS[@]}" "${EXCLUDE_PATTERNS[@]}")
fi

[[ -n "$PATTERN" ]] || die "Missing pattern. Try: fsearch --help"

NAME_GLOB="$(normalize_pattern "$PATTERN" "$SEARCH_TYPE" "$MATCH_MODE" "$QUERY_MODE")"
BACKEND_BIN="$(choose_backend "$BACKEND")"

# -------------------------
# Execute search
# -------------------------
# Bound memory: collect only MAX+1 filtered results first, then compute exact
# filtered total only when truncation is detected.
if [[ "$BACKEND_BIN" == "find" ]]; then
  mapfile -t RESULTS < <(run_find "$SEARCH_PATH" "$NAME_GLOB" "$SEARCH_TYPE" "$MATCH_MODE" | filter_results_stream | head -n "$((MAX + 1))" || true)
else
  mapfile -t RESULTS < <(run_fd "$BACKEND_BIN" "$SEARCH_PATH" "$NAME_GLOB" "$SEARCH_TYPE" "$MATCH_MODE" | filter_results_stream | head -n "$((MAX + 1))" || true)
fi

TOTAL_FOUND="${#RESULTS[@]}"
if (( TOTAL_FOUND > MAX )); then
  _full_count=0
  if [[ "$BACKEND_BIN" == "find" ]]; then
    _full_count=$(run_find "$SEARCH_PATH" "$NAME_GLOB" "$SEARCH_TYPE" "$MATCH_MODE" | filter_results_stream | wc -l || true)
  else
    _full_count=$(run_fd "$BACKEND_BIN" "$SEARCH_PATH" "$NAME_GLOB" "$SEARCH_TYPE" "$MATCH_MODE" | filter_results_stream | wc -l || true)
  fi
  _full_count="${_full_count//[[:space:]]/}"
  [[ "$_full_count" =~ ^[0-9]+$ ]] && TOTAL_FOUND="$_full_count"
fi
SHOWN="$TOTAL_FOUND"
if (( SHOWN > MAX )); then SHOWN="$MAX"; fi

TOP_LEVEL_NEXT_HINT_JSON="null"
if (( TOTAL_FOUND == 1 && SHOWN == 1 )); then
  _top_kind="$(path_kind "${RESULTS[0]}")"
  TOP_LEVEL_NEXT_HINT_JSON="$(render_next_hint_json "${RESULTS[0]}" "$_top_kind")"
fi

# -------------------------
# Output
# -------------------------
if [[ "$OUTPUT" == "paths" ]]; then
  for ((i=0; i<SHOWN; i++)); do
    printf "%s\n" "${RESULTS[i]}"
  done
  exit 0
fi

if [[ "$OUTPUT" == "json" ]]; then
  # Minimal JSON (no jq dependency).
  # Note: paths are escaped.
  echo -n "{"
  echo -n "\"tool\":\"fsearch\","
  echo -n "\"version\":\"$VERSION\","
  echo -n "\"pattern\":\"$(printf "%s" "$PATTERN" | json_escape)\","
  echo -n "\"name_glob\":\"$(printf "%s" "$NAME_GLOB" | json_escape)\","
  echo -n "\"path\":\"$(printf "%s" "$SEARCH_PATH" | json_escape)\","
  echo -n "\"backend\":\"$BACKEND_BIN\","
  echo -n "\"search_type\":\"$SEARCH_TYPE\","
  echo -n "\"match_mode\":\"$MATCH_MODE\","
  echo -n "\"preview_limit\":$PREVIEW,"
  echo -n "\"total_found\":$TOTAL_FOUND,"
  echo -n "\"shown\":$SHOWN,"
  echo -n "\"results\":["
  for ((i=0; i<SHOWN; i++)); do
    p="$(printf "%s" "${RESULTS[i]}" | json_escape)"
    if (( i > 0 )); then echo -n ","; fi
    echo -n "\"$p\""
  done
  echo -n "],\"hits\":["
  for ((i=0; i<SHOWN; i++)); do
    hit_path="${RESULTS[i]}"
    hit_kind="$(path_kind "$hit_path")"
    if (( i > 0 )); then echo -n ","; fi
    echo -n "{"
    echo -n "\"path\":\"$(printf "%s" "$hit_path" | json_escape)\","
    echo -n "\"kind\":\"$hit_kind\","
    echo -n "\"matched_on\":\"$MATCH_MODE\""

    if [[ "$hit_kind" == "dir" && "$PREVIEW" -gt 0 ]]; then
      mapfile -t PREVIEW_PATHS < <(collect_preview "$hit_path" "$PREVIEW" || true)
      preview_truncated="false"
      preview_count="${#PREVIEW_PATHS[@]}"
      if (( preview_count > PREVIEW )); then
        preview_truncated="true"
        preview_count="$PREVIEW"
      fi

      echo -n ",\"preview\":["
      for ((j=0; j<preview_count; j++)); do
        child_path="${PREVIEW_PATHS[j]}"
        child_name="${child_path##*/}"
        child_kind="$(path_kind "$child_path")"
        if (( j > 0 )); then echo -n ","; fi
        echo -n "{\"name\":\"$(printf "%s" "$child_name" | json_escape)\",\"kind\":\"$child_kind\"}"
      done
      echo -n "],\"preview_truncated\":$preview_truncated"
    fi

    echo -n ",\"next_hint\":$(render_next_hint_json "$hit_path" "$hit_kind")"
    echo -n "}"
  done
  echo -n "],\"next_hint\":$TOP_LEVEL_NEXT_HINT_JSON}"
  echo
  exit 0
fi

# pretty output
if (( QUIET == 0 )); then
  echo "Search(pattern: \"$PATTERN\" -> name \"$NAME_GLOB\", path: \"$SEARCH_PATH\")"
  echo "  ⎿ Found $TOTAL_FOUND results (backend: $BACKEND_BIN)"
fi
if (( TOTAL_FOUND == 0 )); then exit 0; fi
for ((i=0; i<SHOWN; i++)); do
  if (( QUIET == 1 )); then
    echo "${RESULTS[i]}"
  else
    echo "     ${RESULTS[i]}"
  fi
done
if (( QUIET == 0 )) && (( TOTAL_FOUND > MAX )); then
  echo "     … (showing first $MAX)"
fi
