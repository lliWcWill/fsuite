#!/usr/bin/env bash
# fsuite — suite-level help and workflow guidance for the fsuite toolchain.

set -euo pipefail

VERSION="3.3.0"

usage() {
  cat <<'EOF'
fsuite — suite-level help for the fsuite workflow

USAGE
  fsuite
  fsuite --help
  fsuite help
  fsuite tools
  fsuite flow
  fsuite examples
  fsuite version
  fsuite usage

DESCRIPTION
fsuite is the suite-level guide for the fourteen operational tools:
ftree, fls, fsearch, fcontent, fmap, fread, fcase, fedit, fwrite, fmetrics, freplay, fprobe, fbash, fs

  Use fsuite when you want the conceptual flow, tool roles, and headless
  operating pattern without digging through the README first.

NOTES
  fsuite, fsuite help, and fsuite --help print the full guide.
  fsuite usage and fsuite -h print this short usage summary.
EOF
}

print_help() {
  cat <<EOF
fsuite ${VERSION}

Fourteen operational tools. One composable sensor suite.

ftree     Scout the project once
fls       Quick directory listing — thin ftree router (list, little tree, recon)
fsearch   Find candidate files by name / extension / glob
fcontent  Confirm exact text across the narrowed set
fmap      Map symbols and structure (50 languages)
fread     Read the exact seam — text, image, or PDF (image/PDF via media engine)
fcase     Preserve investigation state and hand off cleanly
fedit     Preview and apply surgical patches
fwrite    Create/overwrite files via fedit's mutation engine (MCP-only)
fmetrics  Measure what happened, predict the next run, learning loop
freplay   Record and replay derivation paths for investigations
fprobe    Reconnoiter opaque files — binaries, bundles, packed assets
fbash     Token-budgeted shell with classification + background jobs (MCP-native)
fs        One-call search: routes queries to fsearch / fcontent / fmap automatically

Canonical agent flow

ftree -> fsearch | fcontent -> fmap -> fread -> fcase -> fedit -> freplay -> fmetrics
Scout    Narrowing             Bridge   Read     Preserve  Change    Replay     Measure

First-contact mindset

  - Composable sensor suite. Not a single sacred path.
  - There are stronger and weaker combinations, but no one true sequence.
  - Stop overcompensating for weak default tools; trust the direct contract.
  - Literal search is a strength here, not a fallback.
  - Use -o json and -o paths aggressively.
  - Treat fmap as the bridge in the middle, not only a producer before fread.
  - fmap + fread is the power pair for understanding code.
  - fcase preserves the seam once you know what matters.
  - Use ftree intentionally and sparingly on large repos.
  - Use fedit only after inspected context.
  - Use fmetrics for observability, not as a reason to spam ftree.

Strong combinations

  - fsearch -> fmap
  - fcontent -o paths -> fmap
  - fsearch -> fcontent -o paths -> fmap

Headless defaults

  - Prefer -o json for programmatic decisions.
  - Prefer -o paths when piping into another fsuite tool.
  - Prefer pretty only for human terminal output.
  - Results go to stdout. Errors go to stderr.

Examples

  fsuite flow
  fsearch -o paths '*.ts' /project/src | fmap -o json
  fsearch -o paths '*.ts' /project/src | fcontent -o paths "auth" | fmap -o json
  fread -o json /project/src/auth.ts --around "function authenticate" -A 20
  fedit -o json /project/src/auth.ts --function validateLength --replace "return false;" --with "return true;"
  ftree --snapshot -o json /project
  fmetrics import && fmetrics stats -o json

Use each tool's --help for the full flag surface.
EOF
}

print_tools() {
  cat <<'EOF'
Tool roles

  ftree
    Broad orientation. Use once to understand repo shape and likely hotspots.

  fsearch
    Candidate-file discovery by name, extension, or glob.

  fcontent
    Exact text confirmation across the narrowed file set.

  fmap
    Structural map of symbols, imports, functions, types, and handoff seams.

fread
Bounded reads around lines, patterns, symbols, and diffs. Auto-handles
image (PNG/JPEG/GIF/WEBP) and PDF inputs via the media engine — text
extraction, page render, or metadata-only modes.

fcase
Structured continuity for cases, evidence, hypotheses, and handoffs.

fedit
Surgical patching with dry-run diffs, symbol shortcuts, preconditions,
line-range mode, and batch targets-file support.

fwrite
MCP-only virtual tool. Routes through fedit's mutation engine for
file creation and full-file replacement. No CLI surface.

fmetrics
Telemetry import, stats, prediction, and learning-loop refinement
(combo recommendations, run-time prediction, history queries).

freplay
Derivation replay ledger. Records exact fsuite command paths during
investigations so another agent can reproduce the derivation without
improvising. Shares fcase.db for case-linked provenance.

fprobe
Binary and opaque-file reconnaissance — strings extraction, byte
pattern scan with offset context, raw byte-window reads. Python mmap
engine, safe on multi-GB binaries.

fbash
MCP-only token-budgeted shell. Classifies commands (build, test,
git, etc.), supports background jobs with poll/list, integrates with
fcase event logging. No bare-shell CLI surface.

fs
Unified search orchestrator. Auto-classifies query intent (file, content,
symbol, nav) and chains the right tools. Single entry point — agents
should default to fs first for any search before reaching for the
underlying primitives.

fls
Quick directory listing. Thin ftree router for list, little-tree, and
recon modes. Use when you know the directory and want what's in it.
EOF
}

print_flow() {
  cat <<'EOF'
Recommended workflow

  1. fsuite
     Load the suite-level mental model once.

  2. ftree
     Build the broad repo picture once, then stop unless the target changes.

  3. fsearch or fcontent
     Narrow to likely files by path or by literal evidence.

  4. fmap
     Bridge discovery to structural understanding in the middle of the pipeline.

  5. fread
     Pair with fmap to read the exact seam now that the target is clear.

  6. fcase
     Preserve the current case state once the seam, evidence, and next move are known.

  7. fedit
     Preview and apply a surgical change only after inspected context.

  8. freplay
     Record derivation paths during investigations for reproducibility.

  9. fmetrics
     Measure runtime history and import telemetry if needed.

Strong combinations:
  - fsearch -> fmap
  - fcontent -o paths -> fmap
  - fsearch -> fcontent -o paths -> fmap
  - fmap + fread
  - fmap + fread + fcase
  - freplay record + fcase (derivation provenance)

Mindset:
  - heuristic, not rigid rule
  - literal search is a first-class narrowing move
  - use -o json and -o paths aggressively

Heuristic, not rigid rule:
  ftree -> fsearch | fcontent -> fmap -> fread -> fcase -> fedit -> freplay -> fmetrics
EOF
}

print_examples() {
  cat <<'EOF'
Examples

  # Scout once
  ftree --snapshot -o json /project

  # Narrow by path, then map structure
  fsearch -o paths '*.py' /project/src | fmap -o json

  # Narrow by literal evidence, then map structure
  fcontent -o paths "authenticate" /project/src | fmap -o json

  # Narrow twice when needed: path -> exact text -> structure
  fsearch -o paths '*.py' /project/src | fcontent -o paths "authenticate" | fmap -o json

  # fmap + fread is the power pair for understanding code
  fread -o json /project/src/auth.py --around "def authenticate" -B 5 -A 20

  # Preserve continuity before editing or handing off
  fcase init auth-seam --goal "Trace authenticate flow"
  fcase evidence auth-seam --tool fread --path /project/src/auth.py --lines 40:72 --summary "Authenticate branch" --body "..."
  fread -o json /project/src/auth.py --around "def authenticate" -A 20 | fcase evidence import auth-seam
  fcase next auth-seam --body "Patch denial branch after reviewing symbol map"

  # Preview and apply a patch
  fedit -o json /project/src/auth.py --symbol authenticate --replace "return False" --with "return deny()"
  fedit -o json /project/src/auth.py --symbol authenticate --replace "return False" --with "return deny()" --apply

  # Record derivation steps
  freplay record auth-seam --purpose "map gateway symbols" -- fmap -o json src/gateway
  freplay record auth-seam --link evidence:71 -- fread src/auth.ts --symbol authenticate
  freplay show auth-seam -o json
  freplay verify auth-seam
  freplay promote auth-seam 1

  # Measure and inspect
  fmetrics import
  fmetrics stats -o json
EOF
}

if (( $# > 1 )); then
  echo "fsuite: extra arguments are not supported" >&2
  usage >&2
  exit 2
fi

case "${1:-help}" in
  help|--help)
    print_help
    ;;
  tools)
    print_tools
    ;;
  flow)
    print_flow
    ;;
  examples)
    print_examples
    ;;
  version|--version)
    echo "fsuite ${VERSION}"
    ;;
  usage|-h)
    usage
    ;;
  *)
    echo "fsuite: unknown subcommand: $1" >&2
    usage >&2
    exit 2
    ;;
esac
