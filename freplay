#!/usr/bin/env bash
# freplay — deterministic replay engine for fsuite investigation commands.

set -euo pipefail

VERSION="3.1.0"
_FSUITE_DB_TOOL_NAME="freplay"

# ---------------------------------------------------------------------------
# Source shared DB module (_fsuite_db.sh)
# ---------------------------------------------------------------------------
_FSUITE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
_FSUITE_PARENT_DIR="$(cd "$_FSUITE_SCRIPT_DIR/.." 2>/dev/null && pwd || true)"

_FSUITE_LIB_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_LIB_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_db.sh")
_FSUITE_LIB_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_db.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_db.sh"
  "/usr/local/share/fsuite/_fsuite_db.sh"
  "/usr/share/fsuite/_fsuite_db.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

if [[ -z "${_FSUITE_DB_LOADED:-}" ]]; then
  echo "freplay: fatal: cannot find _fsuite_db.sh (searched: ${_FSUITE_LIB_CANDIDATES[*]})" >&2
  exit 2
fi

# ---------------------------------------------------------------------------
# Source shared common module (_fsuite_common.sh)
# ---------------------------------------------------------------------------
_FSUITE_COMMON_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_COMMON_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_common.sh")
_FSUITE_COMMON_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_common.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_common.sh"
  "/usr/local/share/fsuite/_fsuite_common.sh"
  "/usr/share/fsuite/_fsuite_common.sh"
)
for _fsuite_candidate in "${_FSUITE_COMMON_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

# Tools that freplay will never record (denylist).
RECORDING_DENYLIST=("freplay" "fmetrics")

# Default mode classification per tool (tool → default mode).
declare -A TOOL_MODE_DEFAULT=(
  [ftree]="read_only"
  [fsearch]="read_only"
  [fcontent]="read_only"
  [fmap]="read_only"
  [fread]="read_only"
  [fedit]="read_only"
  [fprobe]="read_only"
  [fs]="read_only"
)

# Mode classification per fcase subcommand (subcommand → mode).
declare -A FCASE_SUBCOMMAND_MODE=(
  [status]="read_only"
  [handoff]="read_only"
  [export]="read_only"
  [list]="read_only"
  [init]="mutating"
  [note]="mutating"
  [next]="mutating"
  [target]="mutating"
  [evidence]="mutating"
  [hypothesis]="mutating"
  [reject]="mutating"
)

MAX_RESULT_SUMMARY=240
MAX_ERROR_EXCERPT=240

DEFAULT_OUTPUT="pretty"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
freplay — deterministic replay engine for fsuite investigation commands

USAGE
  freplay --help
  freplay --version
  freplay --self-check
  freplay record <case-slug> [--purpose "..."] [--link <type:id>]... [--replay-id N] [--new] -- <fsuite-command...>
  freplay show <case-slug> [--replay-id N] [-o pretty|json]
  freplay list <case-slug> [-o pretty|json]
  freplay export <case-slug> [--replay-id N] [-o json]
  freplay verify <case-slug> [--replay-id N] [-o pretty|json]
  freplay promote <case-slug> <replay-id>
  freplay archive <case-slug> <replay-id>

SUBCOMMANDS
  record     Run an fsuite command and record its invocation, output, and result
  show       Show a recorded replay (latest or by --replay-id)
  list       List all replays for a case
  export     Export a replay as JSON
  verify     Validate a replay without executing (check paths, tools, links)
  promote    Promote a replay to canonical status
  archive    Archive (soft-delete) a replay

OPTIONS
  --purpose  Human-readable purpose for this recording
  --link     Link this replay to a related entity (e.g. evidence:42)
  --replay-id  Select a specific replay by integer ID
  --new      Force creation of a new replay even if one exists for this command
  -o         Output format: pretty (default) or json

NOTES
  The following tools are excluded from recording:
    freplay, fmetrics
  fedit is classified read_only by default; mutating when --apply is present.
  verify exit codes: 0=pass, 1=warn, 2=fail.
EOF
}

# ---------------------------------------------------------------------------
# Self-check
# ---------------------------------------------------------------------------

cmd_self_check() {
  local all_ok=1

  if has sqlite3; then
    echo "sqlite3: OK"
  else
    echo "sqlite3: MISSING"
    all_ok=0
  fi

  if has perl; then
    echo "perl: OK"
  else
    echo "perl: MISSING"
    all_ok=0
  fi

  if db_exists; then
    echo "fcase.db: OK (${DB_FILE})"
  else
    echo "fcase.db: MISSING (expected at ${DB_FILE})"
    all_ok=0
  fi

  if [[ "$all_ok" -eq 1 ]]; then
    return 0
  else
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Helper: is_fsuite_tool — recognizes all fsuite tools by basename
# ---------------------------------------------------------------------------

is_fsuite_tool() {
  local tool_basename="$1"
  case "$tool_basename" in
    ftree|fsearch|fcontent|fmap|fread|fcase|fedit|fsuite|fmetrics|freplay|fprobe|fs) return 0 ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Helper: is_denied_tool — checks if tool is in RECORDING_DENYLIST
# ---------------------------------------------------------------------------

is_denied_tool() {
  local tool_basename="$1"
  local denied
  for denied in "${RECORDING_DENYLIST[@]}"; do
    [[ "$tool_basename" == "$denied" ]] && return 0
  done
  return 1
}

# ---------------------------------------------------------------------------
# Helper: derive_mode — returns read_only / mutating / unknown
# ---------------------------------------------------------------------------

derive_mode() {
  local tool="$1"
  shift
  local -a args=("$@")

  case "$tool" in
    fedit)
      local arg
      for arg in "${args[@]+"${args[@]}"}"; do
        [[ "$arg" == "--apply" ]] && { echo "mutating"; return; }
      done
      echo "read_only"
      return
      ;;
    fcase)
      # Extract subcommand: first non-flag arg
      local arg subcmd=""
      for arg in "${args[@]+"${args[@]}"}"; do
        if [[ "$arg" != -* ]]; then
          subcmd="$arg"
          break
        fi
      done
      if [[ -n "$subcmd" && -n "${FCASE_SUBCOMMAND_MODE[$subcmd]+_}" ]]; then
        echo "${FCASE_SUBCOMMAND_MODE[$subcmd]}"
      else
        echo "unknown"
      fi
      return
      ;;
    *)
      if [[ -n "${TOOL_MODE_DEFAULT[$tool]+_}" ]]; then
        echo "${TOOL_MODE_DEFAULT[$tool]}"
      else
        echo "unknown"
      fi
      return
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Helper: get_or_create_draft_replay — returns replay_id
# ---------------------------------------------------------------------------

get_or_create_draft_replay() {
  local case_id="$1"
  local now actor version_q now_q actor_q
  now="$(now_utc)"
  actor="$(whoami 2>/dev/null || echo unknown)"
  version_q="$(sql_quote "$VERSION")"
  now_q="$(sql_quote "$now")"
  actor_q="$(sql_quote "$actor")"

  # Single atomic operation: BEGIN IMMEDIATE acquires the write lock,
  # preventing concurrent processes from creating duplicate drafts.
  # INSERT ... WHERE NOT EXISTS creates a draft only if none exist.
  local sql_result
  sql_result="$({
    emit_db_session_prefix
    cat <<SQL
BEGIN IMMEDIATE;

-- Atomically create draft if none exists (lock is held)
INSERT INTO replays (case_id, status, origin, fsuite_version, actor, created_at, updated_at)
SELECT $case_id, 'draft', 'recorded', $version_q, $actor_q, $now_q, $now_q
WHERE NOT EXISTS (SELECT 1 FROM replays WHERE case_id=$case_id AND status='draft');
COMMIT;
SQL
  } | sqlite3 "$DB_FILE" 2>&1)" || die "DB error during draft resolution: $sql_result"

  # Query draft ids after the atomic create step. The write lock above guarantees
  # we did not create duplicates while deciding whether to insert.
  local ids=()
  local output
  output="$(db_query <<<"SELECT id FROM replays WHERE case_id=$case_id AND status='draft' ORDER BY id ASC;")"
  while IFS= read -r line; do
    [[ -n "$line" ]] && ids+=("$line")
  done <<< "$output"

  if (( ${#ids[@]} == 0 )); then
    die "failed to create or find draft replay"
  elif (( ${#ids[@]} == 1 )); then
    printf '%s' "${ids[0]}"
  else
    die "multiple draft replays exist for this case; use --replay-id N or --new to disambiguate"
  fi
}

# ---------------------------------------------------------------------------
# Helper: extract_result_summary — tool-aware summary from stdout
# ---------------------------------------------------------------------------

extract_result_summary() {
  local tool="$1"
  local stdout_file="$2"

  # Only call for read_only mode; caller ensures this.
  local summary
  summary="$(python3 -c "
import json, sys

tool = sys.argv[1]
try:
    with open(sys.argv[2], 'r') as f:
        raw = f.read()
except Exception:
    raw = ''

# Try JSON parse
data = None
try:
    data = json.loads(raw)
except Exception:
    pass

result = None

if tool == 'ftree':
    if data and isinstance(data, dict):
        snap = data.get('snapshot')
        if snap is not None:
            if isinstance(snap, list):
                entries = len(snap)
            elif isinstance(snap, dict):
                entries = len(snap)
            else:
                entries = '?'
            size_val = data.get('size', data.get('total_size', ''))
            result = f'snapshot: {entries} entries, {size_val}' if size_val else f'snapshot: {entries} entries'
        else:
            dirs = len(data.get('directories', []))
            files = len(data.get('files', []))
            result = f'tree: {dirs} dirs, {files} files'
    elif raw:
        # Non-JSON tree output: count dirs/files from lines
        dir_count = 0
        file_count = 0
        for line in raw.splitlines():
            stripped = line.strip()
            if stripped.endswith('/'):
                dir_count += 1
            elif stripped:
                file_count += 1
        result = f'tree: {dir_count} dirs, {file_count} files'

elif tool == 'fsearch':
    if data and isinstance(data, dict):
        matches = data.get('total_matches', data.get('match_count', '?'))
        files = len(data.get('files', data.get('results', [])))
        result = f'{matches} matches in {files} files'

elif tool == 'fcontent':
    if data and isinstance(data, dict):
        matches = data.get('total_matches', data.get('match_count', '?'))
        files = len(data.get('files', data.get('results', [])))
        result = f'{matches} matches in {files} files'

elif tool == 'fmap':
    if data and isinstance(data, dict):
        symbols = data.get('total_symbols', data.get('symbol_count', '?'))
        files = len(data.get('files', data.get('results', [])))
        result = f'{symbols} symbols in {files} files'

elif tool == 'fread':
    if data and isinstance(data, dict):
        lines = data.get('line_count', data.get('total_lines', '?'))
        path = data.get('path', data.get('file', ''))
        result = f'{lines} lines from {path}'

elif tool == 'fedit':
    if raw:
        if 'dry-run' in raw.lower() or 'dry run' in raw.lower():
            result = 'dry-run: ' + raw.splitlines()[0][:200]
        elif 'applied' in raw.lower():
            result = 'applied: ' + raw.splitlines()[0][:200]

elif tool == 'fcase':
    pass  # subcommand-dependent, null is fine

elif tool == 'fmetrics':
    if data and isinstance(data, dict):
        runs = data.get('total_runs', data.get('runs_imported', '?'))
        result = f'{runs} runs imported'
    elif raw:
        for line in raw.splitlines():
            if 'import' in line.lower():
                result = line.strip()[:240]
                break

if result is None and raw:
    result = raw.replace('\n', ' ').replace('\r', ' ')[:240]

if result is not None:
    result = result.replace('\n', ' ').replace('\r', ' ')[:240]
    print(result, end='')
" "$tool" "$stdout_file" 2>/dev/null)" || true

  echo "$summary"
}

# ---------------------------------------------------------------------------
# cmd_record — run an fsuite command and record it as a replay step
# ---------------------------------------------------------------------------

cmd_record() {
  local slug="" purpose="" replay_id_flag="" force_new=0
  local -a links=()
  local -a cmd_args=()
  local seen_separator=0

  # Parse arguments
  while (( $# > 0 )); do
    if (( seen_separator )); then
      cmd_args+=("$1")
      shift
      continue
    fi
    case "$1" in
      --)
        seen_separator=1
        shift
        ;;
      --purpose)
        [[ $# -ge 2 ]] || die 2 "--purpose requires a value"
        purpose="$2"
        shift 2
        ;;
      --purpose=*)
        purpose="${1#--purpose=}"
        shift
        ;;
      --link)
        [[ $# -ge 2 ]] || die 2 "--link requires a value"
        links+=("$2")
        shift 2
        ;;
      --link=*)
        links+=("${1#--link=}")
        shift
        ;;
      --replay-id)
        [[ $# -ge 2 ]] || die 2 "--replay-id requires a value"
        replay_id_flag="$2"
        shift 2
        ;;
      --replay-id=*)
        replay_id_flag="${1#--replay-id=}"
        shift
        ;;
      --new)
        force_new=1
        shift
        ;;
      -*)
        die 2 "unknown option: $1"
        ;;
      *)
        if [[ -z "$slug" ]]; then
          slug="$1"
        else
          die 2 "unexpected argument: $1 (missing -- separator before command?)"
        fi
        shift
        ;;
    esac
  done

  # Validation
  [[ -n "$slug" ]] || die 2 "case slug required"
  (( seen_separator )) || die 2 "-- separator required before command"
  (( ${#cmd_args[@]} > 0 )) || die 2 "command required after --"

  # --replay-id and --new are mutually exclusive
  if [[ -n "$replay_id_flag" ]] && (( force_new )); then
    die 2 "--replay-id and --new are mutually exclusive"
  fi

  # Extract tool basename
  local tool_path="${cmd_args[0]}"
  local tool_basename
  tool_basename="$(basename "$tool_path")"

  # Tool validation: is it an fsuite tool?
  if ! is_fsuite_tool "$tool_basename"; then
    die 2 "'$tool_basename' is not an fsuite tool"
  fi

  # Tool validation: is it denied?
  if is_denied_tool "$tool_basename"; then
    die 2 "'$tool_basename' is excluded from recording"
  fi

  # Validate --link format
  local lnk
  for lnk in "${links[@]+"${links[@]}"}"; do
    if [[ ! "$lnk" =~ ^(evidence|target|hypothesis):[0-9]+$ ]]; then
      die 2 "invalid --link format: '$lnk' (expected type:numeric_id, e.g. evidence:42)"
    fi
  done

  # DB setup and case lookup
  ensure_db
  local case_id
  case_id="$(case_exists_or_die "$slug")"

  # Draft resolution policy
  local replay_id
  if [[ -n "$replay_id_flag" ]]; then
    # Validate that replay exists and is a draft
    local replay_status
    replay_status="$(db_query <<<"SELECT status FROM replays WHERE id=$replay_id_flag AND case_id=$case_id;")"
    [[ -n "$replay_status" ]] || die "replay $replay_id_flag not found for case '$slug'"
    [[ "$replay_status" == "draft" ]] || die "replay $replay_id_flag has status '$replay_status'; only draft replays accept new steps"
    replay_id="$replay_id_flag"
  elif (( force_new )); then
    local now
    now="$(now_utc)"
    db_exec <<SQL
INSERT INTO replays (case_id, status, origin, fsuite_version, actor, created_at, updated_at)
  VALUES ($case_id, 'draft', 'recorded', $(sql_quote "$VERSION"), $(sql_quote "$(whoami)"), $(sql_quote "$now"), $(sql_quote "$now"));
SQL
    replay_id="$(db_query <<<"SELECT id FROM replays WHERE case_id=$case_id AND status='draft' ORDER BY id DESC LIMIT 1;")"
  else
    replay_id="$(get_or_create_draft_replay "$case_id")"
  fi

  # Derive mode
  local mode
  local -a tool_args=("${cmd_args[@]:1}")
  mode="$(derive_mode "$tool_basename" "${tool_args[@]+"${tool_args[@]}"}")"

  # Prepare temp files and cleanup trap
  local stdout_file stderr_file
  stdout_file="$(mktemp)"
  stderr_file="$(mktemp)"
  trap "rm -f '$stdout_file' '$stderr_file'" EXIT

  # Record cwd and start time
  local cwd started_at start_ns end_ns duration_ms
  cwd="$PWD"
  started_at="$(now_utc)"
  start_ns="$(date +%s%N)"

# Execute command, capturing stdout/stderr
local child_rc=0
local telemetry_level telemetry_run_id
telemetry_level="${FSUITE_TELEMETRY:-1}"
telemetry_run_id="${FSUITE_TELEMETRY_RUN_ID:-}"
if [[ -z "$telemetry_run_id" && "$telemetry_level" =~ ^[0-9]+$ ]] && (( telemetry_level >= 1 )); then
  telemetry_run_id="$(date +%s%3N 2>/dev/null || echo 0)_$$"
  [[ "$telemetry_run_id" == "0_$$" ]] && telemetry_run_id=""
fi
if [[ -n "$telemetry_run_id" ]]; then
  FSUITE_TELEMETRY_RUN_ID="$telemetry_run_id" "${cmd_args[@]}" >"$stdout_file" 2>"$stderr_file" || child_rc=$?
else
  "${cmd_args[@]}" >"$stdout_file" 2>"$stderr_file" || child_rc=$?
fi

  end_ns="$(date +%s%N)"
  duration_ms="$(( (end_ns - start_ns) / 1000000 ))"

  # Extract result_summary (read_only only); leave unset for NULL
  local result_summary=""
  local has_result_summary=0
  if [[ "$mode" == "read_only" ]]; then
    result_summary="$(extract_result_summary "$tool_basename" "$stdout_file")"
    [[ -n "$result_summary" ]] && has_result_summary=1
  fi

  # Extract error_excerpt (failure only, bounded); leave unset for NULL
  local error_excerpt=""
  local has_error_excerpt=0
  if (( child_rc != 0 )); then
    error_excerpt="$(head -c "$MAX_ERROR_EXCERPT" "$stderr_file" 2>/dev/null || true)"
    [[ -n "$error_excerpt" ]] && has_error_excerpt=1
  fi

  # Build argv_json as JSON array via python3 (args only, no tool path)
  local argv_json
  argv_json="$(python3 -c "
import json, sys
args = sys.argv[1:]
print(json.dumps(args))
" "${tool_args[@]+"${tool_args[@]}"}")"

  # Insert step with BEGIN IMMEDIATE + retry loop
  local sql_result="" attempt=0
  local sq_argv sq_cwd sq_mode sq_purpose sq_provenance sq_started sq_result_summary sq_error_excerpt sq_telemetry_run_id
  sq_argv="$(sql_quote "$argv_json")"
  sq_cwd="$(sql_quote "$cwd")"
  sq_mode="$(sql_quote "$mode")"
  # NULL when purpose not provided
  if [[ -n "$purpose" ]]; then
    sq_purpose="$(sql_quote "$purpose")"
  else
    sq_purpose="NULL"
  fi
  sq_provenance="$(sql_quote "recorded")"
  sq_started="$(sql_quote "$started_at")"
  # NULL when result_summary not populated
  if (( has_result_summary )); then
    sq_result_summary="$(sql_quote "$result_summary")"
  else
    sq_result_summary="NULL"
  fi
  # NULL when exit_code is 0 or error_excerpt not populated
  if (( has_error_excerpt )); then
    sq_error_excerpt="$(sql_quote "$error_excerpt")"
  else
    sq_error_excerpt="NULL"
  fi
# telemetry_run_id from shared child env, or NULL
if [[ -n "$telemetry_run_id" ]]; then
  sq_telemetry_run_id="$(sql_quote "$telemetry_run_id")"
else
  sq_telemetry_run_id="NULL"
fi

  # Build the atomic SQL block: step INSERT + last_insert_rowid + links + updated_at
  local update_now
  update_now="$(now_utc)"

  local atomic_sql
  atomic_sql="BEGIN IMMEDIATE;
INSERT INTO replay_steps (replay_id, order_num, tool, argv_json, cwd, mode, purpose, provenance, exit_code, duration_ms, started_at, telemetry_run_id, result_summary, error_excerpt)
  VALUES ($replay_id, (SELECT COALESCE(MAX(order_num),0)+1 FROM replay_steps WHERE replay_id=$replay_id), $(sql_quote "$tool_basename"), $sq_argv, $sq_cwd, $sq_mode, $sq_purpose, $sq_provenance, $child_rc, $duration_ms, $sq_started, $sq_telemetry_run_id, $sq_result_summary, $sq_error_excerpt);"

  # Append link INSERTs referencing the step we just inserted
  if (( ${#links[@]} > 0 )); then
    local lnk
    for lnk in "${links[@]+"${links[@]}"}"; do
      local link_type="${lnk%%:*}"
      local link_ref="${lnk#*:}"
      atomic_sql+="
INSERT INTO replay_step_links (step_id, link_type, link_ref)
  VALUES ((SELECT MAX(id) FROM replay_steps WHERE replay_id=$replay_id), $(sql_quote "$link_type"), $(sql_quote "$link_ref"));"
    done
  fi

  # Update replays.updated_at
  atomic_sql+="
UPDATE replays SET updated_at=$(sql_quote "$update_now") WHERE id=$replay_id;
COMMIT;"

  attempt=0
  while (( attempt < 3 )); do
    if sql_result="$({ emit_db_session_prefix; echo "$atomic_sql"; } | sqlite3 "$DB_FILE" 2>&1)"; then
      break
    fi
    if [[ "$sql_result" == *"database is locked"* || "$sql_result" == *"SQLITE_BUSY"* ]]; then
      attempt=$((attempt + 1))
      sleep 0.1
    else
      die "DB error: $sql_result"
    fi
  done
  if (( attempt >= 3 )); then
    die "DB busy after 3 retries — could not insert replay step"
  fi

  # Pass through stdout to caller
  cat "$stdout_file"

  # Pass through child stderr to caller
  cat "$stderr_file" >&2

  # Exit with child's exit code (transparent wrapper)
  exit "$child_rc"
}

cmd_list() {
  local slug="" output="pretty"

  while (( $# > 0 )); do
    case "$1" in
      -o)
        [[ $# -ge 2 ]] || die 2 "-o requires a value"
        output="$2"
        shift 2
        ;;
      -o=*)
        output="${1#-o=}"
        shift
        ;;
      -*)
        die 2 "unknown option: $1"
        ;;
      *)
        if [[ -z "$slug" ]]; then
          slug="$1"
        else
          die 2 "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$slug" ]] || die 2 "case slug required"
  [[ "$output" == "pretty" || "$output" == "json" ]] || die 2 "invalid output format: $output"

  db_exists || die "no fcase.db found"

  local case_id
  case_id="$(case_exists_or_die "$slug")"

  # Query replays ordered by id DESC, pipe-delimited
  local rows
  rows="$(db_query --separator '|' <<<"SELECT id, status, origin, (SELECT COUNT(*) FROM replay_steps WHERE replay_id=replays.id), created_at, label FROM replays WHERE case_id=$case_id ORDER BY id DESC;")"

  if [[ "$output" == "json" ]]; then
    python3 -c "
import sys, json

rows_raw = sys.argv[1]
replays = []
if rows_raw.strip():
    for line in rows_raw.strip().splitlines():
        parts = line.split('|', 5)
        if len(parts) < 6:
            parts += [''] * (6 - len(parts))
        replay_id, status, origin, step_count, created_at, label = parts
        replays.append({
            'id': int(replay_id),
            'status': status,
            'origin': origin,
            'step_count': int(step_count) if step_count.isdigit() else 0,
            'created_at': created_at,
            'label': label,
        })
print(json.dumps({'replays': replays}, indent=2))
" "$rows"
  else
    # Pretty: header + rows
    printf '%-6s  %-10s  %-10s  %-6s  %-20s  %s\n' 'ID' 'STATUS' 'ORIGIN' 'STEPS' 'CREATED_AT' 'LABEL'
    printf '%-6s  %-10s  %-10s  %-6s  %-20s  %s\n' '------' '----------' '----------' '------' '--------------------' '-----'
    if [[ -n "$rows" ]]; then
      while IFS='|' read -r rid rstatus rorigin rcount rcreated rlabel; do
        printf '%-6s  %-10s  %-10s  %-6s  %-20s  %s\n' "$rid" "$rstatus" "$rorigin" "$rcount" "$rcreated" "$rlabel"
      done <<<"$rows"
    fi
  fi
}

# ---------------------------------------------------------------------------
# _emit_replay — shared output formatter for show/export
# ---------------------------------------------------------------------------

_emit_replay() {
  local replay_id="$1"
  local slug="$2"
  local case_id="$3"
  local output="$4"

  # Build the entire replay as a single JSON blob using SQLite's json functions.
  # This avoids any pipe/newline delimiter issues in field values.
  local json_blob
  json_blob="$(db_query <<SQL
SELECT json_object(
  'version', '1.0',
  'tool', 'freplay',
  'case_slug', c.slug,
  'case_goal', c.goal,
  'replay_id', r.id,
  'replay_status', r.status,
  'replay_origin', r.origin,
  'fsuite_version', r.fsuite_version,
  'created_at', r.created_at,
  'actor', r.actor,
  'label', r.label,
  'step_count', (SELECT COUNT(*) FROM replay_steps WHERE replay_id=r.id),
  'steps', COALESCE(
    (SELECT json_group_array(json(step_json)) FROM (
      SELECT json_object(
        'order', rs.order_num,
        'tool', rs.tool,
        'argv', json(rs.argv_json),
        'cwd', rs.cwd,
        'mode', rs.mode,
        'purpose', rs.purpose,
        'provenance', rs.provenance,
        'exit_code', rs.exit_code,
        'duration_ms', rs.duration_ms,
        'started_at', rs.started_at,
        'result_summary', rs.result_summary,
        'error_excerpt', rs.error_excerpt,
        'links', COALESCE(
          (SELECT json_group_array(
            json_object('type', rsl.link_type, 'ref', rsl.link_ref)
          ) FROM replay_step_links rsl WHERE rsl.step_id = rs.id),
          json('[]')
        )
      ) AS step_json
      FROM replay_steps rs
      WHERE rs.replay_id = r.id
      ORDER BY rs.order_num
    )),
    json('[]')
  )
)
FROM replays r
JOIN cases c ON c.id = r.case_id
WHERE r.id = $replay_id AND r.case_id = $case_id;
SQL
)"
  [[ -n "$json_blob" ]] || die "replay $replay_id not found for case '$slug'"

  if [[ "$output" == "json" ]]; then
    python3 -c "
import sys, json
print(json.dumps(json.loads(sys.argv[1]), indent=2))
" "$json_blob"
  else
    # Pretty output: parse the JSON and format for humans
    python3 -c "
import sys, json

d = json.loads(sys.argv[1])

print(f'Replay #{d[\"replay_id\"]}  [{d[\"replay_status\"]}]  {d[\"case_slug\"]}')
print(f'  goal:    {d[\"case_goal\"]}')
print(f'  origin:  {d[\"replay_origin\"]}  version: {d[\"fsuite_version\"]}  actor: {d[\"actor\"]}')
print(f'  created: {d[\"created_at\"]}')
if d.get('label'):
    print(f'  label:   {d[\"label\"]}')
print()

steps = d.get('steps', [])
if steps:
    for s in steps:
        argv = s.get('argv', [])
        if isinstance(argv, list):
            argv_str = ' '.join(str(a) for a in argv)
        else:
            argv_str = str(argv)
        purpose = s.get('purpose')
        result_summary = s.get('result_summary')
        error_excerpt = s.get('error_excerpt')
        purpose_str = f'  purpose: {purpose}' if purpose is not None else ''
        result_str = f'  result:  {result_summary}' if result_summary is not None else ''
        error_str = f'  error:   {error_excerpt}' if error_excerpt is not None else ''
        print(f'  Step {s[\"order\"]}: {s[\"tool\"]} {argv_str}')
        print(f'    mode={s[\"mode\"]}  exit={s[\"exit_code\"]}  duration={s[\"duration_ms\"]}ms  cwd={s[\"cwd\"]}')
        if purpose_str:
            print(f'   {purpose_str}')
        if result_str:
            print(f'   {result_str}')
        if error_str:
            print(f'   {error_str}')
        print()
else:
    print('  (no steps recorded)')
" "$json_blob"
  fi
}

cmd_show() {
  local slug="" replay_id_flag="" output="pretty"

  while (( $# > 0 )); do
    case "$1" in
      --replay-id)
        [[ $# -ge 2 ]] || die 2 "--replay-id requires a value"
        replay_id_flag="$2"
        shift 2
        ;;
      --replay-id=*)
        replay_id_flag="${1#--replay-id=}"
        shift
        ;;
      -o)
        [[ $# -ge 2 ]] || die 2 "-o requires a value"
        output="$2"
        shift 2
        ;;
      -o=*)
        output="${1#-o=}"
        shift
        ;;
      -*)
        die 2 "unknown option: $1"
        ;;
      *)
        if [[ -z "$slug" ]]; then
          slug="$1"
        else
          die 2 "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$slug" ]] || die 2 "case slug required"
  [[ "$output" == "pretty" || "$output" == "json" ]] || die 2 "invalid output format: $output"

  db_exists || die "no fcase.db found"

  local case_id
  case_id="$(case_exists_or_die "$slug")"

  # Resolve replay_id using priority rules
  local replay_id
  if [[ -n "$replay_id_flag" ]]; then
    # Priority 1: explicit --replay-id
    local check
    check="$(db_query <<<"SELECT id FROM replays WHERE id=$replay_id_flag AND case_id=$case_id;")"
    [[ -n "$check" ]] || die "replay $replay_id_flag not found for case '$slug'"
    replay_id="$replay_id_flag"
  else
    # Priority 2: canonical replay
    local canonical_id
    canonical_id="$(db_query <<<"SELECT id FROM replays WHERE case_id=$case_id AND status='canonical' LIMIT 1;")"
    if [[ -n "$canonical_id" ]]; then
      replay_id="$canonical_id"
    else
      # Priority 3: newest draft (highest id)
      local draft_id
      draft_id="$(db_query <<<"SELECT id FROM replays WHERE case_id=$case_id AND status='draft' ORDER BY id DESC LIMIT 1;")"
      if [[ -n "$draft_id" ]]; then
        replay_id="$draft_id"
      else
        # Priority 4: no active replay (only archived or none)
        die "no active replay found for case '$slug'; use --replay-id N to view an archived replay"
      fi
    fi
  fi

  _emit_replay "$replay_id" "$slug" "$case_id" "$output"
}

