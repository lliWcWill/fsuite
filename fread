# Binary extension denylist
# -------------------------
_BINARY_EXT_RE='(pyc|pyo|so|o|a|dylib|dll|exe|com|class|jar|war|ear|zip|gz|bz2|xz|zst|lz4|tar|7z|rar|png|jpg|jpeg|gif|bmp|ico|tiff|webp|mp3|mp4|avi|mkv|mov|flv|wav|ogg|flac|aac|woff|woff2|ttf|otf|eot|pdf|doc|docx|xls|xlsx|ppt|pptx|sqlite|db|wasm)$'

