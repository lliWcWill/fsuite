# -------------------------
# Helpers
# -------------------------
die() {
  local code=2
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    code="$1"
    shift
  fi
  echo "fread: $*" >&2
  exit "$code"
}

has() { command -v "$1" >/dev/null 2>&1; }

json_escape_str() {
  printf '%s' "$1" | perl -0777 -pe '
    s/\\/\\\\/g;
    s/"/\\"/g;
    s/\x08/\\b/g;
    s/\t/\\t/g;
    s/\x0c/\\f/g;
    s/\r/\\r/g;
    s/\n/\\n/g;
    s/([\x00-\x1f])/sprintf("\\u%04x",ord($1))/ge;
  '
}

byte_len() {
  local s="$1"
  local old_lc_all="__FSUITE_UNSET__"
  if [[ -n "${LC_ALL+x}" ]]; then
    old_lc_all="$LC_ALL"
  fi
  LC_ALL=C
  local n=${#s}
  if [[ "$old_lc_all" == "__FSUITE_UNSET__" ]]; then
    unset LC_ALL
  else
    LC_ALL="$old_lc_all"
  fi
  printf '%s' "$n"
}

truncate_utf8_bytes() {
  local max="${1:-0}"
  python3 -c '
import sys

limit = max(int(sys.argv[1]), 0)
data = sys.stdin.buffer.read()
if len(data) <= limit:
  sys.stdout.write(data.decode("utf-8", "strict"))
else:
  # Find the largest prefix <= limit that successfully decodes as UTF-8
  end = limit
  while end > 0:
    try:
      sys.stdout.write(data[:end].decode("utf-8", "strict"))
      break
    except UnicodeDecodeError:
      end -= 1
' "$max"
}

token_estimate_from_bytes() {
  local bytes="${1:-0}"
  (( bytes < 0 )) && bytes=0
  echo $(( (bytes + 2) / 3 ))
}

emit_media_pretty_budgeted_text() {
  local text="$1"
  local line line_bytes remaining_bytes clipped clipped_bytes

  while IFS= read -r line || [[ -n "$line" ]]; do
    line_bytes=$(byte_len "${line}"$'\n')
    if check_budget_preadd 1 "$line_bytes"; then
      printf '%s\n' "$line"
      TOTAL_LINES_READ=$((TOTAL_LINES_READ + 1))
      TOTAL_BYTES_READ=$((TOTAL_BYTES_READ + line_bytes))
      continue
    fi

    if [[ "$TRUNCATION_REASON" == "max_bytes" ]] && (( MAX_BYTES > 0 )); then
      remaining_bytes=$((MAX_BYTES - TOTAL_BYTES_READ))
      if (( remaining_bytes > 1 )) && (( MAX_LINES == 0 || TOTAL_LINES_READ + 1 <= MAX_LINES )); then
        clipped="$(printf '%s' "$line" | truncate_utf8_bytes "$((remaining_bytes - 1))")"
        if [[ -n "$clipped" ]]; then
          clipped_bytes=$(byte_len "${clipped}"$'\n')
          if (( TOTAL_BYTES_READ + clipped_bytes <= MAX_BYTES )); then
            printf '%s\n' "$clipped"
            TOTAL_LINES_READ=$((TOTAL_LINES_READ + 1))
            TOTAL_BYTES_READ=$((TOTAL_BYTES_READ + clipped_bytes))
          fi
        fi
      fi
    fi

    return 1
  done <<< "$text"

  return 0
}

file_bytes() {
  if stat -c %s "$1" 2>/dev/null; then
    return
  fi
  stat -f %z "$1" 2>/dev/null || echo "0"
}

count_file_lines() {
  wc -l < "$1" 2>/dev/null | tr -d '[:space:]'
}

normalize_abs_path() {
local p="$1"
if abs="$(realpath -e "$p" 2>/dev/null)"; then
printf '%s' "$abs"
return 0
  fi
  if abs="$(cd "$(dirname "$p")" 2>/dev/null && printf '%s/%s' "$(pwd)" "$(basename "$p")")"; then
    printf '%s' "$abs"
    return 0
fi
printf '%s' "$p"
}

split_multi_paths() {
local input="$1"
local token="" char next_char
local i input_len
_MULTI_PATH_ARR=()
input_len=${#input}

for ((i=0; i<input_len; i++)); do
  char="${input:i:1}"
  if [[ "$char" == '\' ]] && (( i + 1 < input_len )); then
    next_char="${input:i+1:1}"
    if [[ "$next_char" == "," ]]; then
      token+=","
      ((i++))
      continue
    fi
  fi
  if [[ "$char" == "," ]]; then
    _MULTI_PATH_ARR+=("$token")
    token=""
    continue
  fi
  token+="$char"
done

_MULTI_PATH_ARR+=("$token")
}

detect_language() {
  local file="$1"
  local base ext
  base="$(basename "$file")"
  ext="${base##*.}"
  [[ "$base" == "$ext" ]] && ext=""

  case "$base" in
    Dockerfile|Dockerfile.*|Containerfile|Containerfile.*) echo "dockerfile"; return ;;
    Makefile|makefile|GNUmakefile) echo "makefile"; return ;;
  esac

  case "$ext" in
    py|pyw|pyi) echo "python" ;;
    js|mjs|cjs|jsx) echo "javascript" ;;
    ts|tsx|mts|cts) echo "typescript" ;;
    rs) echo "rust" ;;
    go) echo "go" ;;
    java) echo "java" ;;
    c) echo "c" ;;
    h|cpp|cc|cxx|hpp|hxx|hh) echo "cpp" ;;
    rb|rake|gemspec) echo "ruby" ;;
    lua) echo "lua" ;;
    php) echo "php" ;;
    sh|bash|zsh) echo "bash" ;;
    yml|yaml) echo "yaml" ;;
    md|markdown) echo "markdown" ;;
    json) echo "json" ;;
    toml) echo "toml" ;;
    xml) echo "xml" ;;
    html|htm) echo "html" ;;
    css|scss|sass|less) echo "css" ;;
    sql) echo "sql" ;;
    swift) echo "swift" ;;
    kt|kts) echo "kotlin" ;;
    scala) echo "scala" ;;
    pl|pm) echo "perl" ;;
    ex|exs) echo "elixir" ;;
    erl|hrl) echo "erlang" ;;
    hs) echo "haskell" ;;
    ml|mli) echo "ocaml" ;;
    txt|text|log) echo "text" ;;
    cfg|conf|ini|env) echo "config" ;;
    csv|tsv) echo "data" ;;
    *) echo "unknown" ;;
  esac
}

is_binary_extension() {
  local base lower
  base="$(basename "$1")"
  lower="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]')"

  # Common packed/minified assets first
  if [[ "$lower" == *.min.js ]] || [[ "$lower" == *.min.css ]] || [[ "$lower" == *.map ]]; then
    return 0
  fi

  [[ "$lower" =~ \.${_BINARY_EXT_RE} ]]
}

is_binary_file() {
  local f="$1"
  is_binary_extension "$f" && return 0

  if [[ -f "$f" ]] && [[ -r "$f" ]]; then
    # Portable NUL-byte sniff in first 8KB.
    if od -An -tx1 -N 8192 "$f" 2>/dev/null | grep -Eq '(^|[[:space:]])00([[:space:]]|$)'; then
      return 0
    fi
  fi
  return 1
}

normalize_diff_path() {
  local raw="$1"
  raw="${raw%%$'\t'*}"
  raw="${raw#\"}"
  raw="${raw%\"}"
  [[ "$raw" == "/dev/null" ]] && { echo "__DEV_NULL__"; return; }
  raw="${raw#a/}"
  raw="${raw#b/}"
  echo "$raw"
}

shell_quote() {
  printf '%q' "$1"
}

mark_truncated() {
  local reason="$1"
  if [[ "$TRUNCATED" != "true" ]]; then
    TRUNCATED=true
    TRUNCATION_REASON="$reason"
  fi
}

check_budget_preadd() {
  local add_lines="${1:-0}"
  local add_bytes="${2:-0}"
  local projected_lines=$((TOTAL_LINES_READ + add_lines))
  local projected_bytes=$((TOTAL_BYTES_READ + add_bytes))

  if (( TOKEN_BUDGET > 0 )); then
    local projected_tokens
    projected_tokens=$(token_estimate_from_bytes "$projected_bytes")
    if (( projected_tokens > TOKEN_BUDGET )); then
      mark_truncated "token_budget"
      return 1
    fi
  fi

  if (( MAX_BYTES > 0 )) && (( projected_bytes > MAX_BYTES )); then
    mark_truncated "max_bytes"
    return 1
  fi

  if (( MAX_LINES > 0 )) && (( projected_lines > MAX_LINES )); then
    mark_truncated "max_lines"
    return 1
  fi

  return 0
}

mark_file_read() {
  local path="$1"
  local i
  for (( i=0; i<READ_FILE_COUNT; i++ )); do
    if [[ "${READ_FILE_PATHS[$i]}" == "$path" ]]; then
      return 0
    fi
  done
  READ_FILE_PATHS[$READ_FILE_COUNT]="$path"
  READ_FILE_COUNT=$((READ_FILE_COUNT + 1))
  TOTAL_FILES_READ=$((TOTAL_FILES_READ + 1))
}

find_file_summary_index() {
  local path="$1"
  local i
  for (( i=0; i<FILE_COUNT; i++ )); do
    if [[ "${FILE_PATHS[$i]}" == "$path" ]]; then
      printf '%s' "$i"
      return 0
    fi
  done
  printf '%s' "-1"
  return 0
}

upsert_file_summary() {
  local path="$1" lang="$2" binary_state="$3" size="$4" total_lines="$5" status="$6"
  local idx
  idx="$(find_file_summary_index "$path")"
  if (( idx < 0 )); then
    idx="$FILE_COUNT"
    FILE_COUNT=$((FILE_COUNT + 1))
  fi
  FILE_PATHS[$idx]="$path"
  FILE_LANGS[$idx]="$lang"
  FILE_BINARY_STATE[$idx]="$binary_state"
  FILE_SIZES[$idx]="$size"
  FILE_TOTALLINES[$idx]="$total_lines"
  FILE_STATUSES[$idx]="$status"
}

add_warning() {
  WARN_MSGS[$WARN_COUNT]="$1"
  WARN_COUNT=$((WARN_COUNT + 1))
}

add_error() {
  local path="$1" code="$2" detail="$3"
  ERR_PATHS[$ERR_COUNT]="$path"
  ERR_CODES[$ERR_COUNT]="$code"
  ERR_DETAILS[$ERR_COUNT]="$detail"
  ERR_COUNT=$((ERR_COUNT + 1))
