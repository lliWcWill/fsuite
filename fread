#!/usr/bin/env bash
# fread — budgeted file reading with line numbers, token estimates, and pipeline integration.
# Part of fsuite. Reads files intelligently so agents don't waste context.

set -euo pipefail

VERSION="3.3.0"

# -------------------------
# Source common library for tiered telemetry
# -------------------------
_FSUITE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
_FSUITE_PARENT_DIR="$(cd "$_FSUITE_SCRIPT_DIR/.." 2>/dev/null && pwd || true)"
_FSUITE_LIB_CANDIDATES=()
[[ -n "${FSUITE_SHARE_DIR:-}" ]] && _FSUITE_LIB_CANDIDATES+=("${FSUITE_SHARE_DIR%/}/_fsuite_common.sh")
_FSUITE_LIB_CANDIDATES+=(
  "$_FSUITE_SCRIPT_DIR/_fsuite_common.sh"
  "$_FSUITE_PARENT_DIR/share/fsuite/_fsuite_common.sh"
  "/usr/local/share/fsuite/_fsuite_common.sh"
  "/usr/share/fsuite/_fsuite_common.sh"
)
for _fsuite_candidate in "${_FSUITE_LIB_CANDIDATES[@]}"; do
  if [[ -f "$_fsuite_candidate" ]]; then
    # shellcheck disable=SC1090
    source "$_fsuite_candidate"
    break
  fi
done
unset _fsuite_candidate


# ── Locate media engine ──────────────────────────────────────────
ENGINE_MEDIA=""
_em_candidates=(
    "${_FSUITE_SCRIPT_DIR}/fread-media.py"
    "${FSUITE_SHARE_DIR:-/nonexistent}/fread-media.py"
    "${_FSUITE_SCRIPT_DIR}/../share/fsuite/fread-media.py"
    "/usr/local/share/fsuite/fread-media.py"
    "/usr/share/fsuite/fread-media.py"
)
for _em_c in "${_em_candidates[@]}"; do
    if [[ -f "$_em_c" ]]; then
        ENGINE_MEDIA="$_em_c"
        break
    fi
done
unset _em_c _em_candidates
# ENGINE_MEDIA is empty string when not found — media_dispatch degrades gracefully

# -------------------------
# Telemetry — opt-out via FSUITE_TELEMETRY=0
# -------------------------
now_ms() {
  local ms=""
  ms=$(date +%s%3N 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then
    printf '%s' "$ms"
    return 0
  fi

  ms=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time() * 1000' 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then
    printf '%s' "$ms"
    return 0
  fi

  ms=$(date +%s 2>/dev/null || true)
  if [[ "$ms" =~ ^[0-9]+$ ]]; then
    printf '%s' "$(( ms * 1000 ))"
    return 0
  fi

  printf '0'
}

_FSUITE_TELEM="${FSUITE_TELEMETRY:-1}"
[[ "$_FSUITE_TELEM" =~ ^[0-9]+$ ]] || _FSUITE_TELEM=1
_TELEM_START_MS=$(now_ms)
_TELEM_EXIT_CODE=0
_TELEM_FLAGS=""
_TELEM_PROJECT_NAME=""
_TELEM_PATH_HINT=""

# -------------------------
