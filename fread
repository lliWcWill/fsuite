add_symbol_candidate() {
  local path="$1" symbol="$2" sym_type="$3" start="$4" end="$5"
  CANDIDATE_PATHS[$CANDIDATE_COUNT]="$path"
  CANDIDATE_SYMBOLS[$CANDIDATE_COUNT]="$symbol"
  CANDIDATE_TYPES[$CANDIDATE_COUNT]="$sym_type"
  CANDIDATE_STARTS[$CANDIDATE_COUNT]="$start"
  CANDIDATE_ENDS[$CANDIDATE_COUNT]="$end"
  CANDIDATE_COUNT=$((CANDIDATE_COUNT + 1))
}

derive_symbol_end_from_file() {
  local file_path="$1" start_line="$2" sym_type="$3" fmap_bin="$4"
  local fmap_json result

  fmap_json="$(mktemp)"
  if ! FSUITE_TELEMETRY=0 "$fmap_bin" -o json "$file_path" > "$fmap_json"; then
    rm -f "$fmap_json"
    printf '0'
    return 0
  fi

  result="$(perl -MJSON::PP -e '
    use strict;
    use warnings;

    my ($json_path, $start, $sym_type) = @ARGV;
    open my $fh, q{<:raw}, $json_path or exit 90;
    local $/;
    my $data = JSON::PP::decode_json(<$fh>);
    my $file = $data->{files}[0];
    exit 20 unless $file && ref($file->{symbols}) eq q{ARRAY};
    my @symbols = @{ $file->{symbols} };
    my $idx = -1;
    for my $i (0 .. $#symbols) {
      my $sym = $symbols[$i];
      next unless ($sym->{line} // 0) == $start;
      next unless ($sym->{type} // q{}) eq $sym_type;
      $idx = $i;
      last;
    }
    exit 21 if $idx < 0;
    my $indent = $symbols[$idx]{indent} // 0;
    for my $i ($idx + 1 .. $#symbols) {
      my $next = $symbols[$i];
      next unless ($next->{line} // 0) > $start;
      if (($next->{indent} // 0) <= $indent) {
        print (($next->{line} // 0) - 1);
        exit 0;
      }
    }
    print 0;
  ' "$fmap_json" "$start_line" "$sym_type" 2>/dev/null || true)"

  rm -f "$fmap_json"
  [[ "$result" =~ ^[0-9]+$ ]] || result=0
  printf '%s' "$result"
}

resolve_symbol_request() {
  local target="$1"
  local scope_abs fmap_bin fmap_json result rc resolved_path resolved_start resolved_end resolved_symbol resolved_type total_lines

  scope_abs="$(normalize_abs_path "$target")"

  if [[ ! -e "$scope_abs" ]]; then
    add_error "$scope_abs" "not_found" "file does not exist"
    return 1
  fi
  if [[ ! -r "$scope_abs" ]]; then
    add_error "$scope_abs" "permission" "permission denied"
    return 1
  fi
  if [[ ! -f "$scope_abs" ]] && [[ ! -d "$scope_abs" ]]; then
    add_error "$scope_abs" "not_regular" "not a regular file or directory"
    return 1
  fi

  fmap_bin="${_FSUITE_SCRIPT_DIR}/fmap"
  [[ -x "$fmap_bin" ]] || fmap_bin="$(command -v fmap 2>/dev/null || true)"
  if [[ -z "$fmap_bin" ]]; then
    add_error "$scope_abs" "symbol_lookup_failed" "fmap is required for --symbol but was not found"
    return 1
  fi

  fmap_json="$(mktemp)"
  if ! FSUITE_TELEMETRY=0 "$fmap_bin" -o json --name "$SYMBOL_NAME" "$scope_abs" > "$fmap_json"; then
    rm -f "$fmap_json"
    add_error "$scope_abs" "symbol_lookup_failed" "fmap symbol lookup failed"
    return 1
  fi

  result="$(perl -MJSON::PP -e '
    use strict;
    use warnings;

    sub derive_end_line {
      my ($file, $start, $sym_type) = @_;
      return 0 unless $file && ref($file->{symbols}) eq q{ARRAY};
      my @symbols = @{ $file->{symbols} };
      my $idx = -1;
      for my $i (0 .. $#symbols) {
        my $sym = $symbols[$i];
        next unless ($sym->{line} // 0) == $start;
        next unless ($sym->{type} // q{}) eq $sym_type;
        $idx = $i;
        last;
      }
      return 0 if $idx < 0;
      my $indent = $symbols[$idx]{indent} // 0;
      for my $i ($idx + 1 .. $#symbols) {
        my $next = $symbols[$i];
        next unless ($next->{line} // 0) > $start;
        if (($next->{indent} // 0) <= $indent) {
          return ($next->{line} // 0) - 1;
        }
      }
      return 0;
    }

    my ($json_path, $query) = @ARGV;
    open my $fh, q{<:raw}, $json_path or exit 90;
    local $/;
    my $json = <$fh>;
    my $data = JSON::PP::decode_json($json);
    my @matches = @{ $data->{matches} || [] };
    my @exact = grep { defined($_->{symbol}) && $_->{symbol} eq $query } @matches;
    my @files = @{ $data->{files} || [] };
    my %files_by_path = map { (($_->{path} // q{}) => $_) } @files;

    if (!@exact) {
      exit 20;
    }

    if (@exact > 1) {
      for my $cand (@exact) {
        my $path = $cand->{path} // q{};
        my $start = $cand->{line_start} // 0;
        my $sym_type = $cand->{symbol_type} // q{};
        my $end = defined $cand->{line_end} ? ($cand->{line_end} // 0) : 0;
        if (!$end && exists $files_by_path{$path}) {
          $end = derive_end_line($files_by_path{$path}, $start, $sym_type);
        }
        print join(qq{\t},
          $path,
          ($cand->{symbol} // q{}),
          $sym_type,
          $start,
          ($end || 0)
        ), qq{\n};
      }
      exit 21;
    }

    my $cand = $exact[0];
    my $path = $cand->{path} // q{};
    my $start = $cand->{line_start} // 0;
    my $sym_type = $cand->{symbol_type} // q{};
    my $end = defined $cand->{line_end} ? ($cand->{line_end} // 0) : 0;
    if (!$end && exists $files_by_path{$path}) {
      $end = derive_end_line($files_by_path{$path}, $start, $sym_type);
    }
    print join(qq{\t},
      $path,
      ($cand->{symbol} // q{}),
      $sym_type,
      $start,
      ($end || 0)
    );
  ' "$fmap_json" "$SYMBOL_NAME" 2>/dev/null)" || rc=$?

  rm -f "$fmap_json"
  rc="${rc:-0}"

  case "$rc" in
    0)
      IFS=$'\t' read -r resolved_path resolved_symbol resolved_type resolved_start resolved_end <<< "$result"
      [[ "$resolved_start" =~ ^[0-9]+$ ]] || resolved_start=0
      [[ "$resolved_end" =~ ^[0-9]+$ ]] || resolved_end=0
      if (( resolved_end <= 0 )); then
        resolved_end="$(derive_symbol_end_from_file "$resolved_path" "$resolved_start" "$resolved_type" "$fmap_bin")"
      fi
      if (( resolved_end <= 0 )); then
        total_lines="$(count_file_lines "$resolved_path" 2>/dev/null || echo 0)"
        [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
        resolved_end="$total_lines"
      fi
      set_symbol_resolution "$resolved_path" "$resolved_symbol" "$resolved_type" "$resolved_start" "$resolved_end"
      printf '%s\t%s\t%s\n' "$resolved_path" "$resolved_start" "$resolved_end"
      return 0
      ;;
    20)
      add_error "$scope_abs" "symbol_not_found" "symbol '$SYMBOL_NAME' not found in scope"
      return 1
      ;;
    21)
      while IFS=$'\t' read -r resolved_path resolved_symbol resolved_type resolved_start resolved_end; do
        [[ -n "$resolved_path" ]] || continue
        [[ "$resolved_end" =~ ^[0-9]+$ ]] || resolved_end=0
        if (( resolved_end <= 0 )); then
          resolved_end="$(derive_symbol_end_from_file "$resolved_path" "$resolved_start" "$resolved_type" "$fmap_bin")"
        fi
        if (( resolved_end <= 0 )); then
          total_lines="$(count_file_lines "$resolved_path" 2>/dev/null || echo 0)"
          [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
          resolved_end="$total_lines"
        fi
        add_symbol_candidate "$resolved_path" "$resolved_symbol" "$resolved_type" "$resolved_start" "$resolved_end"
      done <<< "$result"
      add_error "$scope_abs" "symbol_ambiguous" "symbol '$SYMBOL_NAME' matched multiple exact symbols"
      return 1
      ;;
    *)
      add_error "$scope_abs" "symbol_lookup_failed" "failed to resolve symbol '$SYMBOL_NAME'"
      return 1
      ;;
  esac
}

read_range_chunk() {
  local file="$1" start="$2" end="$3"

  _RR_CONTENT=""
  _RR_BYTES=0
  _RR_LINES=0
  _RR_END_LINE=$((start - 1))

  (( start > end )) && return 0

  local rec line_no line display_line line_bytes
  while IFS= read -r rec || [[ -n "$rec" ]]; do
    [[ -z "$rec" ]] && continue
    line_no="${rec%%$'\x1f'*}"
    line="${rec#*$'\x1f'}"

    if (( ${#line} > 2000 )); then
      line="${line:0:2000} [truncated_line]"
    fi

    display_line="${line_no}  ${line}"
    line_bytes=$(byte_len "${display_line}"$'\n')

    if ! check_budget_preadd "$((_RR_LINES + 1))" "$((_RR_BYTES + line_bytes))"; then
      break
    fi

    _RR_CONTENT+="${display_line}"$'\n'
    _RR_BYTES=$((_RR_BYTES + line_bytes))
    _RR_LINES=$((_RR_LINES + 1))
    _RR_END_LINE="$line_no"
  done < <(awk -v s="$start" -v e="$end" 'NR>=s && NR<=e { printf "%d\037%s\n", NR, $0 }' "$file" 2>/dev/null)

  if (( _RR_LINES > 0 )); then
    _RR_CONTENT="${_RR_CONTENT%$'\n'}"
  fi
}

# ── media_dispatch ───────────────────────────────────────────────
# Called inside process_single_file when a binary file is detected.
# Returns 0 if the file was handled (image/pdf), 1 to fall through
# to the normal binary-skip path.
media_dispatch() {
    local path="$1"

    # No engine — degrade silently (warn once)
    if [[ -z "$ENGINE_MEDIA" ]]; then
        if (( _MEDIA_ENGINE_WARNED == 0 )); then
            echo "fread: warning: fread-media.py not found; media files will be skipped" >&2
            _MEDIA_ENGINE_WARNED=1
        fi
        return 1
    fi

    # ── Probe ────────────────────────────────────────────────────
    local probe_json detected
    probe_json="$(python3 "$ENGINE_MEDIA" probe "$path" 2>/dev/null)" || probe_json="{}"
    detected="$(printf '%s' "$probe_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('detected','unknown'))" 2>/dev/null || echo "unknown")"

    if [[ "$detected" == "unknown" ]]; then
        return 1
    fi

    # ── Build engine args ─────────────────────────────────────────
    local engine_args=()
    local subcmd=""

    if [[ "$detected" == "image" ]]; then
        subcmd="image"
        (( MEDIA_META_ONLY ))  && engine_args+=("--meta-only")
        (( MEDIA_NO_RESIZE ))  && engine_args+=("--no-resize")
        if [[ -n "$MEDIA_MAX_TOKENS" ]]; then
            engine_args+=("--max-tokens" "$MEDIA_MAX_TOKENS")
        elif (( NO_TRUNCATE == 1 )); then
            engine_args+=("--max-tokens" "0")
        elif (( TOKEN_BUDGET_EXPLICIT == 1 )); then
            engine_args+=("--max-tokens" "$TOKEN_BUDGET")
        fi
    elif [[ "$detected" == "pdf" ]]; then
        subcmd="pdf"
        (( MEDIA_META_ONLY ))  && engine_args+=("--meta-only")
        (( MEDIA_RENDER ))     && engine_args+=("--render")
        [[ -n "$MEDIA_PAGES" ]] && engine_args+=("--pages" "$MEDIA_PAGES")
        [[ -n "$MEDIA_MAX_PAGES" ]] && engine_args+=("--max-pages" "$MEDIA_MAX_PAGES")
        if [[ -n "$MEDIA_TOKEN_BUDGET_ENGINE" ]]; then
            engine_args+=("--token-budget" "$MEDIA_TOKEN_BUDGET_ENGINE")
        elif (( NO_TRUNCATE == 1 )); then
            engine_args+=("--token-budget" "0")
        elif (( TOKEN_BUDGET_EXPLICIT == 1 )); then
            engine_args+=("--token-budget" "$TOKEN_BUDGET")
        fi
    else
        return 1
    fi

    # ── Run engine ────────────────────────────────────────────────
    local engine_json engine_exit=0
engine_json="$(python3 "$ENGINE_MEDIA" "$subcmd" "$path" ${engine_args[@]+"${engine_args[@]}"} 2>/dev/null)" || engine_exit=$?

if [[ -z "$engine_json" ]]; then
add_warning "media engine returned empty output for: $path"
return 1
fi

    # ── Parse type and detect errors ─────────────────────────────
    local media_type
    media_type="$(printf '%s' "$engine_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('type','error'))" 2>/dev/null || echo "error")"

    if [[ "$media_type" == "error" ]] || (( engine_exit != 0 )); then
        local err_code err_msg
        err_code="$(printf '%s' "$engine_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('code','INTERNAL_ERROR'))" 2>/dev/null || echo "INTERNAL_ERROR")"
        err_msg="$(printf '%s' "$engine_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','unknown error'))" 2>/dev/null || echo "unknown error")"
        add_error "$path" "$err_code" "$err_msg"
        # Mirror the contract used by other failure paths (not_found, not_regular, etc.):
        # populate files[].status so downstream callers can correlate errors[] with paths.
        upsert_file_summary "$path" "$detected" "true" "0" "" "media_error"
        return 0
    fi

    # ── Format output ─────────────────────────────────────────────
    local size_bytes
    size_bytes="$(file_bytes "$path" 2>/dev/null || echo 0)"
    size_bytes="${size_bytes//[[:space:]]/}"
    [[ "$size_bytes" =~ ^[0-9]+$ ]] || size_bytes=0
    if [[ "$OUTPUT" == "paths" ]]; then
        # Paths mode: machine-readable, one path per line. Skip both pretty
        # summary and JSON envelope; render_paths() will emit the path itself.
        :
    elif [[ "$OUTPUT" == "json" ]]; then
        # In JSON mode: surface the engine JSON at the top level via
        # MEDIA_PAYLOAD_JSON (singular, last payload — Phase 3 MCP single-file
        # path) and MEDIA_PAYLOADS_JSON (array, multi-file batch path).
        local chunk_content="$engine_json"
        local chunk_bytes
        chunk_bytes="$(byte_len "$chunk_content")"
        # Honor --max-bytes / --max-lines for media chunks (NOT --token-budget,
        # which the engine already enforces internally for PDF text/render).
        local _media_truncated=0
        if (( MAX_BYTES > 0 )) && (( TOTAL_BYTES_READ + chunk_bytes > MAX_BYTES )); then
            mark_truncated "max_bytes"
            _media_truncated=1
        elif (( MAX_LINES > 0 )) && (( TOTAL_LINES_READ + 1 > MAX_LINES )); then
            mark_truncated "max_lines"
            _media_truncated=1
        fi
        if (( _media_truncated == 1 )); then
            # Budget blocked — record skip status, no chunk emitted, no ingest.
            upsert_file_summary "$path" "$detected" "true" "$size_bytes" "" "budget_skipped"
            return 0
        fi
        MEDIA_PAYLOAD_JSON="$engine_json"
        MEDIA_PAYLOADS_JSON+=("$engine_json")
        add_chunk "$path" 0 0 "" "$chunk_content" "$chunk_bytes" 1
        TOTAL_BYTES_READ=$((TOTAL_BYTES_READ + chunk_bytes))
        TOTAL_LINES_READ=$((TOTAL_LINES_READ + 1))
    else
        # ── Pretty mode ───────────────────────────────────────────
        case "$media_type" in
        image-meta)
            local fmt dims w h orig_sz mtime tok_est
            fmt="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('format','?').upper())" 2>/dev/null || echo "?")"
            w="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('dimensions',{}).get('width','?'))" 2>/dev/null || echo "?")"
            h="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('dimensions',{}).get('height','?'))" 2>/dev/null || echo "?")"
            orig_sz="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('original_size','?'))" 2>/dev/null || echo "?")"
            tok_est="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('tokens_estimate','?'))" 2>/dev/null || echo "?")"
            emit_media_pretty_budgeted_text "📷 ${fmt} ${w}×${h} — ${orig_sz} bytes (~${tok_est} tokens)" || true
            ;;
        image)
            local fmt w h orig_sz tok_est
            fmt="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('format','?').upper())" 2>/dev/null || echo "?")"
            w="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('dimensions',{}).get('width','?'))" 2>/dev/null || echo "?")"
            h="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('dimensions',{}).get('height','?'))" 2>/dev/null || echo "?")"
            orig_sz="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('original_size','?'))" 2>/dev/null || echo "?")"
            tok_est="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('tokens_estimate','?'))" 2>/dev/null || echo "?")"
            emit_media_pretty_budgeted_text "📷 ${fmt} ${w}×${h} — ${orig_sz} bytes (~${tok_est} tokens) [base64 suppressed in pretty mode; use -o json]" || true
            ;;
            pdf-text)
                local pg_count tok_est text_body
                pg_count="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('page_count','?'))" 2>/dev/null || echo "?")"
                tok_est="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('tokens_estimate','?'))" 2>/dev/null || echo "?")"
                text_body="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('text',''))" 2>/dev/null || echo "")"
                echo "--- file: $path ($pg_count pages, $tok_est tokens) ---"
                if [[ -n "$text_body" ]]; then
                    local _media_pretty_truncated=0
                    emit_media_pretty_budgeted_text "$text_body" || _media_pretty_truncated=1
                    (( _media_pretty_truncated )) && echo "... [truncated; raise --max-lines/--max-bytes for full body]"
                fi
                ;;
        pdf-meta)
            local pg_count enc has_text img_count pw ph
            pg_count="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('page_count','?'))" 2>/dev/null || echo "?")"
            enc="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('encrypted','?'))" 2>/dev/null || echo "?")"
            has_text="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('has_text','?'))" 2>/dev/null || echo "?")"
            img_count="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; print(d.get('embedded_image_count','?'))" 2>/dev/null || echo "?")"
            pw="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; ps=d.get('page_size',{}); print(ps.get('width','?'))" 2>/dev/null || echo "?")"
            ph="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin)['file']; ps=d.get('page_size',{}); print(ps.get('height','?'))" 2>/dev/null || echo "?")"
            emit_media_pretty_budgeted_text "📄 PDF — $pg_count pages (${pw}×${ph}), encrypted: $enc, has_text: $has_text, $img_count embedded images" || true
            ;;
        pdf-pages)
            emit_media_pretty_budgeted_text "📄 PDF rendered pages — JSON mode required to receive base64. Use -o json." || true
            ;;
        *)
            echo "fread: media type '$media_type': $path" >&2
            ;;
        esac
    fi

    upsert_file_summary "$path" "$detected" "true" "$size_bytes" "" "read"
    mark_file_read "$path"

    # ── Post-call memory ingest (best-effort, detached) ───────────
    _media_maybe_ingest "$path" "$engine_json"

    return 0
}

# ── _media_maybe_ingest ──────────────────────────────────────────
# Detached best-effort spawn of the memory-ingest helper.
# Never blocks the caller. Logs to ~/.cache/fsuite/memory-ingest.log.
_media_maybe_ingest() {
    local path="$1" engine_json="$2"

    # Skip if opted out
    (( MEDIA_NO_INGEST )) && return 0
    [[ "${FSUITE_MEMORY_INGEST:-1}" == "0" ]] && return 0

    # Skip if no ingest_payload in output
    local has_payload
    has_payload="$(printf '%s' "$engine_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print('yes' if 'ingest_payload' in d else 'no')" 2>/dev/null || echo "no")"
    [[ "$has_payload" == "yes" ]] || return 0

    # Ensure log dir exists
    mkdir -p "$HOME/.cache/fsuite" 2>/dev/null || return 0

    local ingest_helper=""
    local _candidates=(
        "${_FSUITE_SCRIPT_DIR}/mcp/memory-ingest.js"
        "${FSUITE_SHARE_DIR:-/nonexistent}/mcp/memory-ingest.js"
        "/usr/local/share/fsuite/mcp/memory-ingest.js"
        "/usr/share/fsuite/mcp/memory-ingest.js"
        "${FSUITE_SHARE_DIR:-/nonexistent}/memory-ingest.js"
        "/usr/local/share/fsuite/memory-ingest.js"
        "/usr/share/fsuite/memory-ingest.js"
    )
for _c in "${_candidates[@]}"; do
  [[ -f "$_c" ]] && { ingest_helper="$_c"; break; }
done
local payload_file
payload_file="$(mktemp 2>/dev/null)" || return 0

# Write ingest_payload to temp file
# NOTE: Python code below must remain consistent with its own indentation —
# Python parses the string content; the bash indentation of printf/python3
# wrapping lines is independent.
printf '%s' "$engine_json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
ip = d.get('ingest_payload')
if ip is not None:
    print(json.dumps(ip))
" > "$payload_file" 2>/dev/null || { rm -f "$payload_file"; return 0; }

if [[ -z "$ingest_helper" ]]; then
echo "$(date -Iseconds) [memory-ingest] helper not found (checked dev-tree, FSUITE_SHARE_DIR, /usr/local/share/fsuite, /usr/share/fsuite)" >> "$HOME/.cache/fsuite/memory-ingest.log" 2>/dev/null || true
rm -f "$payload_file"
return 0
fi

    # Spawn detached — never blocks fread exit. If setsid is unavailable,
    # still launch the helper so the child can clean up the payload file.
    if command -v setsid >/dev/null 2>&1; then
        setsid bash -c 'node "$0" < "$1" >>"$HOME/.cache/fsuite/memory-ingest.log" 2>&1; status=$?; if (( status != 0 )); then echo "$(date -Iseconds) [memory-ingest] helper exit code $status" >>"$HOME/.cache/fsuite/memory-ingest.log"; fi; rm -f "$1"' \
            "$ingest_helper" "$payload_file" </dev/null >/dev/null 2>&1 &
    else
        echo "$(date -Iseconds) [memory-ingest] setsid not found; launching helper without new session" >> "$HOME/.cache/fsuite/memory-ingest.log" 2>/dev/null || true
        bash -c 'node "$0" < "$1" >>"$HOME/.cache/fsuite/memory-ingest.log" 2>&1; status=$?; if (( status != 0 )); then echo "$(date -Iseconds) [memory-ingest] helper exit code $status" >>"$HOME/.cache/fsuite/memory-ingest.log"; fi; rm -f "$1"' \
            "$ingest_helper" "$payload_file" </dev/null >/dev/null 2>&1 &
    fi

    return 0
}

process_single_file() {
  local file="$1"
  local start="${2:-1}"
  local end="${3:-}"
  local match_line="${4:-}"
  local total_lines_hint="${5:-}"
  local abs_path lang size_bytes total_lines
  local binary_state="unknown"

  abs_path="$(normalize_abs_path "$file")"
  [[ -z "$_TELEM_PATH_HINT" ]] && _TELEM_PATH_HINT="$abs_path"

  if [[ ! -e "$abs_path" ]]; then
    add_error "$abs_path" "not_found" "file does not exist"
    upsert_file_summary "$abs_path" "unknown" "unknown" "0" "" "not_found"
    return 0
  fi
  if [[ ! -f "$abs_path" ]]; then
    add_error "$abs_path" "not_regular" "not a regular file"
    upsert_file_summary "$abs_path" "unknown" "unknown" "0" "" "not_regular"
    return 0
  fi
  if [[ ! -r "$abs_path" ]]; then
    add_error "$abs_path" "permission" "permission denied"
    upsert_file_summary "$abs_path" "unknown" "unknown" "0" "" "skipped_permission"
    return 0
  fi

  lang="$(detect_language "$abs_path")"
  size_bytes="$(file_bytes "$abs_path" 2>/dev/null || echo 0)"
  size_bytes="${size_bytes//[[:space:]]/}"
  [[ "$size_bytes" =~ ^[0-9]+$ ]] || size_bytes=0

if (( FORCE_TEXT == 0 )) && is_binary_file "$abs_path"; then
    # Try media dispatch first (image/pdf engine)
    if media_dispatch "$abs_path"; then
        return 0  # media path handled it
    fi
    # Fall through to binary skip
    binary_state="true"
    upsert_file_summary "$abs_path" "$lang" "$binary_state" "$size_bytes" "" "skipped_binary"
    add_warning "binary file skipped: $abs_path"
    return 0
fi
  binary_state="false"

  if [[ -n "$total_lines_hint" ]] && [[ "$total_lines_hint" =~ ^[0-9]+$ ]]; then
    total_lines="$total_lines_hint"
  else
    total_lines="$(count_file_lines "$abs_path" 2>/dev/null || echo 0)"
    [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  fi

  [[ -z "$end" ]] && end="$total_lines"
  (( start < 1 )) && start=1
  (( end > total_lines )) && end="$total_lines"

  if (( start > end )) || (( total_lines == 0 )); then
    upsert_file_summary "$abs_path" "$lang" "$binary_state" "$size_bytes" "$total_lines" "read_empty"
    return 0
  fi

  local before_chunks="$CHUNK_COUNT"
  read_range_chunk "$abs_path" "$start" "$end"

  if (( _RR_LINES > 0 )); then
    add_chunk "$abs_path" "$start" "$_RR_END_LINE" "$match_line" "$_RR_CONTENT" "$_RR_BYTES" "$_RR_LINES"
    TOTAL_LINES_READ=$((TOTAL_LINES_READ + _RR_LINES))
    TOTAL_BYTES_READ=$((TOTAL_BYTES_READ + _RR_BYTES))
    mark_file_read "$abs_path"
    upsert_file_summary "$abs_path" "$lang" "$binary_state" "$size_bytes" "$total_lines" "read"
  else
    if [[ "$TRUNCATED" == "true" ]]; then
      upsert_file_summary "$abs_path" "$lang" "$binary_state" "$size_bytes" "$total_lines" "budget_skipped"
    else
      upsert_file_summary "$abs_path" "$lang" "$binary_state" "$size_bytes" "$total_lines" "read_empty"
    fi
  fi

  # If no chunk was added and truncation is set, this file was blocked by budget.
  if (( CHUNK_COUNT == before_chunks )) && [[ "$TRUNCATED" == "true" ]]; then
    :
  fi
}

process_around_line() {
  local file="$1" center="$2" before="$3" after="$4"
  local abs_path total_lines start end
  abs_path="$(normalize_abs_path "$file")"
  total_lines="$(count_file_lines "$abs_path" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0

  start=$((center - before))
  end=$((center + after))
  (( start < 1 )) && start=1
  (( end > total_lines )) && end="$total_lines"
  process_single_file "$abs_path" "$start" "$end" "$center" "$total_lines"
}

process_around_pattern() {
  local file="$1" pattern="$2" before="$3" after="$4" all_matches="$5"
  local abs_path total_lines found=0
  abs_path="$(normalize_abs_path "$file")"

  if [[ ! -f "$abs_path" ]] || [[ ! -r "$abs_path" ]]; then
    process_single_file "$abs_path"
    return 0
  fi

  total_lines="$(count_file_lines "$abs_path" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0

  local mline start end
  while IFS= read -r mline || [[ -n "$mline" ]]; do
    [[ -z "$mline" ]] && continue
    [[ "$mline" =~ ^[0-9]+$ ]] || continue
    found=1

    start=$((mline - before))
    end=$((mline + after))
    (( start < 1 )) && start=1
    (( end > total_lines )) && end="$total_lines"

    process_single_file "$abs_path" "$start" "$end" "$mline" "$total_lines"
    [[ "$TRUNCATED" == "true" ]] && break
    (( all_matches == 0 )) && break
  done < <(grep -nF -- "$pattern" "$abs_path" 2>/dev/null | cut -d: -f1 || true)

  if (( found == 0 )); then
    add_error "$abs_path" "pattern_not_found" "pattern '$pattern' not found"
    local _fb
    _fb=$(file_bytes "$abs_path")
    _fb="${_fb//[^0-9]/}"
    [[ "$_fb" =~ ^[0-9]+$ ]] || _fb=0
    upsert_file_summary "$abs_path" "$(detect_language "$abs_path")" "false" "$_fb" "$total_lines" "pattern_not_found"
  fi
}

process_stdin_paths() {
  local max_files="$1"
  local p count=0

  while IFS= read -r p || [[ -n "$p" ]]; do
    [[ -z "$p" ]] && continue
    count=$((count + 1))

    if (( count > max_files )); then
      mark_truncated "max_files"
      add_warning "stdin path limit reached: max_files=$max_files"
      break
    fi

    process_single_file "$p"
    [[ "$TRUNCATED" == "true" ]] && break
  done

  if (( count == 0 )); then
    die "No file paths received on stdin."
  fi
}

process_stdin_unified_diff() {
  local before="$1" after="$2"
  local line raw_path current_file="" current_file_has_hunks=0
  local any_hunks=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^diff[[:space:]]--git[[:space:]] ]]; then
      if [[ -n "$current_file" ]] && (( current_file_has_hunks == 0 )); then
        add_warning "diff file has no hunks (skipped): $current_file"
      fi
      current_file=""
      current_file_has_hunks=0
      continue
    fi

    if [[ "$line" == "GIT binary patch" ]] || [[ "$line" == Binary\ files* ]]; then
      add_warning "binary patch skipped"
      current_file=""
      current_file_has_hunks=0
      continue
    fi

    if [[ "$line" =~ ^\+\+\+[[:space:]](.+)$ ]]; then
      raw_path="${BASH_REMATCH[1]}"
      current_file="$(normalize_diff_path "$raw_path")"
      current_file_has_hunks=0
      if [[ "$current_file" == "__DEV_NULL__" ]]; then
        add_warning "deleted file in diff skipped"
        current_file=""
      fi
      continue
    fi

    if [[ -n "$current_file" ]] && [[ "$line" =~ ^@@[[:space:]]-[0-9]+(,[0-9]+)?[[:space:]]\+([0-9]+)(,([0-9]+))?[[:space:]]@@ ]]; then
      local new_start new_count start end
      new_start="${BASH_REMATCH[2]}"
      new_count="${BASH_REMATCH[4]:-1}"

      start=$((new_start - before))
      end=$((new_start + new_count - 1 + after))
      (( start < 1 )) && start=1

      if [[ ! -f "$current_file" ]]; then
        add_error "$current_file" "not_found" "diff references file not present in working tree"
        continue
      fi

      process_single_file "$current_file" "$start" "$end" "$new_start"
      current_file_has_hunks=1
      any_hunks=1
      [[ "$TRUNCATED" == "true" ]] && break
    fi
  done

  if [[ -n "$current_file" ]] && (( current_file_has_hunks == 0 )); then
    add_warning "diff file has no hunks (skipped): $current_file"
  fi

  if (( any_hunks == 0 )) && (( ERR_COUNT == 0 )); then
    add_warning "no unified diff hunks found on stdin"
  fi
}

compute_next_hint() {
  [[ "$TRUNCATED" == "true" ]] || return 0
  (( CHUNK_COUNT > 0 )) || return 0

  local idx=$((CHUNK_COUNT - 1))
  local last_path="${CHUNK_PATHS[$idx]}"
  local last_end="${CHUNK_ENDS[$idx]}"
  local file_total=""
  local file_idx
  file_idx="$(find_file_summary_index "$last_path")"
  if (( file_idx >= 0 )); then
    file_total="${FILE_TOTALLINES[$file_idx]}"
  fi

  if [[ -n "$file_total" ]] && [[ "$file_total" =~ ^[0-9]+$ ]] && (( last_end < file_total )); then
    local qpath
    qpath="$(shell_quote "$last_path")"
    NEXT_HINT="fread $qpath -r $((last_end + 1)):$file_total --max-lines $MAX_LINES --max-bytes $MAX_BYTES"
    (( TOKEN_BUDGET > 0 )) && NEXT_HINT="$NEXT_HINT --token-budget $TOKEN_BUDGET"
    return 0
  fi

  case "$MODE" in
    stdin_paths)
      NEXT_HINT="fread --from-stdin --stdin-format=paths --max-files $MAX_FILES --max-lines $MAX_LINES --max-bytes $MAX_BYTES"
      (( TOKEN_BUDGET > 0 )) && NEXT_HINT="$NEXT_HINT --token-budget $TOKEN_BUDGET"
      ;;
    stdin_unified_diff)
      NEXT_HINT="git diff | fread --from-stdin --stdin-format=unified-diff -B $BEFORE -A $AFTER"
      ;;
  esac

  return 0
}

render_pretty() {
  local i path start end lines bytes content

  if [[ -n "$RESOLVED_PATH" ]] && (( QUIET == 0 )); then
    echo "# Reading $RESOLVED_PATH (1 of $MULTI_PATH_TOTAL candidates)"
  fi

  for (( i=0; i<CHUNK_COUNT; i++ )); do
    path="${CHUNK_PATHS[$i]}"
    start="${CHUNK_STARTS[$i]}"
    end="${CHUNK_ENDS[$i]}"
    lines="${CHUNK_LINES[$i]}"
    bytes="${CHUNK_BYTES[$i]}"
    content="${CHUNK_CONTENTS[$i]}"

    if (( QUIET == 0 )); then
      echo "Read($path) lines $start-$end | $lines lines | $bytes bytes | ~$(token_estimate_from_bytes "$bytes") tokens"
    fi
    [[ -n "$content" ]] && printf '%s\n' "$content"
  done

  if [[ "$TRUNCATED" == "true" ]] && (( QUIET == 0 )); then
    echo ""
    echo "  ... truncated (reason: $TRUNCATION_REASON)"
    [[ -n "$NEXT_HINT" ]] && echo "  Next: $NEXT_HINT"
  fi

  for (( i=0; i<WARN_COUNT; i++ )); do
    echo "fread: warning: ${WARN_MSGS[$i]}" >&2
  done
  for (( i=0; i<ERR_COUNT; i++ )); do
    echo "fread: ${ERR_CODES[$i]}: ${ERR_PATHS[$i]} — ${ERR_DETAILS[$i]}" >&2
  done
}

render_paths() {
  local i status
  for (( i=0; i<FILE_COUNT; i++ )); do
    status="${FILE_STATUSES[$i]}"
    if [[ "$status" == "read" ]] || [[ "$status" == "read_empty" ]]; then
      printf '%s\n' "${FILE_PATHS[$i]}"
    fi
  done
}

render_json() {
  local total_token_est i content cl first_line
  total_token_est="$(token_estimate_from_bytes "$TOTAL_BYTES_READ")"

  echo -n "{"
  echo -n "\"tool\":\"fread\","
  echo -n "\"version\":\"$VERSION\","
  echo -n "\"mode\":\"$MODE\","
  if [[ -n "$RESOLVED_PATH" ]]; then
    echo -n "\"resolved_path\":\"$(json_escape_str "$RESOLVED_PATH")\","
    echo -n "\"paths_tried\":$MULTI_PATH_TOTAL,"
  fi
  echo -n "\"truncated\":$TRUNCATED,"
  echo -n "\"truncation_reason\":\"$TRUNCATION_REASON\","
  echo -n "\"token_estimate\":$total_token_est,"
  echo -n "\"token_estimator\":\"$TOKEN_ESTIMATOR\","
  echo -n "\"bytes_emitted\":$TOTAL_BYTES_READ,"
  echo -n "\"lines_emitted\":$TOTAL_LINES_READ,"
  echo -n "\"max_lines\":$MAX_LINES,"
  echo -n "\"max_bytes\":$MAX_BYTES,"
  echo -n "\"token_budget\":$TOKEN_BUDGET,"
  if [[ -n "$NEXT_HINT" ]]; then
    echo -n "\"next_hint\":\"$(json_escape_str "$NEXT_HINT")\","
  else
    echo -n "\"next_hint\":null,"
  fi

    # Top-level media_payload — verbatim engine JSON for Phase 3 MCP integration.
    # Singular field: kept for single-file backward compat.
    # Plural field: full array, one element per media file in multi-file batches.
    if [[ -n "$MEDIA_PAYLOAD_JSON" ]]; then
        echo -n "\"media_payload\":${MEDIA_PAYLOAD_JSON},"
    fi
    if (( ${#MEDIA_PAYLOADS_JSON[@]} > 0 )); then
        echo -n "\"media_payloads\":["
        local _first=1 _p
        for _p in "${MEDIA_PAYLOADS_JSON[@]}"; do
            (( _first )) || echo -n ","
            _first=0
            echo -n "$_p"
        done
        echo -n "],"
    fi
  echo -n "\"chunks\":["
  for (( i=0; i<CHUNK_COUNT; i++ )); do
    (( i > 0 )) && echo -n ","
    echo -n "{\"path\":\"$(json_escape_str "${CHUNK_PATHS[$i]}")\","
    echo -n "\"start_line\":${CHUNK_STARTS[$i]},"
    echo -n "\"end_line\":${CHUNK_ENDS[$i]},"
    if [[ -n "${CHUNK_MATCH_LINES[$i]}" ]]; then
      echo -n "\"match_line\":${CHUNK_MATCH_LINES[$i]},"
    else
      echo -n "\"match_line\":null,"
    fi
    echo -n "\"content\":["
    first_line=1
    content="${CHUNK_CONTENTS[$i]}"
    if [[ -n "$content" ]]; then
      while IFS= read -r cl || [[ -n "$cl" ]]; do
        (( first_line )) || echo -n ","
        first_line=0
        echo -n "\"$(json_escape_str "$cl")\""
      done < <(printf '%s' "$content")
    fi
    echo -n "]}"
  done
  echo -n "],"

  echo -n "\"files\":["
  for (( i=0; i<FILE_COUNT; i++ )); do
    (( i > 0 )) && echo -n ","
    echo -n "{\"path\":\"$(json_escape_str "${FILE_PATHS[$i]}")\","
    echo -n "\"language\":\"$(json_escape_str "${FILE_LANGS[$i]}")\","
    case "${FILE_BINARY_STATE[$i]}" in
      true|false)
        echo -n "\"binary\":${FILE_BINARY_STATE[$i]},"
        ;;
      *)
        echo -n "\"binary\":null,"
        ;;
    esac
    echo -n "\"binary_state\":\"$(json_escape_str "${FILE_BINARY_STATE[$i]}")\","
    echo -n "\"file_size_bytes\":${FILE_SIZES[$i]},"
    if [[ -n "${FILE_TOTALLINES[$i]}" ]]; then
      echo -n "\"file_total_lines\":${FILE_TOTALLINES[$i]},"
    else
      echo -n "\"file_total_lines\":null,"
    fi
    echo -n "\"status\":\"$(json_escape_str "${FILE_STATUSES[$i]}")\"}"
  done
  echo -n "],"

  if [[ -n "$SYMBOL_NAME" ]]; then
    if [[ -n "$SYMBOL_RESOLUTION_PATH" ]]; then
      echo -n "\"symbol_resolution\":{"
      echo -n "\"query\":\"$(json_escape_str "$SYMBOL_NAME")\","
      echo -n "\"symbol\":\"$(json_escape_str "$SYMBOL_RESOLUTION_SYMBOL")\","
      echo -n "\"symbol_type\":\"$(json_escape_str "$SYMBOL_RESOLUTION_TYPE")\","
      echo -n "\"path\":\"$(json_escape_str "$SYMBOL_RESOLUTION_PATH")\","
      echo -n "\"line_start\":${SYMBOL_RESOLUTION_LINE_START},"
      echo -n "\"line_end\":${SYMBOL_RESOLUTION_LINE_END}"
      echo -n "},"
    else
      echo -n "\"symbol_resolution\":null,"
    fi

    echo -n "\"candidates\":["
    for (( i=0; i<CANDIDATE_COUNT; i++ )); do
      (( i > 0 )) && echo -n ","
      echo -n "{\"path\":\"$(json_escape_str "${CANDIDATE_PATHS[$i]}")\","
      echo -n "\"symbol\":\"$(json_escape_str "${CANDIDATE_SYMBOLS[$i]}")\","
      echo -n "\"symbol_type\":\"$(json_escape_str "${CANDIDATE_TYPES[$i]}")\","
      echo -n "\"line_start\":${CANDIDATE_STARTS[$i]},"
      echo -n "\"line_end\":${CANDIDATE_ENDS[$i]}}"
    done
    echo -n "],"
  fi

  echo -n "\"warnings\":["
  for (( i=0; i<WARN_COUNT; i++ )); do
    (( i > 0 )) && echo -n ","
    echo -n "\"$(json_escape_str "${WARN_MSGS[$i]}")\""
  done
  echo -n "],"

  echo -n "\"errors\":["
  for (( i=0; i<ERR_COUNT; i++ )); do
    (( i > 0 )) && echo -n ","
    echo -n "{\"path\":\"$(json_escape_str "${ERR_PATHS[$i]}")\","
    echo -n "\"error_code\":\"$(json_escape_str "${ERR_CODES[$i]}")\","
    echo -n "\"error_detail\":\"$(json_escape_str "${ERR_DETAILS[$i]}")\"}"
  done
  echo -n "]}"
  echo
}

self_check() {
  local ok=1 cmd
  echo "fread dependency check:"
  for cmd in sed awk grep wc od perl; do
    if has "$cmd"; then
      echo "  $cmd: $(command -v "$cmd")"
    else
      echo "  $cmd: NOT FOUND"
      ok=0
    fi
  done
  if (( ok == 1 )); then
    echo "All dependencies satisfied."
  else
    echo "Some dependencies missing. Run: fread --install-hints"
  fi

  echo
  echo "fread media support (optional):"
  if has python3; then
    echo "  python3: $(command -v python3)"
    if python3 -c 'import PIL' 2>/dev/null; then
      echo "  PIL (Pillow): present  (image support)"
    else
      echo "  PIL (Pillow): NOT FOUND  (images will use stdlib fallback — no resize)"
    fi
    if python3 -c 'import fitz' 2>/dev/null; then
      echo "  fitz (PyMuPDF): present  (primary PDF backend)"
    else
      echo "  fitz (PyMuPDF): NOT FOUND  (will fall back to Poppler)"
    fi
  else
    echo "  python3: NOT FOUND  (media reading disabled)"
  fi
  for cmd in pdftotext pdftoppm; do
    if has "$cmd"; then
      echo "  $cmd: $(command -v "$cmd")  (Poppler fallback)"
    else
      echo "  $cmd: NOT FOUND  (Poppler fallback unavailable)"
    fi
  done

  if (( ok == 1 )); then
    exit 0
  fi
  exit 1
}

install_hints() {
  cat <<'EOF'
fread requires: sed, awk, grep, wc, od, perl

Debian/Ubuntu:
  sudo apt update && sudo apt install -y coreutils perl

Fedora/RHEL:
  sudo dnf install -y coreutils perl

macOS (Homebrew):
  brew install coreutils perl

OPTIONAL: Media support (image + PDF reading)

Debian/Ubuntu:
  sudo apt install -y python3-pil poppler-utils
  pip install --user pymupdf

Fedora/RHEL:
  sudo dnf install -y python3-pillow poppler-utils
