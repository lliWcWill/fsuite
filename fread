DEFAULT_MAX_LINES=0
DEFAULT_MAX_BYTES=0
DEFAULT_BEFORE=5
DEFAULT_AFTER=10
DEFAULT_MAX_FILES=10
TOKEN_ESTIMATOR="bytes_div_3_conservative"

