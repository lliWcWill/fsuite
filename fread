--version) echo "fread $VERSION"; exit 0 ;;
-h|--help) usage; exit 0 ;;
# ── Media flags ───────────────────────────────────────────────
--meta-only)
    MEDIA_META_ONLY=1
    _TELEM_FLAGS+=" --meta-only"
    shift
    ;;
--render)
    MEDIA_RENDER=1
    _TELEM_FLAGS+=" --render"
    shift
    ;;
--pages)
    [[ -n "${2:-}" ]] || die "Missing value for --pages"
    MEDIA_PAGES="$2"
    _TELEM_FLAGS+=" --pages $2"
    shift 2
    ;;
--no-resize)
    MEDIA_NO_RESIZE=1
    _TELEM_FLAGS+=" --no-resize"
    shift
    ;;
--max-pages)
    [[ -n "${2:-}" ]] || die "Missing value for --max-pages"
    [[ "$2" =~ ^[0-9]+$ ]] || die "--max-pages must be an integer"
    MEDIA_MAX_PAGES="$2"
    _TELEM_FLAGS+=" --max-pages $2"
    shift 2
    ;;
--max-tokens)
    [[ -n "${2:-}" ]] || die "Missing value for --max-tokens"
    [[ "$2" =~ ^[0-9]+$ ]] || die "--max-tokens must be an integer"
    MEDIA_MAX_TOKENS="$2"
    _TELEM_FLAGS+=" --max-tokens $2"
    shift 2
    ;;
--no-ingest)
    MEDIA_NO_INGEST=1
    _TELEM_FLAGS+=" --no-ingest"
    shift
    ;;
    --) shift; break ;;
    -*) die "Unknown option: $1 (try --help)" ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done
while [[ $# -gt 0 ]]; do POSITIONAL+=("$1"); shift; done

_TELEM_FLAGS+=" -o ${OUTPUT}"

if (( NO_TRUNCATE == 1 )); then
  MAX_LINES=0
  MAX_BYTES=0
  TOKEN_BUDGET=0
fi

case "$OUTPUT" in
  pretty|json|paths) ;;
  *) die "Invalid --output: $OUTPUT" ;;
esac

if (( ALL_MATCHES == 1 )) && [[ -z "$AROUND_PATTERN" ]]; then
  die "--all-matches is only valid with --around"
fi

selector_count=0
[[ -n "$RANGE_SPEC" ]] && selector_count=$((selector_count + 1))
(( HEAD_N > 0 )) && selector_count=$((selector_count + 1))
(( TAIL_N > 0 )) && selector_count=$((selector_count + 1))
(( AROUND_LINE > 0 )) && selector_count=$((selector_count + 1))
[[ -n "$AROUND_PATTERN" ]] && selector_count=$((selector_count + 1))
(( selector_count > 1 )) && die "Choose only one of: --lines, --head, --tail, --around-line, --around"
if [[ -n "$SYMBOL_NAME" ]] && (( selector_count > 0 )); then
  die "Choose either --symbol or one of: --lines, --head, --tail, --around-line, --around"
fi

TARGET_PATH="${POSITIONAL[0]:-}"

# -------------------------
# Multi-path fallback resolution
# -------------------------
MULTI_PATH_NO_MATCH=0
if [[ -n "$MULTI_PATHS" ]]; then
  # --paths takes priority over positional path
  if [[ -n "$TARGET_PATH" ]]; then
    add_warning "Both positional path and --paths provided; --paths takes priority"
  fi
  TARGET_PATH=""
  RESOLVED_PATH=""
  split_multi_paths "$MULTI_PATHS"
  MULTI_PATH_TOTAL=${#_MULTI_PATH_ARR[@]}
  _mp_found=0
  MULTI_PATH_NO_MATCH=0
  _mp_tried=()
  for _mp in "${_MULTI_PATH_ARR[@]}"; do
    # Trim whitespace and expand ~
    _mp="${_mp#"${_mp%%[![:space:]]*}"}"
    _mp="${_mp%"${_mp##*[![:space:]]}"}"
    _mp="${_mp/#\~/$HOME}"
    _mp_tried+=("$_mp")
    # Symbol mode accepts either a directory scope or an exact file candidate.
    if [[ -n "${SYMBOL_NAME:-}" ]]; then
      [[ -d "$_mp" || -f "$_mp" ]] || continue
    else
      [[ -f "$_mp" ]] || continue
    fi
    TARGET_PATH="$_mp"
    RESOLVED_PATH="$_mp"
    _mp_found=1
    break
  done
  if (( _mp_found == 0 )); then
    # No match found — record error for JSON renderer, don't call die
    add_error "<<multipath>>" "no_match" "No file found in paths candidates: ${_mp_tried[*]}"
    TARGET_PATH=""
    RESOLVED_PATH=""
    MULTI_PATH_NO_MATCH=1
  fi
  unset _mp_found _mp_tried _mp _MULTI_PATH_ARR
fi

if (( FROM_STDIN == 1 )); then
  [[ -n "$STDIN_FORMAT" ]] || die "--from-stdin requires --stdin-format=paths|unified-diff"
  case "$STDIN_FORMAT" in
    paths) MODE="stdin_paths" ;;
    unified-diff) MODE="stdin_unified_diff" ;;
    *) die "Invalid --stdin-format: $STDIN_FORMAT (expected paths or unified-diff)" ;;
  esac
  if (( selector_count > 0 )) || [[ -n "$TARGET_PATH" ]] || [[ -n "$SYMBOL_NAME" ]]; then
    die "File selectors and positional path are not valid with --from-stdin"
  fi
else
if (( MULTI_PATH_NO_MATCH == 1 )); then
compute_next_hint
if [[ "$OUTPUT" == "json" ]]; then
render_json
elif [[ "$OUTPUT" == "paths" ]]; then
render_paths
else
render_pretty
fi
exit 1
fi
if [[ -z "$TARGET_PATH" ]] && (( ERR_COUNT == 0 )); then
die "Missing file argument. Try: fread --help"
fi
fi

# -------------------------
# Dispatch
# -------------------------
if (( FROM_STDIN == 1 )); then
  if [[ "$STDIN_FORMAT" == "paths" ]]; then
    process_stdin_paths "$MAX_FILES"
  else
    process_stdin_unified_diff "$BEFORE" "$AFTER"
  fi
elif [[ -n "$SYMBOL_NAME" ]]; then
  MODE="symbol"
  if resolve_symbol_request "$TARGET_PATH" >/dev/null; then
    process_single_file "$SYMBOL_RESOLUTION_PATH" "$SYMBOL_RESOLUTION_LINE_START" "$SYMBOL_RESOLUTION_LINE_END" "$SYMBOL_RESOLUTION_LINE_START"
  fi
elif [[ -n "$AROUND_PATTERN" ]]; then
  MODE="around"
  process_around_pattern "$TARGET_PATH" "$AROUND_PATTERN" "$BEFORE" "$AFTER" "$ALL_MATCHES"
elif (( AROUND_LINE > 0 )); then
  MODE="around_line"
  process_around_line "$TARGET_PATH" "$AROUND_LINE" "$BEFORE" "$AFTER"
elif [[ -n "$RANGE_SPEC" ]]; then
  MODE="range"
  range_start="${RANGE_SPEC%%:*}"
  range_end="${RANGE_SPEC##*:}"
  process_single_file "$TARGET_PATH" "$range_start" "$range_end"
elif (( HEAD_N > 0 )); then
  MODE="head"
  process_single_file "$TARGET_PATH" 1 "$HEAD_N"
elif (( TAIL_N > 0 )); then
  MODE="tail"
  total="$(count_file_lines "$TARGET_PATH" 2>/dev/null || echo 0)"
  [[ "$total" =~ ^[0-9]+$ ]] || total=0
  tail_start=$((total - TAIL_N + 1))
  (( tail_start < 1 )) && tail_start=1
  process_single_file "$TARGET_PATH" "$tail_start" "$total" "" "$total"
else
  MODE="file"
  process_single_file "$TARGET_PATH"
fi

compute_next_hint

if [[ "$OUTPUT" == "json" ]]; then
  render_json
elif [[ "$OUTPUT" == "paths" ]]; then
  render_paths
else
  render_pretty
fi

if (( ERR_COUNT > 0 )) && (( CHUNK_COUNT == 0 )); then
  exit 1
fi
exit 0
