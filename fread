set_symbol_resolution() {
  SYMBOL_RESOLUTION_PATH="$1"
  SYMBOL_RESOLUTION_SYMBOL="$2"
  SYMBOL_RESOLUTION_TYPE="$3"
  SYMBOL_RESOLUTION_LINE_START="$4"
  SYMBOL_RESOLUTION_LINE_END="$5"
