        "import:^[[:space:]]*import[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*package[[:space:]]+[a-zA-Z_]"
      )
    ;;
    zsh)
      # Extends bash with zsh-specific patterns
      patterns=(
        "function:^[[:space:]]*(function[[:space:]]+)?[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\(\)"
        "import:^[[:space:]]*(source|\.)[[:space:]]"
        "export:^[[:space:]]*export[[:space:]]"
        "constant:^[[:space:]]*(typeset|local|readonly|declare)[[:space:]]"
        "function:^[[:space:]]*autoload[[:space:]]"
        "function:^[[:space:]]*compdef[[:space:]]"
        "constant:^[[:space:]]*zstyle[[:space:]]"
      )
    ;;
    dart)
      patterns=(
        "class:^[[:space:]]*(abstract[[:space:]]+)?(class|mixin|extension)[[:space:]]+[a-zA-Z_]"
        "type:^[[:space:]]*enum[[:space:]]+[a-zA-Z_]"
        "type:^[[:space:]]*typedef[[:space:]]"
        "function:^[[:space:]]*(static[[:space:]]+)?[a-zA-Z_<>?][a-zA-Z0-9_<>?]*[[:space:]]+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\("
        "import:^[[:space:]]*import[[:space:]]"
        "import:^[[:space:]]*export[[:space:]]"
        "import:^[[:space:]]*part[[:space:]]"
      )
    ;;
    objc)
      patterns=(
        "class:^[[:space:]]*@interface[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*@implementation[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*@protocol[[:space:]]+[a-zA-Z_]"
        "function:^[[:space:]]*[-+][[:space:]]*\("
        "import:^[[:space:]]*#import[[:space:]]"
        "import:^[[:space:]]*#include[[:space:]]"
        "constant:^[[:space:]]*@property[[:space:]]"
        "type:^[[:space:]]*typedef[[:space:]]"
      )
    ;;
    haskell)
      patterns=(
        "class:^[[:space:]]*module[[:space:]]+[A-Z]"
        "class:^[[:space:]]*(data|newtype)[[:space:]]+[A-Z]"
        "type:^[[:space:]]*type[[:space:]]+[A-Z]"
        "class:^[[:space:]]*class[[:space:]]+[A-Z]"
        "function:^[[:space:]]*instance[[:space:]]"
        "function:^[a-z_][a-zA-Z0-9_']*[[:space:]]*::"
        "import:^[[:space:]]*import[[:space:]]"
      )
    ;;
    julia)
      patterns=(
        "function:^[[:space:]]*(function|macro)[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*(abstract[[:space:]]+type|struct|mutable[[:space:]]+struct)[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*module[[:space:]]+[a-zA-Z_]"
        "type:^[[:space:]]*const[[:space:]]+[a-zA-Z_]"
        "import:^[[:space:]]*(using|import)[[:space:]]"
        "export:^[[:space:]]*export[[:space:]]"
      )
    ;;
    powershell)
      patterns=(
        "function:^[[:space:]]*(function|filter)[[:space:]]+[a-zA-Z_]"
        "class:^[[:space:]]*class[[:space:]]+[a-zA-Z_]"
        "type:^[[:space:]]*enum[[:space:]]+[a-zA-Z_]"
        "import:^[[:space:]]*(Import-Module|using[[:space:]]+module)[[:space:]]"
        "import:^[[:space:]]*\.[[:space:]]"
        "constant:^[[:space:]]*\[Parameter"
        "constant:^[[:space:]]*param[[:space:]]*\("
      )
    ;;
    groovy)
      patterns=(
        "class:^[[:space:]]*(class|interface|trait|enum)[[:space:]]+[a-zA-Z_]"
        "function:^[[:space:]]*(def|void|String|int|boolean|static)[[:space:]]+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\("
        "class:^[[:space:]]*pipeline[[:space:]]*\{"
        "function:^[[:space:]]*stage[[:space:]]*\("
        "import:^[[:space:]]*import[[:space:]]"
        "constant:^[[:space:]]*@[A-Z][a-zA-Z]*"
      )
    ;;
    ocaml)
      patterns=(
        "class:^[[:space:]]*module[[:space:]]+[A-Z]"
        "function:^[[:space:]]*let[[:space:]]+[a-z_][a-zA-Z0-9_']*"
        "type:^[[:space:]]*type[[:space:]]+[a-z_]"
        "import:^[[:space:]]*open[[:space:]]+[A-Z]"
        "constant:^[[:space:]]*val[[:space:]]+[a-z_]"
        "class:^[[:space:]]*class[[:space:]]+[a-z_]"
      )
    ;;
    clojure)
      patterns=(
        "function:^[[:space:]]*\(defn[[:space:]]"
        "function:^[[:space:]]*\(defn-[[:space:]]"
        "constant:^[[:space:]]*\(def[[:space:]]"
        "class:^[[:space:]]*\(ns[[:space:]]"
        "function:^[[:space:]]*\(defmacro[[:space:]]"
        "class:^[[:space:]]*\(defprotocol[[:space:]]"
        "class:^[[:space:]]*\(defrecord[[:space:]]"
        "type:^[[:space:]]*\(defmulti[[:space:]]"
        "import:^[[:space:]]*\(require[[:space:]]"
        "import:^[[:space:]]*\(use[[:space:]]"
      )
    ;;
    wasm)
      patterns=(
        "class:^[[:space:]]*\(module"
        "function:^[[:space:]]*\(func[[:space:]]"
        "export:^[[:space:]]*\(export[[:space:]]"
        "import:^[[:space:]]*\(import[[:space:]]"
        "type:^[[:space:]]*\(type[[:space:]]"
        "constant:^[[:space:]]*\(global[[:space:]]"
        "constant:^[[:space:]]*\(memory[[:space:]]"
        "constant:^[[:space:]]*\(table[[:space:]]"
      )
    ;;
    markdown)
      # ATX headings: allow 0-3 leading spaces, optional trailing #
      patterns=(
        "class:^[[:space:]]{0,3}#{1,2}[[:space:]]"
        "function:^[[:space:]]{0,3}#{3,6}[[:space:]]"
        "import:(^|[^!])\[[^]]+\]\([^)]+\)"
        "import:^[[:space:]]{0,3}\[[^]]+\]:[[:space:]]"
        "constant:^[[:space:]]{0,3}\`\`\`"
        "constant:^[[:space:]]{0,3}~~~"
      )
      ;;
  esac

  # Collect all matches to a temp file, then deduplicate by line number (first type wins)
  local sym_type regex
  local _tmp_raw
  _tmp_raw="$(mktemp)"
  for pat_spec in "${patterns[@]}"; do
    sym_type="${pat_spec%%:*}"
    regex="${pat_spec#*:}"
    # grep -n -E -I: line numbers, extended regex, skip binary
    while IFS= read -r line; do
      local lineno="${line%%:*}"
      local text="${line#*:}"
      # Calculate indent: count leading whitespace, tabs as 4 spaces
      local stripped="${text#"${text%%[![:space:]]*}"}"
      local leading="${text%"$stripped"}"
      local indent=0
      local ch
      for (( _i=0; _i<${#leading}; _i++ )); do
        ch="${leading:_i:1}"
        if [[ "$ch" == $'\t' ]]; then
          indent=$(( indent + 4 ))
        else
          indent=$(( indent + 1 ))
        fi
      done
      # Trim trailing whitespace from text
      text="${text%"${text##*[![:space:]]}"}"
      printf '%s\t%s\t%s\t%s\n' "$lineno" "$sym_type" "$indent" "$text" >> "$_tmp_raw"
    done < <(grep -n -E -I "$regex" -- "$file" 2>/dev/null || true)
  done
  # --- Markdown: suppress symbols inside fences/frontmatter, detect setext headings ---
  # Always run for markdown: setext headings are detected here, not by grep
  if [[ "$lang" == "markdown" ]]; then
    touch "$_tmp_raw"  # Ensure file exists even if grep found nothing
    local _tmp_filtered
    _tmp_filtered="$(mktemp)"

    # Build suppressed-line ranges using awk on the original file,
    # then filter the raw symbols against those ranges.
    # Also detect setext headings (line above === or --- underline).
    awk -v raw_file="$_tmp_raw" -v filtered_file="$_tmp_filtered" '
    BEGIN {
      in_fence = 0; in_frontmatter = 0; fence_char = ""
      n_suppress = 0; n_setext = 0
    }
    function leading_indent_ok(line,    i, ch, count) {
      count = 0
      for (i = 1; i <= length(line); i++) {
        ch = substr(line, i, 1)
        if (ch == " " || ch == "\t") count++
        else break
      }
      return count <= 3
    }
    function line_after_indent(line,    i, ch) {
      for (i = 1; i <= length(line); i++) {
        ch = substr(line, i, 1)
        if (ch != " " && ch != "\t") return substr(line, i)
      }
      return ""
    }
    function is_fence_line(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return (index(trimmed, "```") == 1 || index(trimmed, "~~~") == 1)
    }
    function is_setext_h1(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return trimmed ~ /^==+[[:space:]]*$/
    }
    function is_setext_h2(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return trimmed ~ /^--+[[:space:]]*$/
    }
    function is_list_item(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return (trimmed ~ /^[-*+][[:space:]]/ || trimmed ~ /^[0-9]+[.)][[:space:]]/)
    }
    function is_blockquote(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return trimmed ~ /^>/
    }
    function is_atx_heading(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return trimmed ~ /^#/
    }
    function is_html_block(line,    trimmed) {
      if (!leading_indent_ok(line)) return 0
      trimmed = line_after_indent(line)
      return trimmed ~ /^</
    }
    # Frontmatter: --- at line 1 opens, next --- closes
    NR == 1 && /^---[[:space:]]*$/ { in_frontmatter = 1; next }
    in_frontmatter && /^---[[:space:]]*$/ { in_frontmatter = 0; next }
    in_frontmatter { suppress[NR] = 1; n_suppress++; next }

    # Fenced code blocks: ``` or ~~~ (with 0-3 leading spaces)
    is_fence_line($0) {
      if (!in_fence) {
        in_fence = 1
        # Determine fence char for matching close
        if (index(line_after_indent($0), "~~~") == 1) fence_char = "~~~"
        else fence_char = "```"
        # The fence-open line itself is NOT suppressed (shows as constant)
        next
      } else {
        # Check if this line closes the current fence
        if ((fence_char == "```" && index(line_after_indent($0), "```") == 1) ||
            (fence_char == "~~~" && index(line_after_indent($0), "~~~") == 1)) {
          in_fence = 0; fence_char = ""
          # Fence-close line is suppressed (not structural)
          suppress[NR] = 1; n_suppress++
          next
        }
      }
    }
    in_fence { suppress[NR] = 1; n_suppress++; next }

    # Setext headings: current line is ===+ or ---+ (not in fence),
    # and we have accumulated paragraph text above it.
    # CommonMark: the full paragraph becomes the heading, not just the last line.
    is_setext_h1($0) && para_len > 0 && !in_fence {
      setext_lines[n_setext] = para_start "\tclass\t0\t" para_buf
      n_setext++
      para_len = 0; para_buf = ""; para_start = 0
      next
    }
    is_setext_h2($0) && para_len > 0 && !in_fence {
      setext_lines[n_setext] = para_start "\tclass\t0\t" para_buf
      n_setext++
      para_len = 0; para_buf = ""; para_start = 0
      next
    }
    {
      # Determine if this line is paragraph content
      # NOT paragraph: blank, list item (- * + or 1.), blockquote (>),
      # ATX heading (#), HTML (<), thematic break (--- *** ___), fenced code
      is_para = 1
      if ($0 ~ /^[[:space:]]*$/) is_para = 0
      else if (is_list_item($0)) is_para = 0
      else if (is_blockquote($0)) is_para = 0
      else if (is_atx_heading($0)) is_para = 0
      else if (is_html_block($0)) is_para = 0

      if (is_para) {
        if (para_len == 0) {
          para_buf = $0; para_start = NR
        } else {
          para_buf = para_buf " " $0
        }
        para_len++
      } else {
        # Non-paragraph line resets the accumulator
        para_len = 0; para_buf = ""; para_start = 0
      }
    }
    END {
      # Filter raw symbols: remove suppressed lines
      while ((getline line < raw_file) > 0) {
        split(line, parts, "\t")
        lineno = parts[1] + 0
        if (!(lineno in suppress)) {
          print line >> filtered_file
        }
      }
      close(raw_file)
      # Append setext headings
      for (i = 0; i < n_setext; i++) {
        print setext_lines[i] >> filtered_file
      }
      close(filtered_file)
    }
    ' "$file"

    mv "$_tmp_filtered" "$_tmp_raw"
  fi

  # Deduplicate: sort by line number, keep first occurrence per line
  if [[ -s "$_tmp_raw" ]]; then
    sort -t$'\t' -k1,1n -s "$_tmp_raw" | awk -F'\t' '!seen[$1]++'
  fi
  rm -f "$_tmp_raw"
}

extract_symbol_name() {
  local sym_type="$1"
  local text="$2"
  local trimmed before_paren name go_method_re

  trimmed="${text#"${text%%[![:space:]]*}"}"

  case "$sym_type" in
    function)
      # Markdown headings: "### Subsection ###" → "Subsection"
      if [[ "$trimmed" =~ ^(#{1,6})[[:space:]]+(.*) ]]; then
        local _md_title="${BASH_REMATCH[2]}"
        # CommonMark: trailing # is a closing sequence ONLY when preceded by space/tab
        # "## Title ##" → "Title", but "## Topic##" → "Topic##" (literal)
        local _re_trail_hash='^(.*[^[:space:]#])[[:space:]]+#+[[:space:]]*$'
        if [[ "$_md_title" =~ $_re_trail_hash ]]; then
          _md_title="${BASH_REMATCH[1]}"
        fi
        _md_title="${_md_title%"${_md_title##*[![:space:]]}"}"
        printf '%s\n' "$_md_title"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])def[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])function[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
      fi
      go_method_re='(^|[[:space:]])func[[:space:]]+\([^)]*\)[[:space:]]+([_[:alpha:]][_[:alnum:]]*)'
      if [[ "$trimmed" =~ $go_method_re ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])(func|fun|fn)[[:space:]]+([_[:alpha:]][_[:alnum:].:]*) ]]; then
        name="${BASH_REMATCH[3]}"
        name="${name##*.}"
        name="${name##*::}"
        printf '%s\n' "$name"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])(const|let|var)[[:space:]]+([_[:alpha:]][_[:alnum:]]*)[[:space:]]*= ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      # TS/JS class property with modifiers: "private readonly handler ="
      if [[ "$trimmed" =~ ^((override|static|abstract|protected|private|public|readonly|async)[[:space:]]+)+([_[:alpha:]][_[:alnum:]]*)[[:space:]]*[=:] ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      before_paren="${trimmed%%(*}"
      if [[ "$before_paren" != "$trimmed" ]]; then
        name="${before_paren##* }"
        name="${name##*&}"
        name="${name##*\*}"
        name="${name##*.}"
        name="${name##*::}"
        if [[ "$name" =~ ^[_[:alpha:]][_[:alnum:]]*$ ]]; then
          printf '%s\n' "$name"
          return 0
        fi
      fi
      ;;
    class)
      # Markdown headings: "## Title ##" → "Title"
      if [[ "$trimmed" =~ ^(#{1,6})[[:space:]]+(.*) ]]; then
        local _md_title="${BASH_REMATCH[2]}"
        # CommonMark: trailing # only when preceded by space/tab
        local _re_trail_hash='^(.*[^[:space:]#])[[:space:]]+#+[[:space:]]*$'
        if [[ "$_md_title" =~ $_re_trail_hash ]]; then
          _md_title="${BASH_REMATCH[1]}"
        fi
        _md_title="${_md_title%"${_md_title##*[![:space:]]}"}"
        printf '%s\n' "$_md_title"
        return 0
      fi
      if [[ "$trimmed" =~ ^\<([A-Za-z_][A-Za-z0-9_.-]*) ]]; then
        name="${BASH_REMATCH[1]}"
        name="${name##*.}"
        printf '%s\n' "$name"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])(class|struct|enum|interface|protocol|trait|module|object|extension|actor)[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      ;;
    type)
      if [[ "$trimmed" =~ (^|[[:space:]])(interface|typealias|type|enum|associatedtype)[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      ;;
    constant)
      if [[ "$trimmed" =~ (^|[[:space:]])(const|let|var|readonly|val|ENV|ARG)[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      if [[ "$trimmed" =~ ^#define[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
      fi
      ;;
    export)
      if [[ "$trimmed" =~ ^exports\.([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
      fi
      if [[ "$trimmed" =~ module\.exports\.([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])(function|class|const|let|var|interface|type|enum)[[:space:]]+([_[:alpha:]][_[:alnum:]]*) ]]; then
        printf '%s\n' "${BASH_REMATCH[3]}"
        return 0
      fi
      ;;
    import)
      if [[ "$trimmed" =~ (^|[[:space:]])import[[:space:]]+([_[:alpha:]][_[:alnum:]]*)[[:space:]]+from[[:space:]] ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])from[[:space:]]+([_[:alpha:]][_[:alnum:].:/-]*)[[:space:]]+import[[:space:]] ]]; then
        name="${BASH_REMATCH[2]}"
        name="${name##*/}"
        name="${name##*.}"
        name="${name##*::}"
        printf '%s\n' "$name"
        return 0
      fi
      if [[ "$trimmed" =~ require\([\"\']([^\"\']+)[\"\']\) ]]; then
        name="${BASH_REMATCH[1]}"
        name="${name##*/}"
        printf '%s\n' "$name"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])import[[:space:]]+[\"\']([^\"\']+)[\"\'] ]]; then
        name="${BASH_REMATCH[2]}"
        name="${name##*/}"
        printf '%s\n' "$name"
        return 0
      fi
      if [[ "$trimmed" =~ (^|[[:space:]])use[[:space:]]+([_[:alpha:]][_[:alnum:].:]*) ]]; then
        name="${BASH_REMATCH[2]}"
        name="${name##*.}"
        name="${name##*::}"
        printf '%s\n' "$name"
        return 0
      fi
      ;;
  esac

  return 1
}

# -------------------------
# Main processing loop
# -------------------------
# We collect all symbols, then output
TMP_RAW_SYMBOLS="$(mktemp)"
TMP_SYMBOLS="$(mktemp)"
TMP_MATCHES="$(mktemp)"

for file in "${FILE_LIST[@]}"; do
  [[ -f "$file" ]] || continue
  TOTAL_FILES_SCANNED=$((TOTAL_FILES_SCANNED + 1))

  lang=$(detect_language "$file")
  [[ -z "$lang" ]] && continue

  # Extract symbols
  local_symbols=$(extract_symbols "$file" "$lang") || true
  [[ -z "$local_symbols" ]] && continue

  # Apply filters
  filtered_symbols=""
  while IFS=$'\t' read -r lineno sym_type indent text; do
    [[ -z "$lineno" ]] && continue

    # --no-imports filter (unless -t import overrides)
    if (( NO_IMPORTS == 1 )) && [[ "$sym_type" == "import" ]] && [[ "$FILTER_TYPE" != "import" ]]; then
      continue
    fi

    # -t type filter applies during raw collection unless --name is active.
    if [[ -z "$NAME_QUERY" ]] && [[ -n "$FILTER_TYPE" ]] && [[ "$sym_type" != "$FILTER_TYPE" ]]; then
      continue
    fi

    filtered_symbols+="${file}"$'\t'"${lineno}"$'\t'"${sym_type}"$'\t'"${indent}"$'\t'"${text}"$'\n'
  done <<< "$local_symbols"

  [[ -z "$filtered_symbols" ]] && continue

  printf '%s' "$filtered_symbols" >> "$TMP_RAW_SYMBOLS"
done

# Count total symbols
if [[ -s "$TMP_RAW_SYMBOLS" ]]; then
  TOTAL_SYMBOLS=$(wc -l < "$TMP_RAW_SYMBOLS")
  TOTAL_SYMBOLS="${TOTAL_SYMBOLS//[[:space:]]/}"
else
  TOTAL_SYMBOLS=0
fi

# Optional post-extraction symbol-name ranking/filtering.
if [[ -n "$NAME_QUERY" ]] && [[ -s "$TMP_RAW_SYMBOLS" ]]; then
  while IFS=$'\t' read -r _file _lineno _sym_type _indent _text; do
    [[ -z "$_file" ]] && continue
    _symbol_name="$(extract_symbol_name "$_sym_type" "$_text" || true)"
    [[ -n "$_symbol_name" ]] || continue

    _match_kind=""
    _match_rank_key=""
    if [[ "$_symbol_name" == "$NAME_QUERY" ]]; then
      _match_kind="exact"
      _match_rank_key="0"
    elif [[ "$_symbol_name" == *"$NAME_QUERY"* ]]; then
      _match_kind="substring"
      _match_rank_key="1"
    else
      continue
    fi

    if [[ -n "$FILTER_TYPE" ]] && [[ "$_sym_type" != "$FILTER_TYPE" ]]; then
      continue
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$_match_rank_key" "$_file" "$_lineno" "$_sym_type" "$_symbol_name" "$_indent" "$_text" "$_match_kind" >> "$TMP_MATCHES"
  done < "$TMP_RAW_SYMBOLS"

  if [[ -s "$TMP_MATCHES" ]]; then
    _tmp_sorted_matches="$(mktemp)"
    sort -t$'\t' -k1,1n -k2,2 -k3,3n -k4,4 "$TMP_MATCHES" > "$_tmp_sorted_matches"
    mv "$_tmp_sorted_matches" "$TMP_MATCHES"

    while IFS=$'\t' read -r _match_rank_key _file _lineno _sym_type _symbol_name _indent _text _match_kind; do
      printf '%s\t%s\t%s\t%s\t%s\n' "$_file" "$_lineno" "$_sym_type" "$_indent" "$_text" >> "$TMP_SYMBOLS"
    done < "$TMP_MATCHES"
  fi
elif [[ -s "$TMP_RAW_SYMBOLS" ]]; then
  cp "$TMP_RAW_SYMBOLS" "$TMP_SYMBOLS"
fi

OUTPUT_SYMBOLS=0
if [[ -s "$TMP_SYMBOLS" ]]; then
  OUTPUT_SYMBOLS=$(wc -l < "$TMP_SYMBOLS")
  OUTPUT_SYMBOLS="${OUTPUT_SYMBOLS//[[:space:]]/}"
fi

TOTAL_FILES_WITH_SYMBOLS=0
unset LANG_COUNTS 2>/dev/null || true
declare -A LANG_COUNTS=()
declare -A _seen_symbol_files=()
if [[ -s "$TMP_SYMBOLS" ]]; then
  while IFS=$'\t' read -r _f _lineno _sym_type _indent _text; do
    [[ -z "$_f" ]] && continue
    if [[ -z "${_seen_symbol_files[$_f]:-}" ]]; then
      _seen_symbol_files[$_f]=1
      TOTAL_FILES_WITH_SYMBOLS=$((TOTAL_FILES_WITH_SYMBOLS + 1))
      _lang_for_count=$(detect_language "$_f")
      [[ -n "$_lang_for_count" ]] && LANG_COUNTS[$_lang_for_count]=$(( ${LANG_COUNTS[$_lang_for_count]:-0} + 1 ))
    fi
  done < "$TMP_SYMBOLS"
fi
unset _seen_symbol_files

# Apply max-symbols cap
SHOWN_SYMBOLS="$OUTPUT_SYMBOLS"
TRUNCATED=false
if (( OUTPUT_SYMBOLS > MAX_SYMBOLS )); then
  SHOWN_SYMBOLS="$MAX_SYMBOLS"
  TRUNCATED=true
fi

# -------------------------
# Resolve path for output
# -------------------------
if (( SINGLE_FILE == 1 )); then
  ABS_PATH="$(cd "$(dirname "$TARGET")" 2>/dev/null && echo "$(pwd)/$(basename "$TARGET")")" || ABS_PATH="$TARGET"
elif [[ -n "$TARGET" ]] && [[ -d "$TARGET" ]]; then
  ABS_PATH="$(cd "$TARGET" 2>/dev/null && pwd)" || ABS_PATH="$TARGET"
else
  ABS_PATH=""
fi

# -------------------------
# Output: paths
# -------------------------
if [[ "$OUTPUT" == "paths" ]]; then
  if [[ -s "$TMP_SYMBOLS" ]]; then
    head -n "$SHOWN_SYMBOLS" "$TMP_SYMBOLS" | cut -f1 | sort -u
  fi
  exit 0
fi

# -------------------------
# Output: json
# -------------------------
if [[ "$OUTPUT" == "json" ]]; then
  # Determine mode
  _mode="directory"
  (( FILES_FROM_STDIN == 1 )) && _mode="stdin_files"
  (( SINGLE_FILE == 1 )) && _mode="single_file"

  echo -n "{"
  echo -n "\"tool\":\"fmap\","
  echo -n "\"version\":\"$VERSION\","
  echo -n "\"mode\":\"$_mode\","
  if [[ -n "$ABS_PATH" ]]; then
    echo -n "\"path\":\"$(printf "%s" "$ABS_PATH" | json_escape)\","
  fi
  echo -n "\"total_files_scanned\":$TOTAL_FILES_SCANNED,"
  echo -n "\"total_files_with_symbols\":$TOTAL_FILES_WITH_SYMBOLS,"
  echo -n "\"total_symbols\":$TOTAL_SYMBOLS,"
  echo -n "\"shown_symbols\":$SHOWN_SYMBOLS,"
  echo -n "\"truncated\":$TRUNCATED,"
  if [[ -n "$NAME_QUERY" ]]; then
    echo -n "\"query\":\"$(printf "%s" "$NAME_QUERY" | json_escape)\","
  fi

  # Languages object
  echo -n "\"languages\":{"
  _lang_first=1
  for _l in "${!LANG_COUNTS[@]}"; do
    (( _lang_first )) || echo -n ","
    _lang_first=0
    echo -n "\"$_l\":${LANG_COUNTS[$_l]}"
  done
  echo -n "},"

  if [[ -n "$NAME_QUERY" ]]; then
    echo -n "\"matches\":["
    if [[ -s "$TMP_MATCHES" ]]; then
      _match_first=1
      _match_rank=0
      while IFS=$'\t' read -r _match_rank_key _file _lineno _sym_type _symbol_name _indent _text _match_kind; do
        (( _match_rank >= SHOWN_SYMBOLS )) && break
        _match_rank=$((_match_rank + 1))
        (( _match_first )) || echo -n ","
        _match_first=0
        echo -n "{\"path\":\"$(printf "%s" "$_file" | json_escape)\","
        echo -n "\"symbol\":\"$(printf "%s" "$_symbol_name" | json_escape)\","
        echo -n "\"symbol_type\":\"$_sym_type\","
        echo -n "\"line_start\":$_lineno,"
        echo -n "\"line_end\":null,"
        echo -n "\"match_kind\":\"$_match_kind\","
        echo -n "\"rank\":$_match_rank}"
      done < "$TMP_MATCHES"
    fi
    echo -n "],"
  fi

  # Files array
  echo -n "\"files\":["

  if [[ -s "$TMP_SYMBOLS" ]]; then
    _sym_count=0
    _file_first=1
    _current_file=""
    _file_sym_count=0
    _file_lang=""
    _file_symbols=""

    _flush_file() {
      if [[ -n "$_current_file" ]]; then
        (( _file_first )) || echo -n ","
        _file_first=0
        echo -n "{\"path\":\"$(printf "%s" "$_current_file" | json_escape)\","
        echo -n "\"language\":\"$_file_lang\","
        echo -n "\"symbol_count\":$_file_sym_count,"
        echo -n "\"symbols\":[${_file_symbols}]}"
      fi
    }

    while IFS=$'\t' read -r _f _lineno _sym_type _indent _text; do
      [[ -z "$_f" ]] && continue
      (( _sym_count >= SHOWN_SYMBOLS )) && break
      _sym_count=$((_sym_count + 1))

      if [[ "$_f" != "$_current_file" ]]; then
        _flush_file
        _current_file="$_f"
        _file_lang=$(detect_language "$_f")
        _file_sym_count=0
        _file_symbols=""
      fi

      _file_sym_count=$((_file_sym_count + 1))
      [[ -n "$_file_symbols" ]] && _file_symbols+=","
      _escaped_text=$(printf "%s" "$_text" | json_escape)
      _file_symbols+="{\"line\":$_lineno,\"type\":\"$_sym_type\",\"indent\":$_indent,\"text\":\"$_escaped_text\"}"
    done < "$TMP_SYMBOLS"
    _flush_file
  fi

  echo -n "]}"
  echo
  exit 0
fi

# -------------------------
# Output: pretty
# -------------------------
_mode_label="directory"
(( FILES_FROM_STDIN == 1 )) && _mode_label="stdin_files"
(( SINGLE_FILE == 1 )) && _mode_label="single_file"

if (( QUIET == 0 )); then
  # Build optional languages suffix
  _lang_line=""
  for _l in "${!LANG_COUNTS[@]}"; do
    [[ -n "$_lang_line" ]] && _lang_line+=" "
    _lang_line+="${_l}=${LANG_COUNTS[$_l]}"
  done
  _lang_suffix=""
  [[ -n "$_lang_line" ]] && _lang_suffix=" languages: $_lang_line"

  echo "fmap (${ABS_PATH:-stdin})"
  if [[ -n "$NAME_QUERY" ]]; then
    echo "  mode: $_mode_label files_scanned: $TOTAL_FILES_SCANNED (cap=$MAX_FILES) symbols: $SHOWN_SYMBOLS matched (from $TOTAL_SYMBOLS total, cap=$MAX_SYMBOLS) query: $NAME_QUERY$_lang_suffix"
  else
    echo "  mode: $_mode_label files_scanned: $TOTAL_FILES_SCANNED (cap=$MAX_FILES) symbols: $TOTAL_SYMBOLS (cap=$MAX_SYMBOLS)$_lang_suffix"
  fi
fi

# truncation warning shown after symbols

if [[ -s "$TMP_SYMBOLS" ]]; then
  _sym_count=0
  _current_file=""

  while IFS=$'\t' read -r _f _lineno _sym_type _indent _text; do
    [[ -z "$_f" ]] && continue
    (( _sym_count >= SHOWN_SYMBOLS )) && break
    _sym_count=$((_sym_count + 1))

    if [[ "$_f" != "$_current_file" ]]; then
      _current_file="$_f"
      _file_lang=$(detect_language "$_f")
      echo ""
      echo "  $_f ($_file_lang)"
    fi

    # Indent display: 2 spaces base + indent/4 * 2 for nesting
    _display_indent="    "
    if (( _indent > 0 )); then
      _nest_level=$(( _indent / 4 ))
      for (( _i=0; _i<_nest_level; _i++ )); do
        _display_indent+="  "
      done
    fi
    echo "${_display_indent}[$_lineno] $_sym_type: $_text"
  done < "$TMP_SYMBOLS"
elif [[ -n "$NAME_QUERY" ]]; then
  echo "  no symbol matches for query: $NAME_QUERY"
fi

if [[ "$TRUNCATED" == "true" ]]; then
  echo ""
  if [[ -n "$NAME_QUERY" ]]; then
    echo "  ⚠ Showing $SHOWN_SYMBOLS of $OUTPUT_SYMBOLS matched symbols (cap=$MAX_SYMBOLS)"
  else
    echo "  ⚠ Showing $SHOWN_SYMBOLS of $TOTAL_SYMBOLS symbols (cap=$MAX_SYMBOLS)"
  fi
fi

exit 0
